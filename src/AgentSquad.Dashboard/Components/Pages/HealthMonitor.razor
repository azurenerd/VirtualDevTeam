@page "/health"
@rendermode InteractiveServer
@using AgentSquad.Core.Agents
@using AgentSquad.Core.Diagnostics
@using AgentSquad.Dashboard.Services
@using AgentSquad.Orchestrator
@using System.Net.Http.Json
@implements IDisposable
@inject IDashboardDataService DataService
@inject DashboardMode Mode
@inject IServiceProvider Services

<PageTitle>AgentSquad — Health Monitor</PageTitle>

<div class="dashboard-header">
    <h1>Health Monitor</h1>
    <span class="header-badge @OverallStatusClass">● @_assessment.OverallStatus</span>
</div>

@* ── Top Row: Status + Phase Timeline ── *@
<div class="health-top-row">
    <div class="health-card status-card">
        <h2>Execution Status</h2>
        <div class="status-grid">
            <div class="status-item">
                <span class="status-label">Phase</span>
                <span class="status-value phase-value">@_assessment.Phase</span>
            </div>
            <div class="status-item">
                <span class="status-label">Uptime</span>
                <span class="status-value">@FormatDuration(_assessment.Uptime)</span>
            </div>
            <div class="status-item">
                <span class="status-label">Working</span>
                <span class="status-value cyan">@_assessment.WorkingAgents / @_assessment.TotalAgents</span>
            </div>
            <div class="status-item">
                <span class="status-label">Compliant</span>
                <span class="status-value @(_assessment.NonCompliantAgents > 0 ? "yellow" : "green")">
                    @_assessment.CompliantAgents / @_assessment.TotalAgents
                </span>
            </div>
            <div class="status-item">
                <span class="status-label">Errors</span>
                <span class="status-value @(_assessment.ErrorAgents > 0 ? "red" : "green")">
                    @_assessment.ErrorAgents
                </span>
            </div>
            <div class="status-item">
                <span class="status-label">Deadlock</span>
                <span class="status-value @(_assessment.HasDeadlock ? "red" : "green")">
                    @(_assessment.HasDeadlock ? "Yes" : "None")
                </span>
            </div>
        </div>
    </div>

    <div class="health-card phase-card">
        <h2>Phase Progression</h2>
        <div class="phase-timeline">
            @foreach (var phase in _assessment.PhaseTimeline)
            {
                <div class="phase-step @(phase.IsCurrent ? "current" : phase.IsCompleted ? "completed" : "pending")">
                    <div class="phase-dot"></div>
                    <div class="phase-info">
                        <span class="phase-name">@phase.Phase</span>
                        @if (phase.CompletedAt.HasValue)
                        {
                            <span class="phase-time">@phase.CompletedAt.Value.ToLocalTime().ToString("HH:mm:ss")</span>
                        }
                        else if (phase.IsCurrent)
                        {
                            <span class="phase-time active">Active</span>
                        }
                    </div>
                </div>
            }
        </div>

        @if (_assessment.NextPhaseGates.Count > 0)
        {
            <div class="gates-section">
                <h3>Next Phase Gates</h3>
                @foreach (var gate in _assessment.NextPhaseGates)
                {
                    <div class="gate-row @(gate.IsMet ? "met" : "unmet")">
                        <span class="gate-icon">@(gate.IsMet ? "✅" : "⬜")</span>
                        <span class="gate-name">@gate.Name</span>
                        <span class="gate-desc">@gate.Description</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

@* ── Assessment / Observations ── *@
<div class="health-card observations-card">
    <h2>System Assessment</h2>
    <div class="observations-list">
        @foreach (var obs in _assessment.Observations)
        {
            <div class="observation-item">
                <span class="obs-bullet">›</span>
                <span class="obs-text">@((MarkupString)FormatObservation(obs))</span>
            </div>
        }
    </div>
</div>

@* ── Execution Flowchart ── *@
<div class="health-card flowchart-card">
    <h2>Execution Timeline</h2>
    <div class="flowchart">
        @{ var milestones = DataService.GetExecutionTimeline(); }
        @if (milestones.Count == 0)
        {
            <div class="flowchart-empty">Pipeline has not started yet.</div>
        }
        else
        {
            @foreach (var (milestone, index) in milestones.Select((m, i) => (m, i)))
            {
                var isLast = index == milestones.Count - 1;
                <div class="flow-node @milestone.Category @(isLast ? "flow-node-active" : "")">
                    <div class="flow-connector">
                        <div class="flow-dot">@milestone.Icon</div>
                        @if (!isLast)
                        {
                            <div class="flow-line"></div>
                        }
                    </div>
                    <div class="flow-content">
                        <div class="flow-title">@milestone.Title</div>
                        @if (!string.IsNullOrEmpty(milestone.AgentName))
                        {
                            <span class="flow-agent">@milestone.AgentName</span>
                        }
                        @if (!string.IsNullOrEmpty(milestone.Detail))
                        {
                            <div class="flow-detail">@milestone.Detail</div>
                        }
                        <div class="flow-time">@milestone.Timestamp.ToLocalTime().ToString("HH:mm:ss")</div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@* ── Agent Compliance Grid ── *@
<div class="health-card compliance-card">
    <h2>Agent Compliance</h2>
    <div class="compliance-grid">
        <div class="compliance-header">
            <span class="col-agent">Agent</span>
            <span class="col-role">Role</span>
            <span class="col-status">Status</span>
            <span class="col-compliant">Compliant</span>
            <span class="col-task">Current Activity</span>
            <span class="col-scenario">Scenario</span>
        </div>
        @foreach (var agent in _agents.OrderBy(a => a.Role))
        {
            <div class="compliance-row @(!agent.DiagnosticCompliant ? "non-compliant-row" : "")">
                <span class="col-agent">@agent.DisplayName</span>
                <span class="col-role">@agent.Role</span>
                <span class="col-status">
                    <span class="mini-badge status-@(agent.Status.ToString().ToLowerInvariant())">
                        @agent.Status
                    </span>
                </span>
                <span class="col-compliant">
                    @(agent.DiagnosticCompliant ? "✅" : "⚠️")
                </span>
                <span class="col-task" title="@agent.DiagnosticJustification">
                    @(agent.DiagnosticSummary ?? agent.StatusReason ?? "—")
                </span>
                <span class="col-scenario">@(agent.DiagnosticScenarioRef ?? "—")</span>
            </div>
        }
    </div>
</div>

@* ── Diagnostic Feed ── *@
<div class="health-card feed-card">
    <div class="feed-header">
        <h2>Diagnostic Feed</h2>
        <div class="feed-controls">
            <select class="feed-pill" @bind="_filterAgent">
                <option value="">🤖 All Agents</option>
                @foreach (var agent in _agents.OrderBy(a => a.DisplayName))
                {
                    <option value="@agent.Id">@agent.DisplayName</option>
                }
            </select>
            <select class="feed-pill" @bind="_filterCompliance">
                <option value="">📋 All Status</option>
                <option value="compliant">✅ Compliant</option>
                <option value="non-compliant">⚠️ Non-Compliant</option>
            </select>
            <span class="feed-count">@GetFilteredFeed().Count entries</span>
        </div>
    </div>

    <div class="feed-list">
        @{ var feedItems = GetFilteredFeed(); }
        @if (feedItems.Count == 0)
        {
            <div class="feed-empty">No diagnostic entries yet. Agents will report justifications as they work.</div>
        }
        else
        {
            @foreach (var entry in feedItems)
            {
                <div class="feed-entry @(!entry.IsCompliant ? "feed-entry-warn" : "")">
                    <div class="feed-entry-row">
                        <span class="feed-timestamp">@entry.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                        <span class="feed-compliance">@(entry.IsCompliant ? "✅" : "⚠️")</span>
                        <span class="feed-agent-name">@entry.AgentDisplayName</span>
                        @if (!string.IsNullOrEmpty(entry.ScenarioRef))
                        {
                            <span class="feed-scenario-ref">@entry.ScenarioRef</span>
                        }
                        <span class="feed-summary-inline">@entry.Summary</span>
                    </div>
                    @if (!entry.IsCompliant && !string.IsNullOrEmpty(entry.ComplianceIssue))
                    {
                        <div class="feed-compliance-issue">⚠️ @entry.ComplianceIssue</div>
                    }
                    <details class="feed-details">
                        <summary>Justification</summary>
                        <div class="feed-justification">@entry.Justification</div>
                    </details>
                </div>
            }
        }
    </div>
</div>

@code {
    private ExecutionHealthAssessment _assessment = new()
    {
        OverallStatus = "Loading",
        Phase = "—",
        Uptime = TimeSpan.Zero,
        TotalAgents = 0,
        WorkingAgents = 0,
        CompliantAgents = 0,
        NonCompliantAgents = 0,
        ErrorAgents = 0,
        HasDeadlock = false,
        Observations = [],
        NextPhaseGates = [],
        PhaseTimeline = []
    };

    private IReadOnlyList<AgentSnapshot> _agents = [];
    private string _filterAgent = "";
    private string _filterCompliance = "";

    private HttpClient? _http;
    private List<DiagnosticHistoryEntry>? _standaloneDiagnostics;
    private System.Threading.Timer? _pollTimer;

    protected override void OnInitialized()
    {
        if (Mode.IsStandalone)
        {
            var factory = Services.GetService<IHttpClientFactory>();
            _http = factory?.CreateClient("RunnerApi");
            _pollTimer = new System.Threading.Timer(async _ => await PollDiagnosticsAsync(), null, 0, 5000);
        }
        RefreshData();
        DataService.OnChange += OnDataChanged;
    }

    private async Task PollDiagnosticsAsync()
    {
        if (_http is null) return;
        try
        {
            _assessment = await _http.GetFromJsonAsync<ExecutionHealthAssessment>("/api/health/assessment") ?? _assessment;
            _standaloneDiagnostics = await _http.GetFromJsonAsync<List<DiagnosticHistoryEntry>>("/api/health/diagnostics?limit=100");
            var agents = await _http.GetFromJsonAsync<List<AgentSnapshot>>("/api/agents");
            if (agents is not null) _agents = agents;
            await InvokeAsync(StateHasChanged);
        }
        catch { /* runner not reachable */ }
    }

    private void RefreshData()
    {
        _assessment = DataService.GetExecutionHealthAssessment();
        _agents = DataService.GetAllAgentSnapshots();
    }

    private async void OnDataChanged()
    {
        RefreshData();
        await InvokeAsync(StateHasChanged);
    }

    private IReadOnlyList<DiagnosticHistoryEntry> GetFilteredFeed()
    {
        bool? compliantFilter = _filterCompliance switch
        {
            "compliant" => true,
            "non-compliant" => false,
            _ => null
        };

        var agentFilter = string.IsNullOrEmpty(_filterAgent) ? null : _filterAgent;

        if (_standaloneDiagnostics is not null)
        {
            IEnumerable<DiagnosticHistoryEntry> query = _standaloneDiagnostics;
            if (agentFilter is not null) query = query.Where(d => d.AgentId == agentFilter);
            if (compliantFilter is not null) query = query.Where(d => d.IsCompliant == compliantFilter);
            return query.OrderByDescending(d => d.Timestamp).Take(100).ToList();
        }

        return DataService.GetDiagnosticHistory(agentFilter, compliantFilter, 100);
    }

    private string OverallStatusClass => _assessment.OverallStatus switch
    {
        "Healthy" => "badge-healthy",
        "Caution" => "badge-caution",
        "Warning" => "badge-warning",
        "Critical" => "badge-critical",
        _ => ""
    };

    private static string FormatObservation(string obs) =>
        obs.Replace("**", "<strong>").Replace("**", "</strong>");

    private static string FormatDuration(TimeSpan ts) => ts.TotalHours >= 1
        ? $"{(int)ts.TotalHours}h {ts.Minutes}m {ts.Seconds}s"
        : ts.TotalMinutes >= 1
            ? $"{ts.Minutes}m {ts.Seconds}s"
            : $"{ts.Seconds}s";

    public void Dispose()
    {
        DataService.OnChange -= OnDataChanged;
        _pollTimer?.Dispose();
    }
}
