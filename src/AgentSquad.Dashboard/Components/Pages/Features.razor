@page "/features"
@rendermode InteractiveServer
@using AgentSquad.Core.Configuration
@using AgentSquad.Dashboard.Services
@using System.Net.Http.Json
@inject DashboardMode Mode
@inject IServiceProvider ServiceProvider
@inject NavigationManager Navigation

<PageTitle>Virtual Dev Team — Features</PageTitle>

<div class="dashboard-header" data-testid="page-features">
    <h1>Features</h1>
    <div class="header-badges">
        <span class="header-badge">
            ⭐ @_features.Count(f => f.Status == FeatureStatus.Draft) Draft
        </span>
        <span class="header-badge">
            🚀 @_features.Count(f => f.Status == FeatureStatus.Running) Running
        </span>
    </div>
</div>

@* ── New Feature Form (collapsible) ── *@
<div class="feature-form-card">
    <button class="feature-form-toggle" @onclick="ToggleForm">
        <span>@(_showForm ? "▾" : "▸") @(_editingFeature is null ? "New Feature" : "Edit Feature")</span>
        <span class="feature-form-toggle-hint">Define a feature to build against an existing repo</span>
    </button>
    @if (_showForm)
    {
        <div class="feature-form-body">
            <div class="feature-form-row">
                <label class="feature-form-label">Title <span class="required">*</span></label>
                <input type="text" class="feature-form-input" placeholder="e.g., Add user authentication"
                       @bind="_formTitle" @bind:event="oninput" />
            </div>
            <div class="feature-form-row">
                <label class="feature-form-label">Description <span class="required">*</span></label>
                <textarea class="feature-form-textarea" rows="4"
                          placeholder="Describe what you want built — goals, behavior, constraints..."
                          @bind="_formDescription" @bind:event="oninput"></textarea>
            </div>
            <div class="feature-form-row">
                <label class="feature-form-label">Acceptance Criteria</label>
                <textarea class="feature-form-textarea" rows="3"
                          placeholder="Testable criteria that define when this feature is done..."
                          @bind="_formAcceptanceCriteria" @bind:event="oninput"></textarea>
            </div>
            <div class="feature-form-grid">
                <div class="feature-form-row">
                    <label class="feature-form-label">Base Branch</label>
                    <input type="text" class="feature-form-input" placeholder="main"
                           @bind="_formBaseBranch" @bind:event="oninput" />
                </div>
                <div class="feature-form-row">
                    <label class="feature-form-label">Target Repo (optional)</label>
                    <input type="text" class="feature-form-input" placeholder="owner/repo (inherits from project config)"
                           @bind="_formTargetRepo" @bind:event="oninput" />
                </div>
            </div>
            <div class="feature-form-row">
                <label class="feature-form-label">Tech Stack Override</label>
                <input type="text" class="feature-form-input" placeholder="Leave blank to inherit from project config"
                       @bind="_formTechStack" @bind:event="oninput" />
            </div>
            <div class="feature-form-row">
                <label class="feature-form-label">Additional Context</label>
                <textarea class="feature-form-textarea" rows="2"
                          placeholder="Links, design docs, constraints, prior art..."
                          @bind="_formAdditionalContext" @bind:event="oninput"></textarea>
            </div>
            <div class="feature-form-actions">
                @if (!string.IsNullOrEmpty(_formError))
                {
                    <span class="feature-form-error">⚠ @_formError</span>
                }
                <button class="btn-secondary" @onclick="CancelForm">Cancel</button>
                <button class="btn-primary" @onclick="SaveDraftAsync" disabled="@_formSaving">
                    @(_formSaving ? "Saving..." : "💾 Save Draft")
                </button>
                <button class="btn-success" @onclick="SaveAndStartAsync" disabled="@_formSaving">
                    @(_formSaving ? "..." : "▶ Save & Start")
                </button>
            </div>
        </div>
    }
</div>

@* ── Feature List ── *@
@if (_loading)
{
    <div class="feature-loading">Loading features...</div>
}
else if (_features.Count == 0)
{
    <div class="feature-empty">
        <div class="feature-empty-icon">⭐</div>
        <div class="feature-empty-title">No features defined yet</div>
        <div class="feature-empty-hint">Click "New Feature" above to define a feature to build</div>
    </div>
}
else
{
    <div class="feature-list">
        @foreach (var feature in _features.OrderByDescending(f => f.CreatedAt))
        {
            <div class="feature-card feature-status-@feature.Status.ToString().ToLowerInvariant()">
                <div class="feature-card-header">
                    <div class="feature-card-info">
                        <span class="feature-card-status-badge status-@feature.Status.ToString().ToLowerInvariant()">
                            @GetStatusIcon(feature.Status) @feature.Status
                        </span>
                        <span class="feature-card-title">@feature.Title</span>
                    </div>
                    <div class="feature-card-meta">
                        <span class="feature-card-date" title="Created @feature.CreatedAt.ToString("yyyy-MM-dd HH:mm")">
                            @FormatRelativeTime(feature.CreatedAt)
                        </span>
                        @if (!string.IsNullOrEmpty(feature.BaseBranch))
                        {
                            <span class="feature-card-branch">🔀 @feature.BaseBranch</span>
                        }
                    </div>
                    <div class="feature-card-actions">
                        @if (feature.Status == FeatureStatus.Draft)
                        {
                            <button class="btn-sm btn-primary" @onclick="() => StartFeatureAsync(feature.Id)" disabled="@_actionPending">▶ Start</button>
                            <button class="btn-sm btn-secondary" @onclick="() => EditFeature(feature)">✏ Edit</button>
                            <button class="btn-sm btn-danger" @onclick="() => DeleteFeatureAsync(feature.Id)" disabled="@_actionPending">🗑</button>
                        }
                        else if (feature.Status == FeatureStatus.Running)
                        {
                            <button class="btn-sm btn-danger" @onclick="StopRunningAsync" disabled="@_actionPending">⏹ Stop</button>
                        }
                    </div>
                </div>
                <div class="feature-card-body">
                    <div class="feature-card-description">@TruncateText(feature.Description, 200)</div>
                    @if (!string.IsNullOrEmpty(feature.AcceptanceCriteria))
                    {
                        <div class="feature-card-ac">
                            <strong>Acceptance Criteria:</strong> @TruncateText(feature.AcceptanceCriteria, 150)
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    private List<FeatureDefinition> _features = new();
    private bool _loading = true;
    private bool _actionPending;

    // Form state
    private bool _showForm;
    private string? _editingFeature; // Feature ID when editing
    private string _formTitle = "";
    private string _formDescription = "";
    private string _formAcceptanceCriteria = "";
    private string _formBaseBranch = "main";
    private string _formTargetRepo = "";
    private string _formTechStack = "";
    private string _formAdditionalContext = "";
    private string _formError = "";
    private bool _formSaving;

    private HttpClient? _http;

    protected override async Task OnInitializedAsync()
    {
        var factory = ServiceProvider.GetService<IHttpClientFactory>();
        _http = factory?.CreateClient("RunnerApi");

        await LoadFeaturesAsync();
    }

    private async Task LoadFeaturesAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            if (_http is not null)
            {
                var features = await _http.GetFromJsonAsync<List<FeatureDefinition>>("/api/features");
                _features = features ?? new();
            }
            else
            {
                // Direct service injection for Runner-embedded mode
                var store = ServiceProvider.GetService<AgentSquad.Core.Persistence.AgentStateStore>();
                if (store is not null)
                {
                    _features = (await store.ListFeaturesAsync(100)).ToList();
                }
            }
        }
        catch (Exception ex)
        {
            _formError = $"Failed to load features: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void ToggleForm() => _showForm = !_showForm;

    private void CancelForm()
    {
        _showForm = false;
        _editingFeature = null;
        ResetForm();
    }

    private void ResetForm()
    {
        _formTitle = "";
        _formDescription = "";
        _formAcceptanceCriteria = "";
        _formBaseBranch = "main";
        _formTargetRepo = "";
        _formTechStack = "";
        _formAdditionalContext = "";
        _formError = "";
    }

    private void EditFeature(FeatureDefinition feature)
    {
        _editingFeature = feature.Id;
        _formTitle = feature.Title;
        _formDescription = feature.Description;
        _formAcceptanceCriteria = feature.AcceptanceCriteria ?? "";
        _formBaseBranch = feature.BaseBranch;
        _formTargetRepo = feature.TargetRepo ?? "";
        _formTechStack = feature.TechStackOverride ?? "";
        _formAdditionalContext = feature.AdditionalContext ?? "";
        _showForm = true;
    }

    private async Task SaveDraftAsync()
    {
        if (!ValidateForm()) return;
        _formSaving = true;
        _formError = "";
        StateHasChanged();

        try
        {
            var feature = BuildFeatureFromForm();

            if (_http is not null)
            {
                HttpResponseMessage resp;
                if (_editingFeature is not null)
                    resp = await _http.PutAsJsonAsync($"/api/features/{_editingFeature}", feature);
                else
                    resp = await _http.PostAsJsonAsync("/api/features", feature);

                if (!resp.IsSuccessStatusCode)
                {
                    _formError = $"Save failed: {resp.StatusCode}";
                    return;
                }
            }
            else
            {
                var store = ServiceProvider.GetService<AgentSquad.Core.Persistence.AgentStateStore>();
                if (store is not null)
                    await store.SaveFeatureAsync(feature);
            }

            _showForm = false;
            _editingFeature = null;
            ResetForm();
            await LoadFeaturesAsync();
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _formSaving = false;
            StateHasChanged();
        }
    }

    private async Task SaveAndStartAsync()
    {
        if (!ValidateForm()) return;
        _formSaving = true;
        _formError = "";
        StateHasChanged();

        try
        {
            var feature = BuildFeatureFromForm();

            // Save first
            if (_http is not null)
            {
                var saveResp = await _http.PostAsJsonAsync("/api/features", feature);
                if (!saveResp.IsSuccessStatusCode)
                {
                    _formError = $"Save failed: {saveResp.StatusCode}";
                    return;
                }

                // Then start
                var startResp = await _http.PostAsync($"/api/runs/start-feature/{feature.Id}", null);
                if (!startResp.IsSuccessStatusCode)
                {
                    _formError = $"Saved but failed to start: {startResp.StatusCode}";
                    await LoadFeaturesAsync();
                    return;
                }
            }
            else
            {
                var store = ServiceProvider.GetService<AgentSquad.Core.Persistence.AgentStateStore>();
                var coordinator = ServiceProvider.GetService<AgentSquad.Orchestrator.RunCoordinator>();
                if (store is not null) await store.SaveFeatureAsync(feature);
                if (coordinator is not null) await coordinator.StartFeatureAsync(feature.Id);
            }

            _showForm = false;
            _editingFeature = null;
            ResetForm();
            await LoadFeaturesAsync();
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _formSaving = false;
            StateHasChanged();
        }
    }

    private async Task StartFeatureAsync(string featureId)
    {
        _actionPending = true;
        _formError = "";
        StateHasChanged();

        try
        {
            if (_http is not null)
            {
                var resp = await _http.PostAsync($"/api/runs/start-feature/{featureId}", null);
                if (!resp.IsSuccessStatusCode)
                    _formError = $"Start failed: {resp.StatusCode}";
            }
            else
            {
                var coordinator = ServiceProvider.GetService<AgentSquad.Orchestrator.RunCoordinator>();
                if (coordinator is not null) await coordinator.StartFeatureAsync(featureId);
            }

            await LoadFeaturesAsync();
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _actionPending = false;
            StateHasChanged();
        }
    }

    private async Task StopRunningAsync()
    {
        _actionPending = true;
        StateHasChanged();

        try
        {
            if (_http is not null)
                await _http.PostAsync("/api/runs/stop", null);
            else
            {
                var coordinator = ServiceProvider.GetService<AgentSquad.Orchestrator.RunCoordinator>();
                if (coordinator is not null) await coordinator.StopAsync();
            }

            await LoadFeaturesAsync();
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _actionPending = false;
            StateHasChanged();
        }
    }

    private async Task DeleteFeatureAsync(string featureId)
    {
        _actionPending = true;
        StateHasChanged();

        try
        {
            if (_http is not null)
            {
                var resp = await _http.DeleteAsync($"/api/features/{featureId}");
                if (!resp.IsSuccessStatusCode)
                    _formError = $"Delete failed: {resp.StatusCode}";
            }
            else
            {
                var store = ServiceProvider.GetService<AgentSquad.Core.Persistence.AgentStateStore>();
                if (store is not null)
                    await store.DeleteFeatureAsync(featureId);
            }

            await LoadFeaturesAsync();
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _actionPending = false;
            StateHasChanged();
        }
    }

    private bool ValidateForm()
    {
        if (string.IsNullOrWhiteSpace(_formTitle))
        {
            _formError = "Title is required";
            return false;
        }
        if (string.IsNullOrWhiteSpace(_formDescription))
        {
            _formError = "Description is required";
            return false;
        }
        _formError = "";
        return true;
    }

    private FeatureDefinition BuildFeatureFromForm()
    {
        return new FeatureDefinition
        {
            Id = _editingFeature ?? Guid.NewGuid().ToString("N"),
            Title = _formTitle.Trim(),
            Description = _formDescription.Trim(),
            AcceptanceCriteria = string.IsNullOrWhiteSpace(_formAcceptanceCriteria) ? null : _formAcceptanceCriteria.Trim(),
            BaseBranch = string.IsNullOrWhiteSpace(_formBaseBranch) ? "main" : _formBaseBranch.Trim(),
            TargetRepo = string.IsNullOrWhiteSpace(_formTargetRepo) ? null : _formTargetRepo.Trim(),
            TechStackOverride = string.IsNullOrWhiteSpace(_formTechStack) ? null : _formTechStack.Trim(),
            AdditionalContext = string.IsNullOrWhiteSpace(_formAdditionalContext) ? null : _formAdditionalContext.Trim(),
            Status = FeatureStatus.Draft
        };
    }

    private static string GetStatusIcon(FeatureStatus status) => status switch
    {
        FeatureStatus.Draft => "📝",
        FeatureStatus.Queued => "⏳",
        FeatureStatus.Running => "🚀",
        FeatureStatus.Completed => "✅",
        FeatureStatus.Failed => "❌",
        FeatureStatus.Cancelled => "🚫",
        _ => "❓"
    };

    private static string FormatRelativeTime(DateTime utc)
    {
        var diff = DateTime.UtcNow - utc;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 30) return $"{(int)diff.TotalDays}d ago";
        return utc.ToString("MMM dd");
    }

    private static string TruncateText(string text, int maxLen)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= maxLen) return text ?? "";
        return text[..maxLen] + "...";
    }
}
