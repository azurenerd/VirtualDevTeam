    public async ValueTask DisposeAsync()
    {
        DataService.OnChange -= OnDataChanged;
        await _refreshCts.CancelAsync();
        _refreshCts.Dispose();
    }

    private record IssueGroup
    {
        public required PlatformWorkItem Issue { get; init; }
        public required List<PlatformPullRequest> LinkedPRs { get; init; }
        public required List<PlatformWorkItem> ChildIssues { get; init; }
        /// <summary>True when the top-level item is actually a PR rendered as a synthetic issue.</summary>
        public bool IsPullRequest { get; init; }
        /// <summary>Wave assignment for engineering tasks (e.g., "W0", "W1"). Empty for non-engineering items.</summary>
        public string Wave { get; init; } = "";
        /// <summary>Issue numbers this task depends on (blocked by).</summary>
        public List<int> DependsOn { get; init; } = [];
    }

    private record NeonPhase
    {
        public required string Name { get; init; }
        public required string Icon { get; init; }
        public required string CssClass { get; init; }
        public required List<IssueGroup> Items { get; init; }
        /// <summary>True when this phase is a development wave sub-phase.</summary>
        public bool IsWavePhase { get; init; }
    }

    private static readonly System.Text.RegularExpressions.Regex WaveRegex = new(
        @"\*\*Wave:\*\*\s*(W\d+)", System.Text.RegularExpressions.RegexOptions.Compiled);

    private static readonly System.Text.RegularExpressions.Regex DependsOnRegex = new(
        @"\*\*Depends On:\*\*\s*((?:#\d+(?:,\s*)?)+)", System.Text.RegularExpressions.RegexOptions.Compiled);

    private static string ParseWaveFromBody(string? body)
    {
        if (string.IsNullOrWhiteSpace(body)) return "W1";
        var match = WaveRegex.Match(body);
        return match.Success ? match.Groups[1].Value : "W1";
    }

    private static List<int> ParseDependsOnFromBody(string? body)
    {
        if (string.IsNullOrWhiteSpace(body)) return [];
        var match = DependsOnRegex.Match(body);
        if (!match.Success) return [];
        return System.Text.RegularExpressions.Regex.Matches(match.Groups[1].Value, @"#(\d+)")
            .Select(m => int.Parse(m.Groups[1].Value))
            .ToList();
    }
}
