    private void SetDevView(string mode)
    {
        if (_devViewMode == mode) return;
        _devViewMode = mode;
        _selectedIssue = null;
        _selectedGroup = null;
        _selectedPr = null;
        _selectedPrObj = null;
        BuildTimeline();
