@page "/timeline"
@rendermode InteractiveServer
@using AgentSquad.Core.GitHub.Models
@using AgentSquad.Core.GitHub
@using AgentSquad.Dashboard.Services
@implements IAsyncDisposable
@inject IDashboardDataService DataService
@inject NavigationManager Navigation

<PageTitle>AgentSquad — Project Timeline</PageTitle>

@if (_loading)
{
    <div class="ntl-loading">
        <div class="ntl-loading-ring"></div>
        <span>Syncing timeline…</span>
    </div>
}
else if (_phases.Count == 0)
{
    @if (_isRateLimited)
    {
        <div class="empty-state">
            <div class="empty-icon">⏳</div>
            <div class="empty-text">GitHub API rate-limited</div>
            <div class="empty-sub">Waiting for rate limit to reset. Timeline will load automatically when data becomes available.</div>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">🗺️</div>
            <div class="empty-text">No work items yet</div>
            <div class="empty-sub">Issues will appear here as agents create them</div>
        </div>
    }
}
else
{
    <!-- Top bar: title + stats + filter -->
    <div class="ntl-topbar">
        <div class="ntl-topbar-left">
            <h1 class="ntl-title">Project Timeline</h1>
            <div class="ntl-stats">
                <span class="ntl-stat"><span class="ntl-stat-num">@_issues.Count</span> issues</span>
                <span class="ntl-stat-sep">·</span>
                <span class="ntl-stat"><span class="ntl-stat-num ntl-stat-done">@_closedCount</span> closed</span>
                <span class="ntl-stat-sep">·</span>
                <span class="ntl-stat"><span class="ntl-stat-num ntl-stat-open">@_openCount</span> open</span>
            </div>
        </div>
        <div class="ntl-topbar-right">
            <div class="ntl-theme-toggle">
                <button class="ntl-theme-btn @(_designTheme == "default" ? "active" : "")" @onclick='() => SetTheme("default")' title="Default neon theme">Default</button>
                <button class="ntl-theme-btn @(_designTheme == "blueprint" ? "active" : "")" @onclick='() => SetTheme("blueprint")' title="Blueprint flow theme">Blueprint</button>
                <button class="ntl-theme-btn @(_designTheme == "metro" ? "active" : "")" @onclick='() => SetTheme("metro")' title="Metro minimal theme">Metro</button>
                <button class="ntl-theme-btn @(_designTheme == "cards" ? "active" : "")" @onclick='() => SetTheme("cards")' title="Card grid theme">Cards</button>
            </div>
            <span class="ntl-topbar-divider">|</span>
            <div class="ntl-view-toggle">
                <button class="ntl-view-btn @(_devViewMode == "pm" ? "active" : "")" @onclick='() => SetDevView("pm")' title="Show PM enhancement issues">📋 PM View</button>
                <button class="ntl-view-btn @(_devViewMode == "engineering" ? "active" : "")" @onclick='() => SetDevView("engineering")' title="Show engineering tasks with linked PRs">🔧 Engineering View</button>
            </div>
            <span class="ntl-topbar-divider">|</span>
            <div class="ntl-filter-pills">
                <button class="ntl-pill @(_statusFilter == "all" ? "active" : "")" @onclick='() => SetFilter("all")'>All</button>
                <button class="ntl-pill @(_statusFilter == "open" ? "active" : "")" @onclick='() => SetFilter("open")'>Open</button>
                <button class="ntl-pill @(_statusFilter == "closed" ? "active" : "")" @onclick='() => SetFilter("closed")'>Closed</button>
            </div>
            <button class="ntl-refresh-btn @(_refreshing ? "spinning" : "")" @onclick="ForceRefreshAsync" title="Force refresh from GitHub" disabled="@_refreshing"><svg class="ntl-refresh-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13.5 8a5.5 5.5 0 1 1-1.6-3.9M13.5 2.5v2h-2"/></svg></button>
        </div>
    </div>

    <!-- Overall progress -->
    <div class="ntl-progress-wrap">
        <div class="ntl-progress-bar">
            <div class="ntl-progress-fill" style="width: @(_issues.Count > 0 ? _closedCount * 100 / _issues.Count : 0)%"></div>
        </div>
        <span class="ntl-progress-label">@(_issues.Count > 0 ? _closedCount * 100 / _issues.Count : 0)%</span>
    </div>

    <!-- Horizontal timeline with full-height phase columns -->
    <div class="ntl-viewport">
        <div class="ntl-scroll-area">
            <div class="ntl-timeline theme-@_designTheme">
                @{ int nodeIdx = 0; }
                @foreach (var phase in GetFilteredPhases())
                {
                    var phaseClass = GetPhaseClass(phase.Name);
                    var phaseItems = phase.Items;
                    var phaseDone = phaseItems.Count(g => g.Issue.State == "closed");

                    <div class="ntl-phase-column @phaseClass">
                        <!-- Phase label — top-left -->
                        <div class="ntl-phase-label">
                            <span class="ntl-phase-name">@phase.Name</span>
                            <span class="ntl-phase-counter">@phaseDone/@phaseItems.Count</span>
                        </div>

                        <!-- Glowing spine line through center -->
                        <div class="ntl-spine-segment"></div>

                        <!-- Nodes in this phase -->
                        <div class="ntl-phase-nodes">
                            @foreach (var group in phaseItems)
                            {
                                var issue = group.Issue;
                                var isClosed = issue.State == "closed";
                                var isSelected = _selectedIssue == issue.Number;
                                var isAwaitingReview = issue.Labels.Any(l => l.Equals("awaiting-human-review", StringComparison.OrdinalIgnoreCase));
                                nodeIdx++;

                                <div class="ntl-node-cluster" style="--node-delay: @(nodeIdx * 0.06)s">
                                    <div class="ntl-spine-dot @(isClosed ? "done" : "active")"></div>
                                    <div class="ntl-connector"></div>
                                    <div class="ntl-node @(isClosed ? "ntl-node-closed" : "ntl-node-open") @(isSelected ? "ntl-node-selected" : "") @(isAwaitingReview ? "ntl-node-awaiting" : "")"
                                         @onclick="() => SelectNode(issue.Number)" title="@issue.Title">
                                        <div class="ntl-node-indicator @(isClosed ? "ind-closed" : "ind-open")"></div>
                                        <div class="ntl-node-body">
                                            <span class="ntl-node-num ntl-type-@(group.IsPullRequest ? "pr" : "issue")">@(group.IsPullRequest ? "PR" : "Issue") #@issue.Number</span>
                                            <span class="ntl-node-title">@TruncateTitle(issue.Title, 34)</span>
                                        </div>
                                    </div>

                                    @* Child issue nodes *@
                                    @if (group.ChildIssues.Count > 0)
                                    {
                                        <div class="ntl-children">
                                            @foreach (var child in group.ChildIssues)
                                            {
                                                var childClosed = child.State == "closed";
                                                <div class="ntl-child-connector"></div>
                                                <div class="ntl-child-node @(childClosed ? "ntl-child-closed" : "ntl-child-open")"
                                                     @onclick="() => SelectNode(child.Number)" @onclick:stopPropagation="true"
                                                     title="@child.Title">
                                                    <div class="ntl-child-indicator @(childClosed ? "ind-closed" : "ind-open")"></div>
                                                    <span class="ntl-child-label">Issue #@child.Number @TruncateTitle(child.Title, 24)</span>
                                                </div>
                                            }
                                        </div>
                                    }

                                    @* Linked PR nodes (shown as children in engineering view) *@
                                    @if (_devViewMode == "engineering" && group.LinkedPRs.Count > 0)
                                    {
                                        <div class="ntl-children">
                                            @foreach (var pr in group.LinkedPRs)
                                            {
                                                var prMerged = pr.IsMerged;
                                                var prClosed = pr.State == "closed";
                                                var prClass = prMerged ? "ntl-child-merged" : prClosed ? "ntl-child-closed" : "ntl-child-open";
                                                var indClass = prMerged ? "ind-merged" : prClosed ? "ind-closed" : "ind-open";
                                                <div class="ntl-child-connector"></div>
                                                <a class="ntl-child-node @prClass" href="@pr.Url" target="_blank"
                                                   title="@pr.Title" @onclick:stopPropagation="true">
                                                    <div class="ntl-child-indicator @indClass"></div>
                                                    <span class="ntl-child-label">PR #@pr.Number @TruncateTitle(pr.Title, 24)</span>
                                                </a>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Edge fade overlays -->
        <div class="ntl-edge-fade ntl-edge-left"></div>
        <div class="ntl-edge-fade ntl-edge-right"></div>
    </div>

    <!-- Detail panel for selected issue -->
    @if (_selectedIssue.HasValue && _selectedGroup is { } sg)
    {
        <div class="ntl-detail-panel">
            <div class="ntl-detail-header">
                <a class="ntl-detail-num ntl-type-@(sg.IsPullRequest ? "pr" : "issue")" href="@sg.Issue.Url" target="_blank" title="Open on GitHub">
                    @(sg.IsPullRequest ? "PR" : "Issue") #@sg.Issue.Number ↗
                </a>
                <span class="ntl-detail-state @(sg.Issue.State == "closed" ? "state-closed" : "state-open")">
                    @(sg.Issue.State == "closed" ? "✓ Closed" : "● Open")
                </span>
                <button class="ntl-detail-close" @onclick="() => SelectNode(null)">✕</button>
            </div>
            <h3 class="ntl-detail-title">@sg.Issue.Title</h3>
            <div class="ntl-detail-meta">
                @if (!string.IsNullOrEmpty(sg.Issue.AssignedAgent))
                {
                    <span class="ntl-detail-agent">👤 @sg.Issue.AssignedAgent</span>
                }
                <span class="ntl-detail-date">📅 @FormatTime(sg.Issue.CreatedAt)</span>
            </div>
            @if (sg.Issue.Labels.Count > 0)
            {
                <div class="ntl-detail-labels">
                    @foreach (var label in sg.Issue.Labels)
                    {
                        <span class="ntl-label">@label</span>
                    }
                </div>
            }
            @if (sg.ChildIssues.Count > 0)
            {
                <div class="ntl-detail-prs">
                    <span class="ntl-detail-section-title">Child Issues</span>
                    @foreach (var child in sg.ChildIssues)
                    {
                        <div class="ntl-detail-pr @(child.State == "closed" ? "merged" : "open")"
                             @onclick="() => SelectNode(child.Number)">
                            <span class="ntl-detail-pr-indicator @(child.State == "closed" ? "ind-closed" : "ind-open")"></span>
                            <a class="ntl-detail-pr-num" href="@child.Url" target="_blank" @onclick:stopPropagation="true">Issue #@child.Number</a>
                            <span class="ntl-detail-pr-title">@TruncateTitle(child.Title, 60)</span>
                        </div>
                    }
                </div>
            }
            @if (sg.LinkedPRs.Count > 0)
            {
                <div class="ntl-detail-prs" style="margin-top: 8px;">
                    <span class="ntl-detail-section-title">Linked Pull Requests</span>
                    @foreach (var pr in sg.LinkedPRs)
                    {
                        <div class="ntl-detail-pr @(pr.IsMerged ? "merged" : pr.State == "closed" ? "closed" : "open")">
                            <span class="ntl-detail-pr-indicator @(pr.IsMerged ? "ind-merged" : pr.State == "closed" ? "ind-closed-pr" : "ind-open-pr")"></span>
                            <a class="ntl-detail-pr-num" href="@pr.Url" target="_blank">PR #@pr.Number</a>
                            <span class="ntl-detail-pr-title">@TruncateTitle(pr.Title, 60)</span>
                        </div>
                    }
                </div>
            }
        </div>
    }
}

@code {
    private List<AgentIssue> _issues = [];
    private List<AgentPullRequest> _pullRequests = [];
    private List<AgentIssue> _rawIssues = [];
    private List<AgentPullRequest> _rawPullRequests = [];
    private List<NeonPhase> _phases = [];
    private HashSet<int> _syntheticPrNumbers = new(); // tracks which issue numbers are actually PRs
    private string _dataFingerprint = ""; // hash to detect actual data changes
    private bool _loading = true;
    private bool _initialLoadComplete;
    private bool _refreshing;
    private bool _isRateLimited;
    private int _closedCount;
    private int _openCount;

    private string _statusFilter = "all";
    private string _devViewMode = "pm"; // "pm" = enhancement issues, "engineering" = engineering-task issues with PR children
    private string _designTheme = "default"; // "default", "blueprint", "metro", "cards"
    private int? _selectedIssue;
    private IssueGroup? _selectedGroup;

    private Dictionary<int, IssueGroup> _groupLookup = new();

    private CancellationTokenSource _refreshCts = new();

    protected override async Task OnInitializedAsync()
    {
        DataService.OnChange += OnDataChanged;
        await LoadDataAsync(showOverlay: true);
        _ = PollForUpdatesAsync(_refreshCts.Token);
    }

    /// <summary>
    /// Gentle background poll — refreshes timeline every 30s so new issues/PRs
    /// appear without the user needing to reload. Uses cached data from
    /// DashboardDataService so it only hits GitHub when the cache expires.
    /// </summary>
    private async Task PollForUpdatesAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                await LoadDataAsync();
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task LoadDataAsync(bool showOverlay = false)
    {
        if (showOverlay) _loading = true;
        _isRateLimited = DataService.IsGitHubRateLimited;
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(20));
            var issuesTask = DataService.GetIssuesAsync();
            var prsTask = DataService.GetPullRequestsAsync();
            try { await Task.WhenAll(issuesTask, prsTask).WaitAsync(cts.Token); }
            catch (OperationCanceledException) { }

            var newIssues = issuesTask.IsCompletedSuccessfully ? issuesTask.Result.ToList() : [];
            var newPRs = prsTask.IsCompletedSuccessfully ? prsTask.Result.ToList() : [];
            _isRateLimited = DataService.IsGitHubRateLimited;

            // Compute fingerprint: issue/PR numbers + states + labels count + PR merged status
            var fp = ComputeFingerprint(newIssues, newPRs);
            if (fp == _dataFingerprint && !showOverlay)
                return; // nothing changed — skip rebuild and re-render

            _rawIssues = newIssues;
            _rawPullRequests = newPRs;
            _dataFingerprint = fp;
            BuildTimeline();

            if (_phases.Count == 0)
                _ = RetryAfterDelay(TimeSpan.FromSeconds(_isRateLimited ? 30 : 15));
        }
        catch
        {
            _rawIssues = [];
            _rawPullRequests = [];
            _dataFingerprint = "";
            BuildTimeline();
            _ = RetryAfterDelay(TimeSpan.FromSeconds(15));
        }
        finally
        {
            _loading = false;
            _initialLoadComplete = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Cheap fingerprint of issue/PR data to detect real changes without rebuilding the whole timeline.
    /// </summary>
    private static string ComputeFingerprint(List<AgentIssue> issues, List<AgentPullRequest> prs)
    {
        var hash = new System.HashCode();
        hash.Add(issues.Count);
        hash.Add(prs.Count);
        foreach (var i in issues)
        {
            hash.Add(i.Number);
            hash.Add(i.State);
            hash.Add(i.Labels.Count);
            hash.Add(i.UpdatedAt?.Ticks ?? 0);
        }
        foreach (var p in prs)
        {
            hash.Add(p.Number);
            hash.Add(p.State);
            hash.Add(p.IsMerged);
            hash.Add(p.UpdatedAt?.Ticks ?? 0);
        }
        return hash.ToHashCode().ToString();
    }

    private async Task RetryAfterDelay(TimeSpan delay)
    {
        await Task.Delay(delay);
        if (_phases.Count == 0)
        {
            await LoadDataAsync(showOverlay: !_initialLoadComplete);
        }
    }

    private void BuildTimeline()
    {
        try
        {
            BuildTimelineCore();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"BuildTimeline error: {ex}");
            _phases = [];
            _groupLookup = new();
        }
    }

    private void BuildTimelineCore()
    {
        // Work from raw copies so this method can be re-called (e.g., on view toggle)
        _issues = _rawIssues.ToList();
        _pullRequests = _rawPullRequests.ToList();
        _syntheticPrNumbers.Clear();

        // --- Step 1: Detect the latest run's start from the newest Research PR ---
        // Each run creates Research → PM Spec → Architecture PRs. The newest Research PR
        // marks the start of the latest run cycle.
        var latestResearchPr = _pullRequests
            .Where(p => p.Title.StartsWith("Researcher:", StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(p => p.CreatedAt)
            .FirstOrDefault();
        var runCutoff = latestResearchPr?.CreatedAt.AddMinutes(-1) ?? DateTime.MinValue;

        // Filter issues and PRs to only the latest run
        _issues = _issues.Where(i => i.CreatedAt >= runCutoff).ToList();
        _pullRequests = _pullRequests.Where(p => p.CreatedAt >= runCutoff).ToList();

        // Deduplicate by title (safety net — keep newest)
        _issues = _issues
            .GroupBy(i => i.Title.Trim(), StringComparer.OrdinalIgnoreCase)
            .Select(g => g.OrderByDescending(i => i.Number).First())
            .ToList();
        _pullRequests = _pullRequests
            .GroupBy(p => p.Title.Trim(), StringComparer.OrdinalIgnoreCase)
            .Select(g => g.OrderByDescending(p => p.Number).First())
            .ToList();

        // --- Step 2: Add doc PRs as synthetic timeline items ---
        // Research, PM Spec, and Architecture phases are PRs, not issues.
        // Create synthetic AgentIssue entries so they appear as timeline nodes.
        // But skip if a real issue from the same agent already exists (avoids duplicates).
        var existingNumbers = _issues.Select(i => i.Number).ToHashSet();
        foreach (var pr in _pullRequests)
        {
            if (existingNumbers.Contains(pr.Number)) continue;
            var t = pr.Title;
            bool isDocPr = t.StartsWith("Researcher:", StringComparison.OrdinalIgnoreCase)
                || t.StartsWith("ProgramManager:", StringComparison.OrdinalIgnoreCase)
                || t.StartsWith("Architect:", StringComparison.OrdinalIgnoreCase);
            bool isFinalIntegration = t.Contains("Final Integration", StringComparison.OrdinalIgnoreCase);
            if (isDocPr || isFinalIntegration)
            {
                // Extract agent prefix (e.g., "Researcher:") and skip if a real issue
                // from the same agent already exists — the real issue is sufficient.
                var colonIdx = t.IndexOf(':');
                if (colonIdx > 0)
                {
                    var prefix = t[..(colonIdx + 1)];
                    if (_issues.Any(i => i.Title.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)))
                        continue;
                }

                _syntheticPrNumbers.Add(pr.Number);
                _issues.Add(new AgentIssue
                {
                    Number = pr.Number,
                    Title = pr.Title,
                    Body = pr.Body,
                    State = pr.IsMerged ? "closed" : pr.State,
                    CreatedAt = pr.CreatedAt,
                    UpdatedAt = pr.UpdatedAt,
                    Labels = pr.Labels,
                    Url = pr.Url,
                    AssignedAgent = pr.AssignedAgent
                });
            }
        }

        // --- Step 2b: Remove older engineering-task duplicates ---
        // When multiple runs create eng tasks for the same parent, keep only the latest burst.
        // Detect the latest burst: eng tasks created within 30 min of the newest eng task.
        var engTasks = _issues.Where(i => i.Labels.Any(l => l.Equals("engineering-task", StringComparison.OrdinalIgnoreCase))).ToList();
        if (engTasks.Count > 0)
        {
            var newestEngTime = engTasks.Max(e => e.CreatedAt);
            var burstCutoff = newestEngTime.AddMinutes(-30);
            var latestBurstNumbers = engTasks.Where(e => e.CreatedAt >= burstCutoff).Select(e => e.Number).ToHashSet();
            // Remove older eng tasks that aren't in the latest burst
            _issues = _issues.Where(i =>
                !i.Labels.Any(l => l.Equals("engineering-task", StringComparison.OrdinalIgnoreCase))
                || latestBurstNumbers.Contains(i.Number)
            ).ToList();
        }

        // --- Step 3: Build issue→PR links (for detail panel) ---
        var prsByIssue = new Dictionary<int, List<AgentPullRequest>>();
        foreach (var pr in _pullRequests)
        {
            var linked = PullRequestWorkflow.ParseLinkedIssueNumber(pr.Body);
            if (linked.HasValue)
            {
                if (!prsByIssue.ContainsKey(linked.Value)) prsByIssue[linked.Value] = [];
                prsByIssue[linked.Value].Add(pr);
            }
        }

        // --- Step 4: Build parent→child issue relationships ---
        // Enhancement (PM) issues are parents; engineering-task issues are children.
        var childIssueNumbers = new HashSet<int>();
        var childrenByParent = new Dictionary<int, List<AgentIssue>>();
        // Also build engineering-task → linked PRs for engineering view
        var engTaskPRs = new Dictionary<int, List<AgentPullRequest>>();
        foreach (var issue in _issues)
        {
            foreach (var parentIssue in _issues)
            {
                if (parentIssue.Number == issue.Number) continue;
                var parentLabels = parentIssue.Labels.Select(l => l.ToLowerInvariant()).ToList();
                var childLabels = issue.Labels.Select(l => l.ToLowerInvariant()).ToList();
                if (parentLabels.Contains("enhancement") && childLabels.Contains("engineering-task"))
                {
                    if (issue.Body?.Contains($"#{parentIssue.Number}") == true)
                    {
                        if (!childrenByParent.ContainsKey(parentIssue.Number))
                            childrenByParent[parentIssue.Number] = [];
                        childrenByParent[parentIssue.Number].Add(issue);
                        childIssueNumbers.Add(issue.Number);
                    }
                }
            }

            // For engineering view: map PRs to their engineering-task issues
            if (issue.Labels.Any(l => l.Equals("engineering-task", StringComparison.OrdinalIgnoreCase)))
            {
                engTaskPRs[issue.Number] = prsByIssue.GetValueOrDefault(issue.Number, []).OrderBy(p => p.CreatedAt).ToList();
            }
        }

        // --- Step 5: Build groups sorted by issue number (ascending) ---
        // In PM view: enhancement issues are top-level with engineering-task children
        // In Engineering view: engineering-task issues are top-level with linked PRs as children
        _groupLookup.Clear();
        var groups = new List<IssueGroup>();

        if (_devViewMode == "engineering")
        {
            // Engineering view: engineering-task issues become top-level in Development.
            // Non-engineering items (doc phases, enhancements) stay as-is.
            foreach (var issue in _issues.OrderBy(i => i.Number))
            {
                var isEngTask = issue.Labels.Any(l => l.Equals("engineering-task", StringComparison.OrdinalIgnoreCase));
                if (isEngTask)
                {
                    // Engineering task is always top-level; linked PRs become child items
                    var g = new IssueGroup
                    {
                        Issue = issue,
                        LinkedPRs = engTaskPRs.GetValueOrDefault(issue.Number, []),
                        ChildIssues = [],
                        IsPullRequest = _syntheticPrNumbers.Contains(issue.Number)
                    };
                    groups.Add(g);
                    _groupLookup[issue.Number] = g;
                }
                else if (!childIssueNumbers.Contains(issue.Number))
                {
                    // Non-engineering items: enhancement issues lose children in this view
                    // (children are shown as top-level engineering tasks instead)
                    var g = new IssueGroup
                    {
                        Issue = issue,
                        LinkedPRs = prsByIssue.GetValueOrDefault(issue.Number, []).OrderBy(p => p.CreatedAt).ToList(),
                        ChildIssues = [],
                        IsPullRequest = _syntheticPrNumbers.Contains(issue.Number)
                    };
                    groups.Add(g);
                    _groupLookup[issue.Number] = g;
                }
            }
        }
        else
        {
            // PM view (default): enhancement issues are top-level with engineering-task children
            foreach (var issue in _issues.Where(i => !childIssueNumbers.Contains(i.Number)).OrderBy(i => i.Number))
            {
                var g = new IssueGroup
                {
                    Issue = issue,
                    LinkedPRs = prsByIssue.GetValueOrDefault(issue.Number, []).OrderBy(p => p.CreatedAt).ToList(),
                    ChildIssues = childrenByParent.GetValueOrDefault(issue.Number, []).OrderBy(c => c.Number).ToList(),
                    IsPullRequest = _syntheticPrNumbers.Contains(issue.Number)
                };
                groups.Add(g);
                _groupLookup[issue.Number] = g;
            }
        }
        // Always ensure child issues are in lookup for detail panel navigation
        foreach (var issue in _issues.Where(i => childIssueNumbers.Contains(i.Number)))
        {
            if (!_groupLookup.ContainsKey(issue.Number))
            {
                _groupLookup[issue.Number] = new IssueGroup
                {
                    Issue = issue,
                    LinkedPRs = prsByIssue.GetValueOrDefault(issue.Number, []).OrderBy(p => p.CreatedAt).ToList(),
                    ChildIssues = [],
                    IsPullRequest = _syntheticPrNumbers.Contains(issue.Number)
                };
            }
        }

        // --- Step 6: Group into phases ---
        // In PM view: "Development" shows enhancement issues (PM user stories) with eng-task children
        // In Engineering view: "Development" shows engineering-task issues with linked PRs
        var phaseOrder = new[]
        {
            ("Research",      "🔍", "research"),
            ("PM Spec",       "📝", "pmspec"),
            ("Architecture",  "🏗️", "architecture"),
            ("Development",   "⚡", "development"),
            ("Finalization",   "✅", "finalization")
        };

        _phases = new();
        foreach (var (name, icon, css) in phaseOrder)
        {
            var items = groups.Where(g => ClassifyPhase(g.Issue) == name).ToList();
            if (name == "Development")
                items = items.OrderBy(g => g.Issue.Number).ToList();
            if (items.Count > 0)
                _phases.Add(new NeonPhase { Name = name, Icon = icon, CssClass = css, Items = items });
        }

        _closedCount = _issues.Count(i => i.State == "closed");
        _openCount = _issues.Count(i => i.State != "closed");

        if (_selectedIssue.HasValue)
        {
            if (_groupLookup.TryGetValue(_selectedIssue.Value, out var refreshedGroup))
                _selectedGroup = refreshedGroup;
            else
            {
                _selectedIssue = null;
                _selectedGroup = null;
            }
        }
    }

    private string ClassifyPhase(AgentIssue issue)
    {
        var title = issue.Title.ToLowerInvariant();
        var labels = issue.Labels.Select(l => l.ToLowerInvariant()).ToList();

        // Doc phases — always classify by title prefix regardless of state
        if (title.StartsWith("researcher:"))
            return "Research";
        if (title.StartsWith("programmanager:") || title.Contains("pm spec") || title.Contains("specification"))
            return "PM Spec";
        if (title.StartsWith("architect:") || title.Contains("architecture"))
            return "Architecture";

        // Finalization: T-FINAL tasks, final review/validation, TestEngineer final checks
        if (title.Contains("[t-final]") || title.Contains("final integration")
            || title.Contains("final review") || title.Contains("final check") || title.Contains("final validation")
            || (title.StartsWith("testengineer:") && (title.Contains("final") || title.Contains("integration"))))
            return "Finalization";

        if (_devViewMode == "engineering")
        {
            // Engineering view: engineering-task issues → Development (open or closed)
            // Their PRs are shown as children, so they stay in Development regardless of state
            if (labels.Contains("engineering-task"))
                return "Development";
            if (labels.Contains("enhancement"))
                return "hidden"; // PM issues hidden in engineering view
        }
        else
        {
            // PM view: enhancement issues → Development (with eng-task children)
            if (labels.Contains("enhancement"))
                return "Development";
            if (labels.Contains("engineering-task"))
                return "hidden"; // shown as children of enhancement issues
        }

        // Fallback by title keywords
        if (title.Contains("planning") || title.Contains("engineering plan") || title.Contains("principalengineer"))
            return "Development";

        return "Development";
    }

    private List<NeonPhase> GetFilteredPhases()
    {
        var snapshot = _phases.ToList(); // snapshot to avoid concurrent modification during render
        if (_statusFilter == "all") return snapshot;

        var result = new List<NeonPhase>();
        foreach (var phase in snapshot)
        {
            var filtered = phase.Items.Where(g =>
            {
                if (_statusFilter == "open" && g.Issue.State == "closed") return false;
                if (_statusFilter == "closed" && g.Issue.State != "closed") return false;
                return true;
            }).ToList();
            if (filtered.Count > 0)
                result.Add(new NeonPhase { Name = phase.Name, Icon = phase.Icon, CssClass = phase.CssClass, Items = filtered });
        }
        return result;
    }

    private void SetFilter(string f) { _statusFilter = f; StateHasChanged(); }
    private void SetTheme(string t) { _designTheme = t; StateHasChanged(); }

    private async Task ForceRefreshAsync()
    {
        _refreshing = true;
        StateHasChanged();
        try
        {
            DataService.ResetCaches();
            await LoadDataAsync(showOverlay: true);
        }
        finally
        {
            _refreshing = false;
            StateHasChanged();
        }
    }

    private void SetDevView(string mode)
    {
        if (_devViewMode == mode) return;
        _devViewMode = mode;
        _selectedIssue = null;
        _selectedGroup = null;
        BuildTimeline();
        StateHasChanged();
    }

    private void SelectNode(int? issueNumber)
    {
        if (_selectedIssue == issueNumber) { _selectedIssue = null; _selectedGroup = null; }
        else if (issueNumber.HasValue && _groupLookup.TryGetValue(issueNumber.Value, out var g))
        { _selectedIssue = issueNumber; _selectedGroup = g; }
        else { _selectedIssue = null; _selectedGroup = null; }
        StateHasChanged();
    }

    private string GetPhaseClass(string name) => name switch
    {
        "Research" => "phase-research",
        "PM Spec" => "phase-pmspec",
        "Architecture" => "phase-architecture",
        "Development" => "phase-development",
        "Finalization" => "phase-finalization",
        _ => "phase-development"
    };

    private string TruncateTitle(string title, int max)
    {
        if (title.Length <= max) return title;
        return title[..(max - 1)] + "…";
    }

    private string FormatTime(DateTime dt) => dt.ToLocalTime().ToString("MMM d, HH:mm");

    private void OpenGitHub(string url)
    {
        if (!string.IsNullOrEmpty(url))
            Navigation.NavigateTo(url, forceLoad: true);
    }

    private async void OnDataChanged()
    {
        await LoadDataAsync();
    }

    public async ValueTask DisposeAsync()
    {
        DataService.OnChange -= OnDataChanged;
        await _refreshCts.CancelAsync();
        _refreshCts.Dispose();
    }

    private record IssueGroup
    {
        public required AgentIssue Issue { get; init; }
        public required List<AgentPullRequest> LinkedPRs { get; init; }
        public required List<AgentIssue> ChildIssues { get; init; }
        /// <summary>True when the top-level item is actually a PR rendered as a synthetic issue.</summary>
        public bool IsPullRequest { get; init; }
    }

    private record NeonPhase
    {
        public required string Name { get; init; }
        public required string Icon { get; init; }
        public required string CssClass { get; init; }
        public required List<IssueGroup> Items { get; init; }
    }
}
