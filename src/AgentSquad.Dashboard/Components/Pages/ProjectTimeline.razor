    }

    private void SelectNode(int? issueNumber)
    {
        _selectedPr = null;
        _selectedPrObj = null;
        if (_selectedIssue == issueNumber) { _selectedIssue = null; _selectedGroup = null; }
        else if (issueNumber.HasValue && _groupLookup.TryGetValue(issueNumber.Value, out var g))
        { _selectedIssue = issueNumber; _selectedGroup = g; }
        else { _selectedIssue = null; _selectedGroup = null; }
        StateHasChanged();
    }

    private void SelectPr(int? prNumber)
    {
        if (!prNumber.HasValue || _selectedPr == prNumber)
        {
            _selectedPr = null;
            _selectedPrObj = null;
            StateHasChanged();
            return;
        }
        var pr = _rawPullRequests.FirstOrDefault(p => p.Number == prNumber.Value)
                 ?? _pullRequests.FirstOrDefault(p => p.Number == prNumber.Value);
        if (pr is null)
        {
            _selectedPr = null;
            _selectedPrObj = null;
        }
        else
        {
            _selectedIssue = null;
            _selectedGroup = null;
            _selectedPr = prNumber;
            _selectedPrObj = pr;
        }
        StateHasChanged();
    }

    // Builds a stable raw.githubusercontent.com URL for the canonical ready-for-review
    // screenshot captured at the PR's head SHA. Using HeadSha (not branch name) guards
    // against branch mutation or deletion after merge.
    private static string? BuildReadyForReviewScreenshotUrl(PlatformPullRequest pr)
    {
        if (string.IsNullOrEmpty(pr.Url) || string.IsNullOrEmpty(pr.HeadSha)) return null;
        // pr.Url: https://github.com/{owner}/{repo}/pull/{N}
        var match = System.Text.RegularExpressions.Regex.Match(
            pr.Url,
            @"github\.com/([^/]+)/([^/]+)/pull/\d+",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (!match.Success) return null;
        var owner = match.Groups[1].Value;
        var repo = match.Groups[2].Value;
        return $"https://raw.githubusercontent.com/{owner}/{repo}/{pr.HeadSha}/.screenshots/pr-{pr.Number}-ready-for-review.png";
    }

    private record ScreenshotCandidate(string MethodKey, string MethodLabel, string ImageUrl, bool IsWinner);

    // Returns one tile per code-generation strategy. Checks CandidateStateStore for in-memory
    // screenshot data first (base64 from evaluation), then falls back to GitHub raw URLs.
    private List<ScreenshotCandidate> GetScreenshotCandidates(PlatformPullRequest pr)
    {
        var results = new List<ScreenshotCandidate>();
        if (string.IsNullOrEmpty(pr.Url) || string.IsNullOrEmpty(pr.HeadSha))
            return results;

        var m = System.Text.RegularExpressions.Regex.Match(
            pr.Url,
            @"github\.com/([^/]+)/([^/]+)/pull/\d+",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (!m.Success) return results;
        var owner = m.Groups[1].Value;
        var repo = m.Groups[2].Value;

        // Winner resolution: body marker `<!-- winner-strategy: {key} -->` takes priority.
        var winnerKey = "baseline";
        var bodyMatch = System.Text.RegularExpressions.Regex.Match(
            pr.Body ?? string.Empty,
            @"<!--\s*winner-(?:strategy|method):\s*([a-z0-9\-]+)\s*-->",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (bodyMatch.Success)
            winnerKey = bodyMatch.Groups[1].Value.ToLowerInvariant();

        // Try to find in-memory screenshot data from the CandidateStateStore.
        var storeScreenshots = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var task in CandidateStore.GetRecentTasks(20))
        {
            foreach (var (stratId, snap) in task.Candidates)
            {
                if (!string.IsNullOrEmpty(snap.ScreenshotBase64) && !storeScreenshots.ContainsKey(stratId))
                {
                    storeScreenshots[stratId] = $"data:image/png;base64,{snap.ScreenshotBase64}";
                }
            }
        }
        // Also check active tasks
        foreach (var task in CandidateStore.GetActiveTasks())
        {
            foreach (var (stratId, snap) in task.Candidates)
            {
                if (!string.IsNullOrEmpty(snap.ScreenshotBase64) && !storeScreenshots.ContainsKey(stratId))
                {
                    storeScreenshots[stratId] = $"data:image/png;base64,{snap.ScreenshotBase64}";
                }
            }
        }

        (string Key, string Label)[] strategies =
        {
            ("baseline", "Baseline"),
            ("mcp-enhanced", "MCP-Enhanced"),
            ("copilot-cli", "GitHub Copilot CLI"),
            ("squad", "Squad"),
        };

        // Filter to only enabled strategies (normalize IDs for comparison)
        var enabled = _enabledInfo?.EnabledStrategies;
        var normalizedEnabled = enabled is { Count: > 0 }
            ? enabled.Select(StrategyIdNormalizer.Normalize).ToHashSet(StringComparer.OrdinalIgnoreCase)
            : null;
        var filtered = normalizedEnabled is not null
            ? strategies.Where(s => normalizedEnabled.Contains(s.Key)).ToArray()
            : strategies;

        foreach (var (key, label) in filtered)
        {
            // Prefer in-memory screenshot from evaluation; fall back to GitHub raw URL.
            if (storeScreenshots.TryGetValue(key, out var dataUrl))
            {
                results.Add(new ScreenshotCandidate(key, label, dataUrl, IsWinner: key == winnerKey));
            }
            else
            {
                var path = $".screenshots/pr-{pr.Number}-{key}.png";
                var url = $"https://raw.githubusercontent.com/{owner}/{repo}/{pr.HeadSha}/{path}";
                results.Add(new ScreenshotCandidate(key, label, url, IsWinner: key == winnerKey));
            }
        }
        return results;
    }

    private string GetPhaseClass(string name) => name switch
    {
        "Research" => "phase-research",
        "PM Spec" => "phase-pmspec",
        "Architecture" => "phase-architecture",
        "Development" => "phase-development",
        "Eng Planning" => "phase-development",
        "Testing" => "phase-finalization",
        "Finalization" => "phase-finalization",
        _ when name.StartsWith("Development W") => "phase-development",
        _ => "phase-development"
    };

