@page "/develop"
@using AgentSquad.Core.Configuration
@using AgentSquad.Core.DevPlatform.Capabilities
@using System.Timers
@using AgentSquad.Core.DevPlatform.Config
@using System.Net.Http.Json
@using AgentSquad.Dashboard.Services
@inject DevelopSettingsService SettingsService
@inject IWorkItemSearchService WorkItemSearch
@inject IRepositoryManagementService RepoService
@inject IConfigurationService ConfigService
@inject NavigationManager Navigation
@inject ILogger<Develop> Logger
@rendermode InteractiveServer

<PageTitle>Develop — AgentSquad</PageTitle>

<div class="page-header" data-testid="page-develop">
    <h1 class="page-title">🛠️ Develop</h1>
    <div class="header-badges">
        @if (_globalError is not null)
        {
            <span class="badge badge-error">⚠ Error</span>
        }
    </div>
</div>

@if (_loading)
{
    <div class="config-loading" style="text-align:center; padding:3rem;">
        <div class="config-spinner"></div>
        <p style="color:var(--text-secondary); margin-top:1rem;">Loading settings…</p>
    </div>
}
else
{
    <!-- Step Indicator -->
    <div class="wizard-steps">
        @for (int i = 0; i < _stepLabels.Length; i++)
        {
            var step = i;
            var state = step < _currentStep ? "completed" : step == _currentStep ? "active" : "future";
            <div class="wizard-step @state" @onclick="() => JumpToStep(step)">
                <div class="wizard-step-circle">
                    @if (state == "completed")
                    {
                        <span>✓</span>
                    }
                    else
                    {
                        <span>@(step + 1)</span>
                    }
                </div>
                <span class="wizard-step-label">@_stepLabels[step]</span>
            </div>
            @if (step < _stepLabels.Length - 1)
            {
                <div class="wizard-step-line @(step < _currentStep ? "completed" : "")"></div>
            }
        }
    </div>

    @if (_globalError is not null)
    {
        <div class="config-pat-result config-pat-error" style="margin-bottom:1rem;">
            ⚠ @_globalError
            <button class="config-btn-remove" style="float:right;" @onclick="() => _globalError = null">✕</button>
        </div>
    }

    <div class="wizard-body">
        @* ───── Step 1: What to Build ───── *@
        @if (_currentStep == 0)
        {
            <div class="config-card">
                <div class="config-card-header" style="cursor:default;">
                    <span class="config-card-icon">💡</span>
                    <span class="config-card-title">What to Build</span>
                </div>
                <div class="config-card-body">
                    <div class="config-field">
                        <label title="This can be an entire application or a single feature. The AI agents will determine scope.">
                            Description <span style="color:var(--accent-cyan);">*</span>
                            <span class="wizard-tooltip" title="This can be an entire application or a single feature. The AI agents will determine scope.">ⓘ</span>
                        </label>
                        <textarea class="config-textarea" rows="8"
                                  placeholder="Describe what you want built..."
                                  @bind="_settings.Description" @bind:event="oninput"></textarea>
                    </div>
                    <div class="config-field">
                        <label title="Leave blank and the AI will choose. Or specify constraints.">
                            Tech Stack <span style="color:var(--text-muted, #616161);">(optional)</span>
                            <span class="wizard-tooltip" title="Leave blank and the AI will choose. Or specify constraints.">ⓘ</span>
                        </label>
                        <input type="text" class="config-input"
                               placeholder="e.g., .NET 8 Blazor, React + Node.js"
                               @bind="_settings.TechStack" @bind:event="oninput" />
                    </div>

                    <div class="config-field">
                        <label title="Folder in the repository where agent-generated documents (PMSpec, Architecture, Research) are stored.">
                            Agent Docs Folder <span style="color:var(--text-muted, #616161);">(optional)</span>
                            <span class="wizard-tooltip" title="Folder in the repository where agent-generated documents (PMSpec, Architecture, Research) are stored. A run-specific subfolder is created automatically.">ⓘ</span>
                        </label>
                        <input type="text" class="config-input"
                               placeholder="AgentDocs"
                               @bind="_settings.DocsFolderPath" @bind:event="oninput" />
                    </div>

                    <div class="config-field">
                        <label title="Controls how the PM creates work items from the spec.">
                            PM Issue Creation
                            <span class="wizard-tooltip" title="Single Issue creates one Enhancement with links to docs. Detailed User Stories creates individual issues per story.">ⓘ</span>
                        </label>
                        <div class="wizard-radio-group">
                            <label class="wizard-radio-label">
                                <input type="radio" name="issueMode" checked="@(!_settings.SingleIssueMode)"
                                       @onchange='() => _settings.SingleIssueMode = false' />
                                <span>📝 Detailed User Stories</span>
                            </label>
                            <label class="wizard-radio-label">
                                <input type="radio" name="issueMode" checked="@(_settings.SingleIssueMode)"
                                       @onchange='() => _settings.SingleIssueMode = true' />
                                <span>📌 Single Issue with Doc Links</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* ───── Step 2: Repository & Auth ───── *@
        @if (_currentStep == 1)
        {
            <div class="config-card">
                <div class="config-card-header" style="cursor:default;">
                    <span class="config-card-icon">📦</span>
                    <span class="config-card-title">Platform &amp; Repository</span>
                </div>
                <div class="config-card-body">
                    <!-- Platform selector -->
                    <div class="config-field">
                        <label>Platform</label>
                        <div class="wizard-radio-group">
                            <label class="wizard-radio @(_settings.Platform == "GitHub" ? "selected" : "")">
                                <input type="radio" name="platform" value="GitHub"
                                       checked="@(_settings.Platform == "GitHub")"
                                       @onchange="@(() => SetPlatform(PlatformGitHub))" />
                                <span>🐙 GitHub</span>
                            </label>
                            <label class="wizard-radio @(_settings.Platform == "AzureDevOps" ? "selected" : "")">
                                <input type="radio" name="platform" value="AzureDevOps"
                                       checked="@(_settings.Platform == "AzureDevOps")"
                                       @onchange="@(() => SetPlatform(PlatformAdo))" />
                                <span>🔷 Azure DevOps</span>
                            </label>
                        </div>
                    </div>

                    <!-- Repo mode -->
                    <div class="config-field">
                        <label>Repository</label>
                        <div class="wizard-radio-group">
                            <label class="wizard-radio @(!_settings.CreateNewRepo ? "selected" : "")">
                                <input type="radio" name="repoMode" checked="@(!_settings.CreateNewRepo)"
                                       @onchange="() => _settings.CreateNewRepo = false" />
                                <span>Use Existing</span>
                            </label>
                            <label class="wizard-radio @(_settings.CreateNewRepo ? "selected" : "")">
                                <input type="radio" name="repoMode" checked="@(_settings.CreateNewRepo)"
                                       @onchange="() => _settings.CreateNewRepo = true" />
                                <span>Create New</span>
                            </label>
                        </div>
                    </div>

                    @if (!_settings.CreateNewRepo)
                    {
                        <!-- Existing repo fields -->
                        @if (_settings.Platform == "GitHub")
                        {
                            <div class="config-field">
                                <label>Repository (owner/repo)</label>
                                <div class="config-pat-row">
                                    <input type="text" class="config-input" placeholder="owner/repo"
                                           @bind="_settings.GitHub.Repo" @bind:event="oninput" />
                                    <button class="config-validate-btn @(_repoVerified == true ? "config-validate-success" : "")"
                                            @onclick="VerifyRepoAsync" disabled="@_repoVerifying">
                                        @if (_repoVerifying) { <span class="config-spinner-sm"></span> }
                                        else { <span>Verify</span> }
                                    </button>
                                </div>
                                @if (_repoVerified == true)
                                {
                                    <div class="config-pat-result config-pat-success">✓ Repository found</div>
                                }
                                else if (_repoVerified == false)
                                {
                                    <div class="config-pat-result config-pat-error">✕ @(_repoError ?? "Repository not found")</div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="config-field-row">
                                <div class="config-field">
                                    <label>Organization</label>
                                    <input type="text" class="config-input" placeholder="my-org"
                                           @bind="_settings.AzureDevOps.Organization" @bind:event="oninput" />
                                </div>
                                <div class="config-field">
                                    <label>Project</label>
                                    <input type="text" class="config-input" placeholder="my-project"
                                           @bind="_settings.AzureDevOps.Project" @bind:event="oninput" />
                                </div>
                            </div>
                            <div class="config-field">
                                <label>Repository</label>
                                <div class="config-pat-row">
                                    <input type="text" class="config-input" placeholder="my-repo"
                                           @bind="_settings.AzureDevOps.Repository" @bind:event="oninput" />
                                    <button class="config-validate-btn @(_repoVerified == true ? "config-validate-success" : "")"
                                            @onclick="VerifyRepoAsync" disabled="@_repoVerifying">
                                        @if (_repoVerifying) { <span class="config-spinner-sm"></span> }
                                        else { <span>Verify</span> }
                                    </button>
                                </div>
                                @if (_repoVerified == true)
                                {
                                    <div class="config-pat-result config-pat-success">✓ Repository found</div>
                                }
                                else if (_repoVerified == false)
                                {
                                    <div class="config-pat-result config-pat-error">✕ @(_repoError ?? "Repository not found")</div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <!-- Create new repo -->
                        <div class="config-field">
                            <label>New Repository Name</label>
                            <div class="config-pat-row">
                                <input type="text" class="config-input" placeholder="my-new-project"
                                       @bind="_settings.NewRepoName" @bind:event="oninput" />
                                <button class="config-validate-btn @(_repoCreated ? "config-validate-success" : "")"
                                        @onclick="CreateRepoAsync"
                                        disabled="@(_repoCreating || string.IsNullOrWhiteSpace(_settings.NewRepoName))">
                                    @if (_repoCreating) { <span class="config-spinner-sm"></span> }
                                    else if (_repoCreated) { <span>✓ Created</span> }
                                    else { <span>Create Private Repo</span> }
                                </button>
                            </div>
                            @if (_repoCreated)
                            {
                                <div class="config-pat-result config-pat-success">✓ Repository created: @_repoCreatedUrl</div>
                            }
                            else if (_repoCreateError is not null)
                            {
                                <div class="config-pat-result config-pat-error">✕ @_repoCreateError</div>
                            }
                        </div>
                    }

                    <!-- Default Branch -->
                    <div class="config-field" style="margin-top:0.5rem;">
                        <label>Default Branch</label>
                        <input type="text" class="config-input" style="max-width:200px;"
                               @bind="CurrentDefaultBranch" @bind:event="oninput" />
                    </div>
                </div>
            </div>

            <!-- Auth Card -->
            <div class="config-card" style="margin-top:1rem;">
                <div class="config-card-header" style="cursor:default;">
                    <span class="config-card-icon">🔐</span>
                    <span class="config-card-title">Authentication</span>
                </div>
                <div class="config-card-body">
                    <!-- Auth Method Toggle -->
                    <div class="config-field" style="margin-bottom:1rem;">
                        <label>Auth Method</label>
                        <div class="auth-method-toggle">
                            <button type="button"
                                    class="auth-method-btn @(_settings.AuthMethod == "Pat" ? "auth-method-active" : "")"
                                    @onclick='() => SwitchAuthMethod("Pat")'>
                                🔑 PAT
                            </button>
                            <button type="button"
                                    class="auth-method-btn @(_settings.AuthMethod == "AzureCliBearer" ? "auth-method-active" : "")"
                                    @onclick='() => SwitchAuthMethod("AzureCliBearer")'>
                                🎫 Bearer Token
                            </button>
                        </div>
                    </div>

                    @if (_settings.AuthMethod == "Pat")
                    {
                        <!-- PAT Input -->
                        <div class="config-field">
                            <label>Personal Access Token (PAT)</label>
                            @if (_hasUserSecretsPat && !_overridePat)
                            {
                                <div class="config-pat-result config-pat-success" style="margin-bottom:0.5rem;">
                                    ✓ PAT configured via User Secrets
                                </div>
                                <p class="config-hint">
                                    Your PAT is securely stored in .NET User Secrets and will be used automatically.
                                    <button class="config-btn-inline" style="margin-left:0.5rem;" @onclick="() => _overridePat = true" type="button">
                                        Use a different PAT
                                    </button>
                                </p>
                            }
                            else
                            {
                                <div class="config-pat-row">
                                    <div class="config-secret-field" style="flex:1;">
                                        <input type="@(_showPat ? "text" : "password")" class="config-input"
                                               placeholder="Paste your PAT here…"
                                               @bind="_patInput" @bind:event="oninput" />
                                        <button class="config-secret-toggle" @onclick="() => _showPat = !_showPat" type="button">
                                            @(_showPat ? "🙈" : "👁️")
                                        </button>
                                    </div>
                                    <button class="config-validate-btn @(_patVerified == true ? "config-validate-success" : "")"
                                            @onclick="VerifyPatAsync" disabled="@(_patVerifying || string.IsNullOrWhiteSpace(_patInput))">
                                        @if (_patVerifying) { <span class="config-spinner-sm"></span> }
                                        else { <span>Verify</span> }
                                    </button>
                                </div>
                                @if (_patVerified == true)
                                {
                                    <div class="config-pat-result config-pat-success">✓ PAT is valid</div>
                                }
                                else if (_patVerified == false)
                                {
                                    <div class="config-pat-result config-pat-error">✕ @(_patError ?? "PAT validation failed")</div>
                                }
                                @if (_overridePat)
                                {
                                    <p class="config-hint">
                                        <button class="config-btn-inline" @onclick="() => { _overridePat = false; _patInput = string.Empty; _patVerified = null; }" type="button">
                                            ← Keep using User Secrets
                                        </button>
                                    </p>
                                }
                                else
                                {
                                    <p class="config-hint">
                                        💡 Prefer User Secrets over pasting here:
                                        <code>dotnet user-secrets set "AgentSquad:DevPlatform:@(_settings.Platform):Pat" "your-pat"</code>
                                    </p>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <!-- Bearer Token Input -->
                        <div class="config-field">
                            <label>Bearer Token</label>
                            @if (_hasUserSecretsBearer && !_overrideBearer)
                            {
                                <div class="config-pat-result config-pat-success" style="margin-bottom:0.5rem;">
                                    ✓ Bearer token configured via User Secrets
                                </div>
                                <p class="config-hint">
                                    Your bearer token is securely stored in .NET User Secrets and will be used automatically.
                                    <button class="config-btn-inline" style="margin-left:0.5rem;" @onclick="() => _overrideBearer = true" type="button">
                                        Use a different token
                                    </button>
                                </p>
                            }
                            else
                            {
                                <div class="config-pat-row">
                                    <div class="config-secret-field" style="flex:1;">
                                        <input type="@(_showBearer ? "text" : "password")" class="config-input"
                                               placeholder="Paste your bearer token here…"
                                               @bind="_bearerInput" @bind:event="oninput" />
                                        <button class="config-secret-toggle" @onclick="() => _showBearer = !_showBearer" type="button">
                                            @(_showBearer ? "🙈" : "👁️")
                                        </button>
                                    </div>
                                    <button class="config-validate-btn @(_bearerVerified == true ? "config-validate-success" : "")"
                                            @onclick="VerifyBearerAsync" disabled="@(_bearerVerifying || string.IsNullOrWhiteSpace(_bearerInput))">
                                        @if (_bearerVerifying) { <span class="config-spinner-sm"></span> }
                                        else { <span>Verify</span> }
                                    </button>
                                </div>
                                @if (_bearerVerified == true)
                                {
                                    <div class="config-pat-result config-pat-success">✓ Bearer token is valid — authenticated as @_bearerUser</div>
                                }
                                else if (_bearerVerified == false)
                                {
                                    <div class="config-pat-result config-pat-error">✕ @(_bearerError ?? "Bearer token validation failed")</div>
                                }
                                @if (_overrideBearer)
                                {
                                    <p class="config-hint">
                                        <button class="config-btn-inline" @onclick="() => { _overrideBearer = false; _bearerInput = string.Empty; _bearerVerified = null; }" type="button">
                                            ← Keep using User Secrets
                                        </button>
                                    </p>
                                }
                                else
                                {
                                    <p class="config-hint">
                                        💡 Prefer User Secrets over pasting here:
                                        <code>dotnet user-secrets set "AgentSquad:DevPlatform:AzureDevOps:BearerToken" "your-token"</code>
                                    </p>
                                }
                            }
                            <div class="config-hint" style="margin-top:0.5rem; padding:0.5rem; background:var(--bg-card-alt, #1a1a2e); border-radius:6px;">
                                ⏱️ Bearer tokens expire in ~1 hour. Get one with:<br/>
                                <code style="font-size:0.8rem;">az account get-access-token --resource 499b84ac-1321-427f-aa17-267ca6975798 --query accessToken -o tsv</code>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* ───── Step 3: Work Item Linking ───── *@
        @if (_currentStep == 2)
        {
            <div class="config-card">
                <div class="config-card-header" style="cursor:default;">
                    <span class="config-card-icon">🔗</span>
                    <span class="config-card-title">Link to Existing Work Item (Optional)</span>
                </div>
                <div class="config-card-body">
                    <div class="config-field">
                        <label>Search by ID, title, or URL</label>
                        <input type="text" class="config-input" placeholder="Search work items…"
                               value="@_workItemQuery"
                               @oninput="OnWorkItemSearchInput" />
                        @if (_workItemSearching)
                        {
                            <div style="margin-top:0.5rem; color:var(--text-secondary);">
                                <span class="config-spinner-sm"></span> Searching…
                            </div>
                        }
                    </div>

                    @if (_workItemResults.Count > 0 && _selectedWorkItem is null)
                    {
                        <div class="wizard-search-results">
                            @foreach (var item in _workItemResults)
                            {
                                <div class="wizard-search-item" @onclick="() => SelectWorkItem(item)">
                                    <span class="wizard-wi-type-badge @GetWorkItemBadgeClass(item.WorkItemType)">@item.WorkItemType</span>
                                    <span class="wizard-wi-id">#@item.Id</span>
                                    <span class="wizard-wi-title">@item.Title</span>
                                    <span class="wizard-wi-state">@item.State</span>
                                </div>
                            }
                        </div>
                    }

                    @if (_selectedWorkItem is not null)
                    {
                        <div class="wizard-selected-item">
                            <div style="display:flex; align-items:center; gap:0.75rem; flex:1;">
                                <span class="wizard-wi-type-badge @GetWorkItemBadgeClass(_selectedWorkItem.WorkItemType)">@_selectedWorkItem.WorkItemType</span>
                                <span style="font-weight:600; color:var(--accent-cyan);">#@_selectedWorkItem.Id</span>
                                <span style="color:var(--text-primary);">@_selectedWorkItem.Title</span>
                                <span class="wizard-wi-state">@_selectedWorkItem.State</span>
                            </div>
                            <button class="config-btn-remove" @onclick="RemoveWorkItem" title="Remove">✕</button>
                        </div>
                    }

                    @if (_workItemSearchError is not null)
                    {
                        <div class="config-pat-result config-pat-error" style="margin-top:0.75rem;">
                            ⚠ @_workItemSearchError
                        </div>
                    }

                    <div style="margin-top:1.5rem; text-align:center;">
                        <button class="wizard-skip-btn" @onclick="() => GoToStep(3)">
                            Skip this step →
                        </button>
                    </div>
                </div>
            </div>
        }

        @* ───── Step 4: Review & Start ───── *@
        @if (_currentStep == 3)
        {
            <div class="config-card">
                <div class="config-card-header" style="cursor:default;">
                    <span class="config-card-icon">📋</span>
                    <span class="config-card-title">Review &amp; Start</span>
                </div>
                <div class="config-card-body">
                    <!-- Warnings -->
                    @if (string.IsNullOrWhiteSpace(_settings.Description))
                    {
                        <div class="wizard-warning">⚠ Description is empty — agents need to know what to build.</div>
                    }
                    @if (_patVerified != true && string.IsNullOrWhiteSpace(_patInput) && !_hasUserSecretsPat
                         && _bearerVerified != true && string.IsNullOrWhiteSpace(_bearerInput) && !_hasUserSecretsBearer)
                    {
                        <div class="wizard-warning">⚠ No authentication configured — agents may not be able to access the repository.</div>
                    }
                    @if (!_settings.CreateNewRepo && !_repoCreated && _repoVerified != true)
                    {
                        <div class="wizard-warning">⚠ Repository has not been verified.</div>
                    }

                    <!-- Summary -->
                    <div class="wizard-summary">
                        <div class="wizard-summary-section">
                            <div class="wizard-summary-section-header">
                                <span>💡 What to Build</span>
                                <button class="config-btn-inline" @onclick="() => GoToStep(0)">Edit</button>
                            </div>
                            <div class="wizard-summary-row">
                                <span class="wizard-summary-label">Description</span>
                                <span class="wizard-summary-value">
                                    @(string.IsNullOrWhiteSpace(_settings.Description)
                                        ? "—"
                                        : (_settings.Description.Length > 200
                                            ? _settings.Description[..200] + "…"
                                            : _settings.Description))
                                </span>
                            </div>
                            <div class="wizard-summary-row">
                                <span class="wizard-summary-label">Tech Stack</span>
                                <span class="wizard-summary-value">@(string.IsNullOrWhiteSpace(_settings.TechStack) ? "AI will choose" : _settings.TechStack)</span>
                            </div>
                            <div class="wizard-summary-row">
                                <span class="wizard-summary-label">Docs Folder</span>
                                <span class="wizard-summary-value">@(string.IsNullOrWhiteSpace(_settings.DocsFolderPath) ? "AgentDocs" : _settings.DocsFolderPath)</span>
                            </div>
                            <div class="wizard-summary-row">
                                <span class="wizard-summary-label">PM Issue Mode</span>
                                <span class="wizard-summary-value">@(_settings.SingleIssueMode ? "📌 Single Issue" : "📝 Detailed User Stories")</span>
                            </div>
                        </div>

                        <div class="wizard-summary-section">
                            <div class="wizard-summary-section-header">
                                <span>📦 Repository</span>
                                <button class="config-btn-inline" @onclick="() => GoToStep(1)">Edit</button>
                            </div>
                            <div class="wizard-summary-row">
                                <span class="wizard-summary-label">Platform</span>
                                <span class="wizard-summary-value">@(_settings.Platform == "GitHub" ? "🐙 GitHub" : "🔷 Azure DevOps")</span>
                            </div>
                            <div class="wizard-summary-row">
                                <span class="wizard-summary-label">Repository</span>
                                <span class="wizard-summary-value">@GetRepoDisplayName()</span>
                            </div>
                            <div class="wizard-summary-row">
                                <span class="wizard-summary-label">Branch</span>
                                <span class="wizard-summary-value">@CurrentDefaultBranch</span>
                            </div>
                            <div class="wizard-summary-row">
                                <span class="wizard-summary-label">Auth</span>
                                <span class="wizard-summary-value">
                                    @if (_settings.AuthMethod == "AzureCliBearer")
                                    {
                                        @if (_bearerVerified == true) { <span style="color:var(--accent-green);">✓ Bearer verified (@_bearerUser)</span> }
                                        else if (!string.IsNullOrWhiteSpace(_bearerInput)) { <span style="color:#f0c674;">Bearer entered (not verified)</span> }
                                        else if (_hasUserSecretsBearer) { <span style="color:var(--accent-green);">✓ Bearer via User Secrets</span> }
                                        else { <span style="color:var(--text-secondary);">Not configured</span> }
                                    }
                                    else
                                    {
                                        @if (_patVerified == true) { <span style="color:var(--accent-green);">✓ PAT verified</span> }
                                        else if (!string.IsNullOrWhiteSpace(_patInput)) { <span style="color:#f0c674;">PAT entered (not verified)</span> }
                                        else if (_hasUserSecretsPat) { <span style="color:var(--accent-green);">✓ Configured via User Secrets</span> }
                                        else { <span style="color:var(--text-secondary);">Not configured</span> }
                                    }
                                </span>
                            </div>
                        </div>

                        <div class="wizard-summary-section">
                            <div class="wizard-summary-section-header">
                                <span>🔗 Work Item</span>
                                <button class="config-btn-inline" @onclick="() => GoToStep(2)">Edit</button>
                            </div>
                            <div class="wizard-summary-row">
                                <span class="wizard-summary-label">Linked Item</span>
                                <span class="wizard-summary-value">
                                    @if (_selectedWorkItem is not null)
                                    {
                                        <span>@_selectedWorkItem.WorkItemType #@_selectedWorkItem.Id — @_selectedWorkItem.Title</span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--text-secondary);">None</span>
                                    }
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Start Button -->
                    <div style="text-align:center; margin-top:2rem;">
                        @if (_startSuccess)
                        {
                            <div class="config-pat-result config-pat-success" style="margin-bottom:1rem; text-align:center; font-size:1.1rem;">
                                🚀 Agents are starting! Redirecting to Overview…
                            </div>
                        }
                        else
                        {
                            <button class="wizard-start-btn" @onclick="StartBuildingAsync"
                                    disabled="@(_starting || string.IsNullOrWhiteSpace(_settings.Description))">
                                @if (_starting)
                                {
                                    <span class="config-spinner-sm"></span>
                                    <span>Starting…</span>
                                }
                                else
                                {
                                    <span>🚀 Start Building</span>
                                }
                            </button>
                        }
                        @if (_startError is not null)
                        {
                            <div class="config-pat-result config-pat-error" style="margin-top:1rem;">
                                ✕ @_startError
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Wizard Navigation -->
    <div class="wizard-actions">
        @if (_currentStep > 0)
        {
            <button class="wizard-nav-btn wizard-back-btn" @onclick="() => GoToStep(_currentStep - 1)">
                ← Back
            </button>
        }
        else
        {
            <div></div>
        }

        @if (_currentStep < 3)
        {
            <button class="wizard-nav-btn wizard-next-btn" @onclick="() => GoToStep(_currentStep + 1)"
                    disabled="@(!CanAdvance())">
                Next →
            </button>
        }
    </div>
}

@code {
    private static readonly string[] _stepLabels = { "What to Build", "Repo & Auth", "Work Items", "Review" };
    private const string PlatformGitHub = "GitHub";
    private const string PlatformAdo = "AzureDevOps";

    private DevelopSettings _settings = new();
    private int _currentStep;
    private bool _loading = true;
    private string? _globalError;

    // Step 2 state — PAT
    private string _patInput = "";
    private bool _showPat;
    private bool _patVerifying;
    private bool? _patVerified;
    private string? _patError;
    private bool _hasUserSecretsPat;
    private bool _overridePat;
    // Step 2 state — Bearer Token
    private string _bearerInput = "";
    private bool _showBearer;
    private bool _bearerVerifying;
    private bool? _bearerVerified;
    private string? _bearerError;
    private string? _bearerUser;
    private bool _hasUserSecretsBearer;
    private bool _overrideBearer;
    // Step 2 state — Repo
    private bool _repoVerifying;
    private bool? _repoVerified;
    private string? _repoError;
    private bool _repoCreating;
    private bool _repoCreated;
    private string? _repoCreatedUrl;
    private string? _repoCreateError;

    // Step 3 state
    private string _workItemQuery = "";
    private bool _workItemSearching;
    private string? _workItemSearchError;
    private List<WorkItemSearchResult> _workItemResults = new();
    private WorkItemSearchResult? _selectedWorkItem;
    private Timer? _debounceTimer;
    private CancellationTokenSource? _searchCts;

    // Step 4 state
    private bool _starting;
    private bool _startSuccess;
    private string? _startError;

    private string CurrentDefaultBranch
    {
        get => _settings.Platform == "GitHub" ? _settings.GitHub.DefaultBranch : _settings.AzureDevOps.DefaultBranch;
        set
        {
            if (_settings.Platform == "GitHub")
                _settings.GitHub.DefaultBranch = value;
            else
                _settings.AzureDevOps.DefaultBranch = value;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _settings = await SettingsService.LoadAsync();
            if (_settings.ParentWorkItemId.HasValue)
            {
                _ = LoadLinkedWorkItemAsync(_settings.ParentWorkItemId.Value);
            }

            // Check if a PAT or Bearer token is already configured via User Secrets / runtime config
            try
            {
                var config = ConfigService.GetCurrentConfig();
                _hasUserSecretsPat = _settings.Platform switch
                {
                    "AzureDevOps" => !string.IsNullOrWhiteSpace(config.DevPlatform?.AzureDevOps?.Pat),
                    "GitHub" => !string.IsNullOrWhiteSpace(config.Project?.GitHubToken),
                    _ => false
                };
                _hasUserSecretsBearer = _settings.Platform == "AzureDevOps"
                    && !string.IsNullOrWhiteSpace(config.DevPlatform?.AzureDevOps?.BearerToken);
            }
            catch
            {
                _hasUserSecretsPat = false;
                _hasUserSecretsBearer = false;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load develop settings");
            _globalError = "Failed to load settings: " + ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoToStep(int step)
    {
        if (step >= 0 && step <= 3)
            _currentStep = step;
    }

    private void JumpToStep(int step)
    {
        if (step <= _currentStep || CanAdvanceToStep(step))
            _currentStep = step;
    }

    private bool CanAdvance()
    {
        return _currentStep switch
        {
            0 => !string.IsNullOrWhiteSpace(_settings.Description),
            1 => true,
            2 => true,
            _ => false
        };
    }

    private bool CanAdvanceToStep(int target)
    {
        for (int i = 0; i < target; i++)
        {
            if (i == 0 && string.IsNullOrWhiteSpace(_settings.Description))
                return false;
        }
        return true;
    }

    private void SetPlatform(string platform)
    {
        _settings.Platform = platform;
        _repoVerified = null;
        _repoError = null;
    }

    private string GetRepoDisplayName()
    {
        if (_settings.CreateNewRepo)
            return string.IsNullOrWhiteSpace(_settings.NewRepoName) ? "—" : $"{_settings.NewRepoName} (new)";
        if (_settings.Platform == "GitHub")
            return string.IsNullOrWhiteSpace(_settings.GitHub.Repo) ? "—" : _settings.GitHub.Repo;
        var ado = _settings.AzureDevOps;
        return string.IsNullOrWhiteSpace(ado.Repository) ? "—" : $"{ado.Organization}/{ado.Project}/{ado.Repository}";
    }

    // ── Step 2: Repo verification (saves settings then reads back for validation) ──
    private async Task VerifyRepoAsync()
    {
        _repoVerifying = true;
        _repoVerified = null;
        _repoError = null;
        try
        {
            await SettingsService.SaveAsync(_settings);
            // If save succeeds, consider repo config valid (actual connectivity checked at start)
            _repoVerified = true;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Repo verification failed");
            _repoVerified = false;
            _repoError = ex.Message;
        }
        finally
        {
            _repoVerifying = false;
        }
    }

    private async Task VerifyPatAsync()
    {
        _patVerifying = true;
        _patVerified = null;
        _patError = null;
        try
        {
            // Basic client-side validation — actual auth check happens at agent start
            if (string.IsNullOrWhiteSpace(_patInput) || _patInput.Length < 10)
            {
                _patVerified = false;
                _patError = "PAT appears too short. GitHub PATs start with 'ghp_', ADO PATs are 52+ characters.";
                return;
            }
            _patVerified = true;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "PAT verification failed");
            _patVerified = false;
            _patError = ex.Message;
        }
        finally
        {
            _patVerifying = false;
        }
        await Task.CompletedTask;
    }

    private void SwitchAuthMethod(string method)
    {
        _settings.AuthMethod = method;
        // Reset verification state when switching
        _patVerified = null;
        _patError = null;
        _bearerVerified = null;
        _bearerError = null;
        _bearerUser = null;
    }

    private async Task VerifyBearerAsync()
    {
        _bearerVerifying = true;
        _bearerVerified = null;
        _bearerError = null;
        _bearerUser = null;
        try
        {
            if (string.IsNullOrWhiteSpace(_bearerInput) || _bearerInput.Length < 100)
            {
                _bearerVerified = false;
                _bearerError = "Bearer token appears too short. ADO bearer tokens are typically 2000+ characters.";
                return;
            }

            // Live verification: call ADO connection data API with the bearer token
            var org = _settings.AzureDevOps.Organization;
            if (string.IsNullOrWhiteSpace(org))
            {
                _bearerVerified = false;
                _bearerError = "Set the ADO organization first so we can verify the token.";
                return;
            }

            using var http = new HttpClient();
            http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", _bearerInput.Trim());
            var resp = await http.GetAsync($"https://dev.azure.com/{org}/_apis/connectionData");
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                _bearerUser = json.GetProperty("authenticatedUser")
                    .GetProperty("providerDisplayName").GetString() ?? "Unknown";
                _bearerVerified = true;
            }
            else
            {
                _bearerVerified = false;
                _bearerError = $"ADO returned {(int)resp.StatusCode}. Token may be expired or invalid for org '{org}'.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Bearer token verification failed");
            _bearerVerified = false;
            _bearerError = ex.Message;
        }
        finally
        {
            _bearerVerifying = false;
        }
    }

    private async Task CreateRepoAsync()
    {
        _repoCreating = true;
        _repoCreated = false;
        _repoCreateError = null;
        try
        {
            var result = await RepoService.CreateRepositoryAsync(_settings.NewRepoName, isPrivate: true);
            if (result.Success)
            {
                _repoCreated = true;
                _repoCreatedUrl = result.RepositoryUrl;
            }
            else
            {
                _repoCreateError = result.ErrorMessage ?? "Failed to create repository";
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Repo creation failed");
            _repoCreateError = ex.Message;
        }
        finally
        {
            _repoCreating = false;
        }
    }

    // ── Step 3: Work item search with debounce ──
    private void OnWorkItemSearchInput(ChangeEventArgs e)
    {
        _workItemQuery = e.Value?.ToString() ?? "";
        _debounceTimer?.Dispose();

        if (string.IsNullOrWhiteSpace(_workItemQuery))
        {
            _workItemResults.Clear();
            _workItemSearchError = null;
            return;
        }

        var query = _workItemQuery;
        _debounceTimer = new Timer(300);
        _debounceTimer.AutoReset = false;
        _debounceTimer.Elapsed += async (_, _) =>
        {
            await InvokeAsync(async () =>
            {
                await SearchWorkItemsAsync(query);
                StateHasChanged();
            });
        };
        _debounceTimer.Start();
    }

    private async Task SearchWorkItemsAsync(string query)
    {
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var ct = _searchCts.Token;

        _workItemSearching = true;
        _workItemSearchError = null;
        try
        {
            var results = await WorkItemSearch.SearchAsync(query, maxResults: 10, ct);
            if (!ct.IsCancellationRequested)
            {
                _workItemResults = results.ToList();
            }
        }
        catch (OperationCanceledException) { /* expected */ }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Work item search failed for query: {Query}", query);
            _workItemSearchError = "Search failed: " + ex.Message;
        }
        finally
        {
            _workItemSearching = false;
        }
    }

    private void SelectWorkItem(WorkItemSearchResult item)
    {
        _selectedWorkItem = item;
        _settings.ParentWorkItemId = item.Id;
        _workItemResults.Clear();
        _workItemQuery = "";
    }

    private void RemoveWorkItem()
    {
        _selectedWorkItem = null;
        _settings.ParentWorkItemId = null;
    }

    private async Task LoadLinkedWorkItemAsync(int id)
    {
        try
        {
            var results = await WorkItemSearch.SearchAsync(id.ToString(), maxResults: 1);
            if (results.Count > 0)
            {
                _selectedWorkItem = results[0];
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load linked work item {Id}", id);
        }
    }

    private static string GetWorkItemBadgeClass(string type) => type.ToLowerInvariant() switch
    {
        "bug" => "wi-bug",
        "epic" => "wi-epic",
        "feature" => "wi-feature",
        "user story" => "wi-story",
        "task" => "wi-task",
        _ => "wi-default"
    };

    // ── Step 4: Start ──
    private async Task StartBuildingAsync()
    {
        _starting = true;
        _startError = null;
        _startSuccess = false;
        try
        {
            await SettingsService.SaveAsync(_settings);
            // The /api/develop/start endpoint validates and returns started=true
            _startSuccess = true;
            Logger.LogInformation("Build started for: {Description}", _settings.Description[..Math.Min(80, _settings.Description.Length)]);

            // Brief delay then navigate to overview
            await Task.Delay(1500);
            Navigation.NavigateTo("/", forceLoad: false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to start build");
            _startError = ex.Message;
        }
        finally
        {
            _starting = false;
        }
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
        _searchCts?.Cancel();
        _searchCts?.Dispose();
    }
}

