@page "/"
@rendermode InteractiveServer
@using AgentSquad.Core.Agents
@using AgentSquad.Core.Agents.Decisions
@using AgentSquad.Core.Agents.Steps
@using AgentSquad.Core.Configuration
@using AgentSquad.Core.Diagnostics
@using AgentSquad.Core.GitHub
@using AgentSquad.Core.Notifications
@using AgentSquad.Dashboard.Services
@using Microsoft.Extensions.Logging
@using Markdig
@implements IDisposable
@inject IDashboardDataService DataService
@inject NavigationManager Navigation
@inject IServiceProvider ServiceProvider
@inject IGitHubService GitHub

<PageTitle>AgentSquad — Overview</PageTitle>

<div class="dashboard-header" data-testid="page-agent-overview">
    <h1>Agent Overview</h1>
    <div class="header-badges">
        <span class="header-badge @HealthClass">
            @if (_hasDeadlock) { <span>⚠</span> } else { <span>●</span> }
            @HealthLabel
        </span>
        <div class="agent-filter-wrap">
            <button class="header-badge agent-filter-toggle" @onclick="ToggleAgentFilter" data-testid="agents-filter-toggle">
                🤖 @_visibleAgents.Count Agents@(_hiddenAgentIds.Count > 0 ? $", {_hiddenAgentIds.Count} Hidden" : "")
                <span class="agent-filter-chevron">▾</span>
            </button>
            @if (_showAgentFilter)
            {
                <div class="agent-filter-dropdown">
                    @foreach (var agent in _agents)
                    {
                        var isHidden = _hiddenAgentIds.Contains(agent.Id);
                        <button class="agent-filter-item @(isHidden ? "hidden-agent" : "")" @onclick="() => ToggleAgentVisibility(agent.Id)">
                            <span class="agent-filter-check">@(isHidden ? "☐" : "☑")</span>
                            <span class="agent-filter-name">@agent.DisplayName</span>
                            <span class="agent-filter-status status-@(agent.Status.ToString().ToLowerInvariant())">@agent.Status</span>
                        </button>
                    }
                </div>
            }
        </div>
        @{ var ncCount = _agents.Count(a => !a.DiagnosticCompliant); }
        @if (ncCount > 0)
        {
            <span class="header-badge danger">⚠ @ncCount Non-Compliant</span>
        }
        <button class="ntl-refresh-btn @(_refreshing ? "spinning" : "")" @onclick="ForceRefreshAsync" title="Force refresh" disabled="@_refreshing" data-testid="agents-force-refresh"><svg class="ntl-refresh-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13.5 8a5.5 5.5 0 1 1-1.6-3.9M13.5 2.5v2h-2"/></svg></button>
    </div>
</div>

@if (_hasDeadlock)
{
    <div class="deadlock-banner">
        <span class="deadlock-icon">🔒</span>
        <span>Deadlock detected among agents: @(string.Join(" → ", _deadlockCycle ?? []))</span>
    </div>
}

@if (_isProjectComplete)
{
    <div class="project-complete-banner" data-testid="project-complete-banner">
        <div class="complete-icon">🎉</div>
        <div class="complete-content">
            <h2>Project Complete!</h2>
            <p>All PRs merged and all issues closed — the project has been delivered successfully.</p>
        </div>
    </div>
}

@* ── Project Control Card ── *@
<div class="project-control-card">
    <div class="project-control-header">
        <span class="project-control-icon">
            @switch (_runState)
            {
                case "Running": <span>🚀</span> break;
                case "Paused": <span>⏸️</span> break;
                case "Completed": <span>✅</span> break;
                case "Failed": <span>❌</span> break;
                default: <span>⏹️</span> break;
            }
        </span>
        <div class="project-control-info">
            <span class="project-control-title">
                @if (!string.IsNullOrEmpty(_runDisplayName))
                {
                    @_runDisplayName
                }
                else
                {
                    <span>No Active Run</span>
                }
            </span>
            <span class="project-control-status status-@_runState.ToLowerInvariant()">@_runState</span>
            @if (!string.IsNullOrEmpty(_runMode))
            {
                <span class="project-control-mode">@_runMode</span>
            }
        </div>
        <div class="project-control-actions">
            @if (_runState is "Idle" or "" or "Completed" or "Failed" or "Cancelled")
            {
                <button class="btn-primary" @onclick="StartProjectAsync" disabled="@_runActionPending"
                        title="Starts a new project run using the project description and settings from the Configuration page. Agents will be spawned according to the selected framework strategy.">
                    @(_runActionPending ? "Starting..." : "▶ Start Project")
                </button>
            }
            else if (_runState is "Running")
            {
                <button class="btn-danger" @onclick="PauseRunAsync" disabled="@_runActionPending"
                        title="Pauses the current run. All agents will be stopped gracefully and workflow state will be checkpointed. You can resume later with the Continue button.">
                    @(_runActionPending ? "Pausing..." : "⏸ Pause")
                </button>
            }
            else if (_runState is "Paused")
            {
                <button class="btn-primary" @onclick="ResumeRunAsync" disabled="@_runActionPending"
                        title="Resumes the paused run. Agents will be respawned and continue from the last checkpointed workflow phase.">
                    @(_runActionPending ? "Resuming..." : "▶ Continue")
                </button>
            }
        </div>
    </div>
    @if (!string.IsNullOrEmpty(_runError))
    {
        <div class="project-control-error">⚠ @_runError</div>
    }
</div>

<div class="stats-row">
    <div class="stat-card">
        <div class="stat-label">Total Agents</div>
        <div class="stat-value">@_agents.Count</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Idle</div>
        <div class="stat-value green">@CountByStatus(AgentStatus.Idle)</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Working</div>
        <div class="stat-value cyan">@CountByStatus(AgentStatus.Working)</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Blocked</div>
        <div class="stat-value red">@CountByStatus(AgentStatus.Blocked)</div>
    </div>
    @if (_decisionLog is not null)
    {
        var pending = _decisionLog.GetPendingDecisions().Count;
        var total = _decisionLog.GetAllDecisions().Count;
        <div class="stat-card @(pending > 0 ? "stat-card-alert" : "")">
            <div class="stat-label">⚖️ Decisions</div>
            <div class="stat-value @(pending > 0 ? "amber" : "")">
                @total
                @if (pending > 0)
                {
                    <span class="stat-sub-badge">@pending gated</span>
                }
            </div>
        </div>
    }
</div>

@if (_teamComposition is not null)
{
    <div class="team-composition-card" @onclick="() => _teamCompExpanded = !_teamCompExpanded">
        <div class="team-comp-header">
            <span class="team-comp-icon">🏗️</span>
            <span class="team-comp-title">Team Composition</span>
            <span class="team-comp-summary">@_teamCompSummary</span>
            <span class="team-comp-chevron @(_teamCompExpanded ? "expanded" : "")">▶</span>
        </div>
        @if (_teamCompExpanded)
        {
            <div class="team-comp-body" @onclick:stopPropagation="true">
                @((MarkupString)Markdig.Markdown.ToHtml(_teamComposition, _mdPipeline))
            </div>
        }
    </div>
}

@if (_agents.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">🤖</div>
        <div class="empty-text">No agents registered</div>
        <div class="empty-sub">Agents will appear here once they connect to the orchestrator</div>
    </div>
}
else
{
    <div class="agent-grid">
        @foreach (var agent in _visibleAgents)
        {
            var statusClass = $"status-{agent.Status.ToString().ToLowerInvariant()}";
            var roleClass = $"role-{agent.Role.ToString().ToLowerInvariant()}";
            var selectedClass = _selectedAgentId == agent.Id ? "selected" : "";
            var approvalClass = IsAwaitingApproval(agent) ? "awaiting-approval" : "";

            <div class="agent-card @statusClass @selectedClass @approvalClass" @onclick="() => NavigateToAgent(agent.Id)" data-testid="agent-card" data-agent-id="@agent.Id" data-agent-status="@agent.Status">
                <div class="agent-card-header">
                    <div class="agent-avatar @roleClass">
                        @GetRoleInitials(agent.Role, agent.Specialty)
                    </div>
                    <div class="agent-info">
                        <div class="agent-name" title="@agent.DisplayName">@agent.DisplayName</div>
                        <div class="agent-role">@FormatRole(agent.Role, agent.Specialty)</div>
                        @if (agent.Capabilities.Count > 0)
                        {
                            <div class="agent-capabilities">
                                @foreach (var cap in agent.Capabilities.Take(3))
                                {
                                    <span class="capability-tag">@cap</span>
                                }
                                @if (agent.Capabilities.Count > 3)
                                {
                                    <span class="capability-more">+@(agent.Capabilities.Count - 3)</span>
                                }
                            </div>
                        }
                    </div>
                    <span class="status-badge @statusClass">
                        <span class="status-dot"></span>
                        @agent.Status
                    </span>
                </div>
                <div class="agent-card-body">
                    <div class="agent-detail">
                        <span class="detail-label">Task</span>
                        @if (!string.IsNullOrEmpty(agent.StatusReason))
                        {
                            <span class="detail-value task-active" title="@agent.StatusReason">@TruncateTask(agent.StatusReason)</span>
                        }
                        else if (agent.AssignedPullRequest is not null)
                        {
                            <span class="detail-value task-active">PR #@agent.AssignedPullRequest</span>
                        }
                        else
                        {
                            <span class="detail-value task-idle">Idle</span>
                        }
                    </div>

                    @* Work item link (PR or Issue) *@
                    @{ var prNum = ExtractPrNumber(agent.StatusReason) ?? agent.AssignedPullRequest; }
                    @if (prNum is not null)
                    {
                        <div class="agent-detail" @onclick:stopPropagation="true">
                            <span class="detail-label">🔗 Work</span>
                            <a class="detail-value work-link" href="https://github.com/@DataService.RepositoryDisplayName/pull/@prNum" target="_blank" rel="noopener">
                                PR #@prNum ↗
                            </a>
                        </div>
                    }

                    @* Approval details when awaiting gate *@
                    @if (IsAwaitingApproval(agent))
                    {
                        var gate = GetActiveGateForAgent(agent);
                        <div class="agent-detail approval-detail">
                            <span class="detail-label">🚦 Gate</span>
                            <span class="detail-value approval-value">
                                @if (gate is not null)
                                {
                                    <span title="@gate.Context">@gate.GateName</span>
                                    @if (gate.GitHubUrl is not null)
                                    {
                                        <a class="gate-link" href="@gate.GitHubUrl" target="_blank" rel="noopener" @onclick:stopPropagation="true">Review ↗</a>
                                    }
                                }
                                else
                                {
                                    <span>@ExtractGateName(agent.StatusReason)</span>
                                }
                            </span>
                        </div>
                    }

                    @* Diagnostic justification *@
                    @if (!string.IsNullOrEmpty(agent.DiagnosticSummary))
                    {
                        <div class="agent-detail diagnostic-row" title="@agent.DiagnosticJustification">
                            <span class="detail-label">@(agent.DiagnosticCompliant ? "✅" : "⚠️") Why</span>
                            <span class="detail-value diagnostic-value @(agent.DiagnosticCompliant ? "" : "non-compliant-text")">
                                @TruncateDiagnostic(agent.DiagnosticSummary)
                            </span>
                        </div>
                    }

                    <div class="agent-detail" @onclick:stopPropagation="true">
                        <span class="detail-label">Model</span>
                        @if (_editingModelAgentId == agent.Id)
                        {
                            <select class="model-select" value="@agent.ActiveModel"
                                    @onchange="(e) => OnModelSelected(agent.Id, e)" data-testid="agent-card-model-select">
                                @foreach (var model in _availableModels)
                                {
                                    <option value="@model" selected="@(model == agent.ActiveModel)">@model</option>
                                }
                            </select>
                            <button class="model-edit-btn" @onclick="() => _editingModelAgentId = null" title="Cancel" data-testid="agent-card-model-cancel">✕</button>
                        }
                        else
                        {
                            <span class="detail-value">@agent.ActiveModel</span>
                            <button class="model-edit-btn" @onclick="() => _editingModelAgentId = agent.Id" title="Change model" data-testid="agent-card-model-edit">✏️</button>
                        }
                    </div>
                    @if (agent.Status == AgentStatus.Working)
                    {
                        <div class="agent-detail">
                            <span class="detail-label">Duration</span>
                            <span class="detail-value task-active">@FormatDuration(DateTime.UtcNow - agent.LastStatusChange)</span>
                        </div>
                    }
                    @{ var stepInfo = GetAgentStepInfo(agent.Id); }
                    @if (stepInfo.total > 0)
                    {
                        var stepPct = (int)(100.0 * stepInfo.completed / stepInfo.total);
                        <div class="agent-detail">
                            <span class="detail-label">Steps</span>
                            <span class="detail-value">
                                <div class="step-compact" title="@stepInfo.tooltip">
                                    <span class="step-compact-text">Step @(stepInfo.completed)/@(stepInfo.total): @(stepInfo.currentName ?? "—")</span>
                                    <div class="step-compact-bar">
                                        <div class="step-compact-fill" style="width: @(stepPct)%"></div>
                                    </div>
                                </div>
                            </span>
                        </div>
                    }
                    @if (agent.ErrorCount > 0)
                    {
                        <div class="agent-detail error-badge-row" @onclick:stopPropagation="true" @onclick="() => ShowErrors(agent.Id)" data-testid="agent-card-error-badge">
                            <span class="error-badge">⚠ @agent.ErrorCount error@(agent.ErrorCount != 1 ? "s" : "")</span>
                        </div>
                    }
                    <div class="agent-actions" @onclick:stopPropagation="true">
                        <button class="action-btn chat-btn" @onclick="() => OpenChat(agent.Id)" title="Chat with this agent" data-testid="agent-card-chat-btn">💬 Chat</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (_showErrorModal && _errorModalAgentId is not null)
{
    <div class="modal-overlay" @onclick="CloseErrorModal" data-testid="modal-agent-errors">
        <div class="error-modal" @onclick:stopPropagation="true">
            <div class="error-modal-header">
                <h3>Errors — @_errorModalAgentName</h3>
                <button class="modal-close" @onclick="CloseErrorModal" data-testid="modal-error-close">✕</button>
            </div>
            <div class="error-modal-body" data-testid="modal-error-body">
                @if (_errorEntries.Count == 0)
                {
                    <div class="empty-errors">No errors recorded</div>
                }
                else
                {
                    @foreach (var err in _errorEntries)
                    {
                        <div class="error-entry @(err.Level == Microsoft.Extensions.Logging.LogLevel.Warning ? "warn" : "err")" data-testid="modal-error-entry">
                            <div class="error-entry-header">
                                <span class="error-level">@(err.Level == Microsoft.Extensions.Logging.LogLevel.Warning ? "⚠ WARN" : "❌ ERROR")</span>
                                <span class="error-time">@err.Timestamp.ToString("HH:mm:ss")</span>
                            </div>
                            <div class="error-message">@err.Message</div>
                            @if (err.ExceptionDetails is not null)
                            {
                                <details class="error-details">
                                    <summary>Stack trace</summary>
                                    <pre>@err.ExceptionDetails</pre>
                                </details>
                            }
                        </div>
                    }
                }
            </div>
            <div class="error-modal-footer">
                <button class="btn-reset" @onclick="ResetErrors" data-testid="modal-error-reset">Clear All Errors</button>
            </div>
        </div>
    </div>
}

@* Chat Modal *@
@if (_showChatModal && _chatAgentId is not null)
{
    <div class="modal-overlay" @onclick="CloseChat">
        <div class="chat-modal" @onclick:stopPropagation="true">
            <div class="chat-modal-header">
                <div class="chat-header-left">
                    <h3>💬 @_chatAgentName</h3>
                    @if (_chatAgent is not null && !string.IsNullOrEmpty(_chatAgent.DiagnosticSummary))
                    {
                        <span class="chat-diag-badge @(_chatAgent.DiagnosticCompliant ? "compliant" : "non-compliant")"
                              title="@_chatAgent.DiagnosticJustification">
                            @(_chatAgent.DiagnosticCompliant ? "✅" : "⚠️") @_chatAgent.DiagnosticSummary
                        </span>
                    }
                </div>
                <button class="modal-close" @onclick="CloseChat">✕</button>
            </div>
            <div class="chat-modal-body">
                @if (_chatMessages.Count == 0 && !_chatSending)
                {
                    <div class="chat-empty">
                        <div class="chat-empty-icon">💬</div>
                        <div class="chat-empty-text">Ask @_chatAgentName anything</div>
                        <div class="chat-empty-examples">
                            <div class="chat-example" @onclick='() => SetChatInput("What are you currently working on and why?")'>
                                "What are you currently working on and why?"
                            </div>
                            <div class="chat-example" @onclick='() => SetChatInput("Explain your last decision in detail.")'>
                                "Explain your last decision in detail."
                            </div>
                            <div class="chat-example" @onclick='() => SetChatInput("What should you be doing right now according to the scenarios?")'>
                                "What should you be doing right now?"
                            </div>
                        </div>
                    </div>
                }
                @foreach (var msg in _chatMessages)
                {
                    <div class="chat-message @(msg.Role == "user" ? "chat-user" : "chat-assistant")">
                        <div class="chat-msg-header">
                            <span class="chat-role">@(msg.Role == "user" ? "👤 You" : $"🤖 {_chatAgentName}")</span>
                            <span class="chat-time">@msg.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                        </div>
                        <div class="chat-msg-body">@((MarkupString)RenderMarkdown(msg.Content))</div>
                    </div>
                }
                @if (_chatSending)
                {
                    <div class="chat-message chat-assistant">
                        <div class="chat-msg-header">
                            <span class="chat-role">🤖 @_chatAgentName</span>
                        </div>
                        <div class="chat-msg-body chat-typing">Thinking…</div>
                    </div>
                }
            </div>
            <div class="chat-modal-footer">
                <input class="chat-input" type="text" placeholder="Ask a question or give an instruction…"
                       @bind="_chatInput" @bind:event="oninput"
                       @onkeydown="OnChatKeyDown"
                       disabled="@_chatSending" />
                <button class="chat-send-btn" @onclick="SendChat"
                        disabled="@(_chatSending || string.IsNullOrWhiteSpace(_chatInput))">
                    @(_chatSending ? "⏳" : "➤")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<AgentSnapshot> _agents = [];
    private HashSet<string> _hiddenAgentIds = [];
    private bool _showAgentFilter;
    private List<AgentSnapshot> _visibleAgents => _agents.Where(a => !_hiddenAgentIds.Contains(a.Id)).ToList();

    // Project control state
    private string _runState = "Idle";
    private string _runMode = "";
    private string _runDisplayName = "";
    private string _runError = "";
    private bool _runActionPending;
    private HttpClient? _runsHttp;
    private string? _selectedAgentId;
    private bool _hasDeadlock;
    private List<string>? _deadlockCycle;
    private IDecisionLog? _decisionLog;
    private IAgentTaskTracker? _taskTracker;

    // Error modal state
    private bool _showErrorModal;
    private string? _errorModalAgentId;
    private string? _errorModalAgentName;
    private List<AgentLogEntry> _errorEntries = [];

    // Model editing state
    private string? _editingModelAgentId;
    private IReadOnlyList<string> _availableModels = [];

    // Chat modal state
    private bool _showChatModal;
    private string? _chatAgentId;
    private string? _chatAgentName;
    private AgentSnapshot? _chatAgent;
    private List<AgentChatMessage> _chatMessages = [];
    private string _chatInput = "";
    private bool _chatSending;
    private bool _refreshing;
    private bool _isProjectComplete;

    // Team composition state
    private string? _teamComposition;
    private string _teamCompSummary = "";
    private bool _teamCompExpanded;

    protected override void OnInitialized()
    {
        _decisionLog = ServiceProvider.GetService<IDecisionLog>();
        _taskTracker = ServiceProvider.GetService<IAgentTaskTracker>();
        RefreshData();
        _availableModels = DataService.GetAvailableModels();
        DataService.OnChange += OnDataChanged;

        // Set up HTTP client for run control API
        var factory = ServiceProvider.GetService<IHttpClientFactory>();
        if (factory is not null)
        {
            _runsHttp = factory.CreateClient("RunnerApi");
        }

        _ = LoadTeamCompositionAsync();
        _ = LoadRunStateAsync();
    }

    private void RefreshData()
    {
        _agents = DataService.GetAllAgentSnapshots().ToList();
        _hasDeadlock = DataService.HasDeadlock(out _deadlockCycle);
        var health = DataService.GetExecutionHealthAssessment();
        _isProjectComplete = health.Phase == "Completion" && _runState is "Running" or "Completed";
    }

    private async Task LoadTeamCompositionAsync()
    {
        try
        {
            var content = await GitHub.GetFileContentAsync("TeamComposition.md");
            if (!string.IsNullOrWhiteSpace(content))
            {
                _teamComposition = content;
                // Extract summary line: "X built-in, Y SME agents" or role count
                var lines = content.Split('\n');
                var rationale = lines.FirstOrDefault(l => l.StartsWith("This is", StringComparison.OrdinalIgnoreCase)
                    || l.StartsWith("The project", StringComparison.OrdinalIgnoreCase));
                var roleCount = lines.Count(l => l.TrimStart().StartsWith("|") && !l.Contains("---") && !l.Contains("Role"));
                _teamCompSummary = roleCount > 0 ? $"{roleCount} roles assigned" : "View details";
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { /* File not yet created — will appear after PM runs */ }
    }

    private void ToggleAgentFilter() => _showAgentFilter = !_showAgentFilter;

    private void ToggleAgentVisibility(string agentId)
    {
        if (!_hiddenAgentIds.Remove(agentId))
            _hiddenAgentIds.Add(agentId);
    }

    private async Task ForceRefreshAsync()
    {
        _refreshing = true;
        StateHasChanged();
        try
        {
            DataService.ResetCaches();
            RefreshData();
        }
        finally
        {
            _refreshing = false;
            StateHasChanged();
        }
    }

    private async void OnDataChanged()
    {
        RefreshData();
        // Re-check for TeamComposition.md if not yet loaded
        if (_teamComposition is null)
            await LoadTeamCompositionAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void SelectAgent(string agentId)
    {
        _selectedAgentId = _selectedAgentId == agentId ? null : agentId;
    }

    private void NavigateToAgent(string agentId)
    {
        Navigation.NavigateTo($"/agent/{agentId}");
    }

    private int CountByStatus(AgentStatus status) =>
        _agents.Count(a => a.Status == status);

    private static bool IsAwaitingApproval(AgentSnapshot agent) =>
        agent.StatusReason?.Contains("Awaiting human approval", StringComparison.OrdinalIgnoreCase) == true;

    private string HealthClass => _hasDeadlock ? "danger" :
        _agents.Any(a => a.Status == AgentStatus.Blocked) ? "warning" : "healthy";

    private string HealthLabel => _hasDeadlock ? "Deadlock" :
        _agents.Any(a => a.Status == AgentStatus.Blocked) ? "Degraded" : "Healthy";

    private static string GetRoleInitials(AgentRole role, string? specialty = null) => role switch
    {
        AgentRole.ProgramManager => "PM",
        AgentRole.Researcher => "RS",
        AgentRole.Architect => "AR",
        AgentRole.SoftwareEngineer => "SWE",
        AgentRole.TestEngineer => "TE",
        AgentRole.Custom when !string.IsNullOrEmpty(specialty) => GetInitialsFromName(specialty),
        _ => "??"
    };

    private static string GetInitialsFromName(string name)
    {
        var words = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return words.Length >= 2
            ? $"{words[0][0]}{words[1][0]}".ToUpperInvariant()
            : name.Length >= 2 ? name[..2].ToUpperInvariant() : name.ToUpperInvariant();
    }

    private static string FormatRole(AgentRole role, string? specialty = null) => role switch
    {
        AgentRole.ProgramManager => "Program Manager",
        AgentRole.Researcher => "Researcher",
        AgentRole.Architect => "Architect",
        AgentRole.SoftwareEngineer => "Software Engineer",
        AgentRole.TestEngineer => "Test Engineer",
        AgentRole.Custom when !string.IsNullOrEmpty(specialty) => "SME Specialist",
        _ => role.ToString()
    };

    private static string FormatDuration(TimeSpan ts) => ts.TotalHours >= 1
        ? $"{ts.Hours}h {ts.Minutes}m"
        : ts.TotalMinutes >= 1
            ? $"{ts.Minutes}m {ts.Seconds}s"
            : $"{ts.Seconds}s";

    private static string TruncateTask(string text) =>
        text.Length <= 40 ? text : string.Concat(text.AsSpan(0, 37), "...");

    private static string TruncateDiagnostic(string text) =>
        text.Length <= 80 ? text : string.Concat(text.AsSpan(0, 77), "...");

    private static readonly MarkdownPipeline _mdPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private static string RenderMarkdown(string markdown) =>
        Markdown.ToHtml(markdown ?? "", _mdPipeline);

    private void OnModelSelected(string agentId, ChangeEventArgs e)
    {
        var newModel = e.Value?.ToString();
        if (!string.IsNullOrEmpty(newModel))
        {
            DataService.SetAgentModel(agentId, newModel);
            _editingModelAgentId = null;
        }
    }

    private void ShowErrors(string agentId)
    {
        var agent = _agents.FirstOrDefault(a => a.Id == agentId);
        if (agent is null) return;

        _errorModalAgentId = agentId;
        _errorModalAgentName = agent.DisplayName;
        _errorEntries = DataService.GetAgentErrors(agentId).ToList();
        _showErrorModal = true;
    }

    private void CloseErrorModal()
    {
        _showErrorModal = false;
        _errorModalAgentId = null;
        _errorEntries = [];
    }

    private void ResetErrors()
    {
        if (_errorModalAgentId is not null)
        {
            DataService.ClearAgentErrors(_errorModalAgentId);
            _errorEntries = [];
            _showErrorModal = false;
            _errorModalAgentId = null;
        }
    }

    // Chat methods
    private void OpenChat(string agentId)
    {
        var agent = _agents.FirstOrDefault(a => a.Id == agentId);
        if (agent is null) return;

        _chatAgentId = agentId;
        _chatAgentName = agent.DisplayName;
        _chatAgent = agent;
        _chatMessages = DataService.GetAgentChatHistory(agentId).ToList();
        _chatInput = "";
        _chatSending = false;
        _showChatModal = true;
    }

    private void CloseChat()
    {
        _showChatModal = false;
        _chatAgentId = null;
    }

    private void SetChatInput(string text)
    {
        _chatInput = text;
    }

    private async Task OnChatKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_chatSending && !string.IsNullOrWhiteSpace(_chatInput))
        {
            await SendChat();
        }
    }

    private async Task SendChat()
    {
        if (_chatAgentId is null || string.IsNullOrWhiteSpace(_chatInput) || _chatSending) return;

        var message = _chatInput.Trim();
        _chatInput = "";
        _chatSending = true;
        StateHasChanged();

        try
        {
            await DataService.SendAgentChatAsync(_chatAgentId, message);
            _chatMessages = DataService.GetAgentChatHistory(_chatAgentId).ToList();
        }
        catch (Exception ex)
        {
            _chatMessages.Add(new AgentChatMessage
            {
                Role = "assistant",
                Content = $"Error: {ex.Message}",
                Timestamp = DateTime.UtcNow
            });
        }
        finally
        {
            _chatSending = false;
            StateHasChanged();
        }
    }

    // Gate notification helpers
    private IReadOnlyList<GateNotification> _openGates = Array.Empty<GateNotification>();
    private DateTime _lastGateRefresh = DateTime.MinValue;

    private IReadOnlyList<GateNotification> GetOpenGates()
    {
        // Cache for 2 seconds to avoid repeated lookups per render
        if ((DateTime.UtcNow - _lastGateRefresh).TotalSeconds > 2)
        {
            var svc = ServiceProvider.GetService<GateNotificationService>();
            var httpSvc = ServiceProvider.GetService<HttpGateNotificationService>();
            _openGates = svc?.GetByStatus(NotificationFilter.Open)
                      ?? httpSvc?.GetByStatus(NotificationFilter.Open)
                      ?? Array.Empty<GateNotification>();
            _lastGateRefresh = DateTime.UtcNow;
        }
        return _openGates;
    }

    private GateNotification? GetActiveGateForAgent(AgentSnapshot agent)
    {
        var gates = GetOpenGates();
        // Match by PR number if available
        var prNum = ExtractPrNumber(agent.StatusReason) ?? agent.AssignedPullRequest;
        if (prNum is not null && int.TryParse(prNum, out var num))
        {
            var match = gates.FirstOrDefault(g => g.ResourceNumber == num && !g.IsResolved);
            if (match is not null) return match;
        }
        // Fallback: match by gate name extracted from status
        var gateName = ExtractGateName(agent.StatusReason);
        if (gateName is not null)
            return gates.FirstOrDefault(g => g.GateName.Contains(gateName, StringComparison.OrdinalIgnoreCase) && !g.IsResolved);
        return null;
    }

    private static string? ExtractPrNumber(string? statusReason)
    {
        if (statusReason is null) return null;
        var match = System.Text.RegularExpressions.Regex.Match(statusReason, @"PR #(\d+)");
        return match.Success ? match.Groups[1].Value : null;
    }

    private static string ExtractGateName(string? statusReason)
    {
        if (statusReason is null) return "Unknown gate";
        // Pattern: "⏳ Awaiting human approval — gate-name" or "on PR #123"
        var dashIdx = statusReason.IndexOf('—');
        if (dashIdx >= 0 && dashIdx + 2 < statusReason.Length)
            return statusReason[(dashIdx + 2)..].Trim();
        var onIdx = statusReason.IndexOf("on PR", StringComparison.OrdinalIgnoreCase);
        if (onIdx >= 0)
            return statusReason[onIdx..].Trim();
        return "Approval required";
    }

    private (int completed, int total, string? currentName, string? tooltip) GetAgentStepInfo(string agentId)
    {
        if (_taskTracker is null)
            return (0, 0, null, null);
        var progress = _taskTracker.GetProgress(agentId);
        var currentStep = _taskTracker.GetCurrentStep(agentId);
        string? tooltip = null;
        if (currentStep is not null)
        {
            var parts = new List<string> { $"Current: {currentStep.Name}" };
            if (currentStep.Elapsed.HasValue)
                parts.Add($"Duration: {FormatDuration(currentStep.Elapsed.Value)}");
            if (!string.IsNullOrEmpty(currentStep.ModelUsed))
                parts.Add($"Model: {currentStep.ModelUsed}");
            if (currentStep.LlmCallCount > 0)
                parts.Add($"LLM calls: {currentStep.LlmCallCount}");
            if (!string.IsNullOrEmpty(currentStep.Description))
                parts.Add($"Details: {(currentStep.Description.Length > 120 ? currentStep.Description[..120] + "…" : currentStep.Description)}");
            parts.Add($"Progress: {progress.completed}/{progress.total} steps");
            tooltip = string.Join("\n", parts);
        }
        return (progress.completed, progress.total, currentStep?.Name, tooltip);
    }

