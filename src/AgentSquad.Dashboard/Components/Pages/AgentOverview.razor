    // ── Project Control Methods ──────────────────────────────────────

    private async Task LoadRunStateAsync()
    {
        if (_runsHttp is null)
        {
            // Fallback: try direct service injection (works in Runner-embedded mode)
            var coordinator = ServiceProvider.GetService<AgentSquad.Orchestrator.RunCoordinator>();
            if (coordinator is not null)
            {
                var run = coordinator.ActiveRun;
                var profile = coordinator.ActiveProfile;
                _runState = run?.Status.ToString() ?? "Idle";
                _runMode = run?.Mode.ToString() ?? "";
                _runDisplayName = profile?.DisplayName ?? "";
                await InvokeAsync(StateHasChanged);
            }
            return;
        }

        try
        {
            var resp = await _runsHttp.GetAsync("/api/runs/active");
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadFromJsonAsync<RunActiveResponse>();
                if (json?.run is not null)
                {
                    _runState = json.run.status ?? "Idle";
                    _runMode = json.run.mode ?? "";
                    _runDisplayName = json.profile?.displayName ?? "";
                }
                else
                {
                    _runState = "Idle";
                    _runMode = "";
                    _runDisplayName = "";
                }
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { /* API not available yet */ }
    }

    private async Task StartProjectAsync()
    {
        _runActionPending = true;
        _runError = "";
        StateHasChanged();

        try
        {
            if (_runsHttp is not null)
            {
                var resp = await _runsHttp.PostAsync("/api/runs/start-project", null);
                if (resp.IsSuccessStatusCode)
                {
                    _runState = "Running";
                    _runMode = "Project";
                    _runDisplayName = "Greenfield Project";
                }
                else
                {
                    var body = await resp.Content.ReadAsStringAsync();
                    _runError = $"Failed to start: {body}";
                }
            }
            else
            {
                var coordinator = ServiceProvider.GetService<AgentSquad.Orchestrator.RunCoordinator>();
                if (coordinator is not null)
                {
                    await coordinator.StartProjectAsync();
                    _ = Task.Run(async () =>
                    {
                        try { await coordinator.SpawnAgentsForRunAsync(); }
                        catch { /* logged internally */ }
                    });
                    _runState = "Running";
                    _runMode = "Project";
                    _runDisplayName = "Greenfield Project";
                }
            }
        }
        catch (Exception ex)
        {
            _runError = ex.Message;
        }
        finally
        {
            _runActionPending = false;
            StateHasChanged();
        }
    }

    private async Task PauseRunAsync()
    {
        _runActionPending = true;
        _runError = "";
        StateHasChanged();

        try
        {
            if (_runsHttp is not null)
            {
                var resp = await _runsHttp.PostAsync("/api/runs/stop", null);
                if (resp.IsSuccessStatusCode)
                {
                    _runState = "Paused";
                }
                else
                {
                    _runError = "Failed to pause run";
                }
            }
            else
            {
                var coordinator = ServiceProvider.GetService<AgentSquad.Orchestrator.RunCoordinator>();
                if (coordinator is not null)
                {
                    await coordinator.StopAsync();
                    _runState = "Paused";
                }
            }
        }
        catch (Exception ex)
        {
            _runError = ex.Message;
        }
        finally
        {
            _runActionPending = false;
            StateHasChanged();
        }
    }

    private async Task ResumeRunAsync()
    {
        _runActionPending = true;
        _runError = "";
        StateHasChanged();

        try
        {
            if (_runsHttp is not null)
            {
                var resp = await _runsHttp.PostAsync("/api/runs/resume", null);
                if (resp.IsSuccessStatusCode)
                {
                    _runState = "Running";
                }
                else
                {
                    _runError = "Failed to resume run";
                }
            }
            else
            {
                var coordinator = ServiceProvider.GetService<AgentSquad.Orchestrator.RunCoordinator>();
                if (coordinator is not null)
                {
                    await coordinator.ResumeAsync();
                    await coordinator.SpawnAgentsForRunAsync();
                    _runState = "Running";
                }
            }
        }
        catch (Exception ex)
        {
            _runError = ex.Message;
        }
        finally
        {
            _runActionPending = false;
            StateHasChanged();
        }
    }

    // DTOs for JSON deserialization
    private record RunActiveResponse(RunInfo? run, ProfileInfo? profile);
    private record RunInfo(string? status, string? mode, string? runId);
    private record ProfileInfo(string? displayName, string? mode);
}
