@page "/reasoning"
@rendermode InteractiveServer
@using AgentSquad.Core.Agents.Reasoning
@using AgentSquad.Core.Agents.Decisions
@using AgentSquad.Core.Agents.Steps
@using System.Net.Http.Json
@using AgentSquad.Dashboard.Services
@implements IDisposable
@inject DashboardMode Mode

<PageTitle>Virtual Dev Team — Agent Reasoning</PageTitle>

<div class="dashboard-header" data-testid="page-reasoning">
    <h1>🧠 Agent Reasoning</h1>
    <div class="header-badges">
        <span class="header-badge @(_events.Count > 0 ? "badge-active" : "badge-idle")">
            @(_events.Count) events
        </span>
        @if (_pendingDecisionCount > 0)
        {
            <span class="header-badge warning">@_pendingDecisionCount pending decisions</span>
        }
    </div>
</div>

@* ── Event Type Filter Bar ── *@
<div class="reasoning-type-filters">
    <button class="type-filter-btn @(_typeFilter == null ? "active" : "")"
            @onclick="() => SetTypeFilter(null)">All</button>
    <button class="type-filter-btn @(_typeFilter == "Steps" ? "active" : "")"
            @onclick='() => SetTypeFilter("Steps")'>📊 Steps</button>
    <button class="type-filter-btn @(_typeFilter == "Decisions" ? "active" : "")"
            @onclick='() => SetTypeFilter("Decisions")'>
        ⚖️ Decisions @if (_decisions.Count > 0) { <span class="filter-count">@_decisions.Count</span> }
    </button>
    <button class="type-filter-btn @(_typeFilter == "Planning" ? "active" : "")"
            @onclick='() => SetTypeFilter("Planning")'>🎯 Planning</button>
    <button class="type-filter-btn @(_typeFilter == "Generating" ? "active" : "")"
            @onclick='() => SetTypeFilter("Generating")'>✍️ Generating</button>
    <button class="type-filter-btn @(_typeFilter == "Assessing" ? "active" : "")"
            @onclick='() => SetTypeFilter("Assessing")'>🔍 Assessing</button>
    <button class="type-filter-btn @(_typeFilter == "Other" ? "active" : "")"
            @onclick='() => SetTypeFilter("Other")'>📋 Other</button>
</div>

@if (_loading)
{
    <div class="reasoning-loading">
        <div class="reasoning-loading-spinner"></div>
        <p>Connecting to agent reasoning stream…</p>
    </div>
}
else
{
<div class="reasoning-layout">
    @* ── Left: Agent Selector ── *@
    <div class="reasoning-agents">
        <div class="reasoning-card">
            <h3>Agents</h3>
            <button class="reason-agent-btn @(_selectedAgent == null ? "active" : "")"
                    @onclick="() => SelectAgent(null)">
                📋 All Agents
            </button>
            @foreach (var agentId in _agentIds)
            {
                var displayName = GetDisplayName(agentId);
                var eventCount = _events.Count(e => e.AgentId == agentId);
                var decisionCount = _decisions.Count(d => d.AgentId == agentId);
                var latestType = _events.Where(e => e.AgentId == agentId).MaxBy(e => e.Timestamp)?.EventType;
                <button class="reason-agent-btn @(_selectedAgent == agentId ? "active" : "")"
                        @onclick="() => SelectAgent(agentId)">
                    <span class="agent-icon">@GetEventIcon(latestType)</span>
                    <span class="agent-name">@displayName</span>
                    <span class="agent-badge">@eventCount</span>
                    @if (decisionCount > 0)
                    {
                        <span class="agent-badge decision-badge">⚖️ @decisionCount</span>
                    }
                </button>
            }
        </div>
    </div>

    @* ── Right: Event Timeline ── *@
    <div class="reasoning-timeline">
        @if (_typeFilter == "Steps")
        {
            @* ── Step timeline view — grouped by task ── *@
            @if (!_groupedStepsByAgent.Any())
            {
                <div class="reasoning-empty">
                    <div class="empty-icon">📊</div>
                    <h3>No Task Steps Yet</h3>
                    <p>Step tracking data will appear here when agents begin executing tasks.</p>
                </div>
            }
            else
            {
                <div class="step-timeline">
                    @foreach (var kvp in _filteredGroupedSteps)
                    {
                        var agentId = kvp.Key;
                        var taskGroups = kvp.Value;
                        var progress = _stepProgress.GetValueOrDefault(agentId);
                        var isExpanded = _expandedStepAgents.Contains(agentId);
                        var pct = progress.total > 0 ? (int)(100.0 * progress.completed / progress.total) : 0;

                        <div class="step-agent-section">
                            <div class="step-agent-header" @onclick="() => ToggleStepAgent(agentId)">
                                <span class="step-agent-chevron @(isExpanded ? "expanded" : "")">▶</span>
                                <span class="step-agent-name">@GetDisplayName(agentId)</span>
                                <span class="step-agent-progress-text">@progress.completed/@progress.total steps</span>
                            </div>
                            @if (isExpanded)
                            {
                                <div class="step-agent-body">
                                    <div class="step-progress-bar">
                                        <div class="step-progress-fill" style="width: @(pct)%"></div>
                                    </div>
                                    @foreach (var group in taskGroups)
                                    {
                                        var groupKey = $"{agentId}:{group.TaskId}";
                                        var isGroupExpanded = _expandedTaskGroups.Contains(groupKey)
                                            || group.Status == AgentTaskStepStatus.InProgress
                                            || group.Status == AgentTaskStepStatus.WaitingOnHuman;
                                        var groupPct = group.Total > 0 ? (int)(100.0 * group.Completed / group.Total) : 0;

                                        <div class="step-task-group @(group.Status == AgentTaskStepStatus.InProgress ? "step-task-active" : "")"
                                             title="@BuildTaskGroupTooltip(group)">
                                            <div class="step-task-header" @onclick="() => ToggleTaskGroup(groupKey)">
                                                <span class="step-task-chevron @(isGroupExpanded ? "expanded" : "")">▶</span>
                                                <span class="step-task-icon">@GetTaskGroupIcon(group.Status)</span>
                                                <span class="step-task-name">@group.DisplayName</span>
                                                <div class="step-task-meta">
                                                    <span class="step-task-progress">@group.Completed/@group.Total</span>
                                                    @if (group.TotalElapsed.HasValue)
                                                    {
                                                        <span class="step-elapsed">@FormatStepDuration(group.TotalElapsed.Value)</span>
                                                    }
                                                    @if (group.TotalLlmCalls > 0)
                                                    {
                                                        <span class="step-llm-count">@group.TotalLlmCalls calls</span>
                                                    }
                                                </div>
                                            </div>
                                            @if (isGroupExpanded)
                                            {
                                                <div class="step-task-body">
                                                    <div class="step-task-progress-bar">
                                                        <div class="step-progress-fill" style="width: @(groupPct)%"></div>
                                                    </div>
                                                    <div class="step-list">
                                                        @foreach (var step in group.Steps)
                                                        {
                                                            <div class="step-item @(step.Status == AgentTaskStepStatus.InProgress ? "step-active" : "")"
                                                                 title="@BuildStepTooltip(step)">
                                                                <span class="step-icon">@GetStepStatusIcon(step.Status)</span>
                                                                <span class="step-name @(step.Status == AgentTaskStepStatus.Pending ? "step-name-pending" : "")">@step.Name</span>
                                                                <div class="step-meta">
                                                                    @if (step.Elapsed.HasValue)
                                                                    {
                                                                        <span class="step-elapsed">@FormatStepDuration(step.Elapsed.Value)</span>
                                                                    }
                                                                    @if (step.LlmCallCount > 0)
                                                                    {
                                                                        <span class="step-llm-count">@step.LlmCallCount calls</span>
                                                                    }
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }
        else if (_typeFilter == "Decisions")
        {
            @* ── Decision-specific view ── *@
            @if (!_filteredDecisions.Any())
            {
                <div class="reasoning-empty">
                    <div class="empty-icon">⚖️</div>
                    <h3>No Decisions Yet</h3>
                    <p>Agent decisions with impact classification will appear here when decision gating is enabled.</p>
                </div>
            }
            else
            {
                @foreach (var decision in _filteredDecisions)
                {
                    <div class="reasoning-event event-decision @GetDecisionStatusClass(decision.Status)">
                        <div class="event-header">
                            <span class="event-icon">⚖️</span>
                            <span class="impact-badge impact-@decision.ImpactLevel.ToString().ToLower()">@decision.ImpactLevel</span>
                            <span class="event-agent">@decision.AgentDisplayName</span>
                            <span class="event-phase">@decision.Phase</span>
                            @if (!string.IsNullOrEmpty(decision.Category))
                            {
                                <span class="decision-category">@decision.Category</span>
                            }
                            <span class="decision-status-pill status-@decision.Status.ToString().ToLower()">
                                @GetDecisionStatusIcon(decision.Status) @decision.Status
                            </span>
                            <span class="event-time">@decision.CreatedAt.ToLocalTime().ToString("HH:mm:ss")</span>
                        </div>
                        <div class="event-summary"><strong>@decision.Title</strong></div>
                        <div class="decision-rationale">@decision.Rationale</div>
                        @if (!string.IsNullOrEmpty(decision.Alternatives))
                        {
                            <div class="decision-field">
                                <strong>Alternatives:</strong> @decision.Alternatives
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(decision.AffectedFiles))
                        {
                            <div class="decision-field">
                                <strong>Affected Files:</strong> @decision.AffectedFiles
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(decision.RiskAssessment))
                        {
                            <div class="decision-field">
                                <strong>Risk:</strong> @decision.RiskAssessment
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(decision.Plan))
                        {
                            <details class="event-detail">
                                <summary>View implementation plan</summary>
                                <pre>@decision.Plan</pre>
                            </details>
                        }
                        @if (!string.IsNullOrEmpty(decision.HumanFeedback))
                        {
                            <div class="decision-feedback">
                                <strong>Human Feedback:</strong> @decision.HumanFeedback
                            </div>
                        }
                    </div>
                }
            }
        }
        else if (!_filteredEvents.Any())
        {
            <div class="reasoning-empty">
                <div class="empty-icon">🧠</div>
                <h3>No Reasoning Events Yet</h3>
                <p>Events will appear here when agents begin self-assessment loops.
                   Enable the agentic loop in Configuration → AgenticLoop.Enabled = true.</p>
            </div>
        }
        else
        {
            @foreach (var evt in _filteredEvents)
            {
                <div class="reasoning-event @GetEventClass(evt.EventType) @(evt.Passed == true ? "event-pass" : evt.Passed == false ? "event-fail" : "")">
                    <div class="event-header">
                        <span class="event-icon">@GetEventIcon(evt.EventType)</span>
                        <span class="event-type">@evt.EventType</span>
                        <span class="event-agent">@evt.AgentDisplayName</span>
                        <span class="event-phase">@evt.Phase</span>
                        @if (evt.Iteration > 0)
                        {
                            <span class="event-iteration">Iter @evt.Iteration</span>
                        }
                        @if (evt.Duration.HasValue)
                        {
                            <span class="event-duration">@($"{evt.Duration.Value.TotalSeconds:F1}s")</span>
                        }
                        <span class="event-time">@evt.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                    </div>
                    <div class="event-summary">@evt.Summary</div>
                    @if (evt.Gaps is { Count: > 0 })
                    {
                        <div class="event-gaps">
                            <strong>Gaps identified:</strong>
                            <ul>
                                @foreach (var gap in evt.Gaps)
                                {
                                    <li>@gap</li>
                                }
                            </ul>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(evt.Detail))
                    {
                        <details class="event-detail">
                            <summary>View full detail</summary>
                            <pre>@evt.Detail</pre>
                        </details>
                    }
                </div>
            }
        }
    </div>
</div>
}

@code {
    [Inject] private IServiceProvider Services { get; set; } = default!;

    private IAgentReasoningLog? _directLog;
    private IDecisionLog? _decisionLog;
    private IAgentTaskTracker? _taskTracker;
    private HttpClient? _http;
    private Timer? _pollTimer;
    private List<AgentReasoningEvent> _events = [];
    private List<AgentDecision> _decisions = [];
    private List<string> _agentIds = [];
    private string? _selectedAgent;
    private string? _typeFilter = "Steps";
    private int _pendingDecisionCount;
    private bool _disposed;
    private bool _loading = true;

    // Step tracking state
    private Dictionary<string, IReadOnlyList<AgentTaskGroup>> _groupedStepsByAgent = new();
    private Dictionary<string, (int completed, int total)> _stepProgress = new();
    private HashSet<string> _expandedStepAgents = new();
    private HashSet<string> _expandedTaskGroups = new();

    private Dictionary<string, IReadOnlyList<AgentTaskGroup>> _filteredGroupedSteps =>
        _selectedAgent is null
            ? _groupedStepsByAgent
            : _groupedStepsByAgent
                .Where(kvp => kvp.Key == _selectedAgent)
                .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);

    private IEnumerable<AgentReasoningEvent> _filteredEvents
    {
        get
        {
            var agentFiltered = _selectedAgent is null
                ? _events
                : _events.Where(e => e.AgentId == _selectedAgent);

            if (_typeFilter is not null and not "Decisions")
            {
                agentFiltered = _typeFilter switch
                {
                    "Planning" => agentFiltered.Where(e => e.EventType == AgentReasoningEventType.Planning),
                    "Generating" => agentFiltered.Where(e => e.EventType == AgentReasoningEventType.Generating),
                    "Assessing" => agentFiltered.Where(e => e.EventType == AgentReasoningEventType.Assessing),
                    "Other" => agentFiltered.Where(e => e.EventType is AgentReasoningEventType.Refining
                        or AgentReasoningEventType.Publishing or AgentReasoningEventType.Error
                        or AgentReasoningEventType.HumanIntervention),
                    _ => agentFiltered,
                };
            }

            return agentFiltered.OrderByDescending(e => e.Timestamp);
        }
    }

    private IEnumerable<AgentDecision> _filteredDecisions =>
        (_selectedAgent is null
            ? _decisions
            : _decisions.Where(d => d.AgentId == _selectedAgent))
        .OrderByDescending(d => d.CreatedAt);

    protected override void OnInitialized()
    {
        if (!Mode.IsStandalone)
        {
            _directLog = Services.GetService<IAgentReasoningLog>();
            _decisionLog = Services.GetService<IDecisionLog>();
            _taskTracker = Services.GetService<IAgentTaskTracker>();
        }
        else
        {
            var factory = Services.GetService<IHttpClientFactory>();
            _http = factory?.CreateClient("RunnerApi");
        }

        _pollTimer = new Timer(async _ => await PollAsync(), null,
            TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(3));
    }

    private async Task PollAsync()
    {
        if (_disposed) return;
        try
        {
            if (_directLog is not null)
            {
                _agentIds = _directLog.GetAgentIds().ToList();
                _events = _directLog.GetRecentEvents(200).ToList();
            }
            else if (_http is not null)
            {
                var agents = await _http.GetFromJsonAsync<List<string>>("/api/reasoning/agents");
                var events = await _http.GetFromJsonAsync<List<AgentReasoningEvent>>("/api/reasoning/recent?count=200");
                if (agents is not null) _agentIds = agents;
                if (events is not null) _events = events;
            }

            // Also poll decisions
            if (_decisionLog is not null)
            {
                _decisions = _decisionLog.GetAllDecisions().ToList();
                _pendingDecisionCount = _decisionLog.GetPendingDecisions().Count;

                // Merge decision agent IDs into _agentIds
                foreach (var agentId in _decisionLog.GetAgentIds())
                {
                    if (!_agentIds.Contains(agentId))
                        _agentIds.Add(agentId);
                }
            }

            // Poll task steps
            if (_typeFilter == "Steps")
            {
                await PollStepsAsync();
            }

            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
        catch { /* Runner not reachable — silently retry */ }
    }

    private async Task PollStepsAsync()
    {
        if (_taskTracker is not null)
        {
            var newGrouped = new Dictionary<string, IReadOnlyList<AgentTaskGroup>>();
            var newProgress = new Dictionary<string, (int completed, int total)>();
            foreach (var agentId in _agentIds)
            {
                var groups = _taskTracker.GetGroupedSteps(agentId);
                if (groups.Count > 0)
                {
                    newGrouped[agentId] = groups;
                    newProgress[agentId] = _taskTracker.GetProgress(agentId);
                }
            }
            // Also check active steps for agents not yet in _agentIds
            foreach (var step in _taskTracker.GetActiveSteps())
            {
                if (!newGrouped.ContainsKey(step.AgentId))
                {
                    newGrouped[step.AgentId] = _taskTracker.GetGroupedSteps(step.AgentId);
                    newProgress[step.AgentId] = _taskTracker.GetProgress(step.AgentId);
                    if (!_agentIds.Contains(step.AgentId))
                        _agentIds.Add(step.AgentId);
                }
            }
            _groupedStepsByAgent = newGrouped;
            _stepProgress = newProgress;
        }
        else if (_http is not null)
        {
            var newGrouped = new Dictionary<string, IReadOnlyList<AgentTaskGroup>>();
            var newProgress = new Dictionary<string, (int completed, int total)>();
            foreach (var agentId in _agentIds)
            {
                try
                {
                    var groups = await _http.GetFromJsonAsync<List<AgentTaskGroup>>($"/api/steps/{agentId}/grouped");
                    if (groups is { Count: > 0 })
                    {
                        newGrouped[agentId] = groups;
                        var progress = await _http.GetFromJsonAsync<ProgressDto>($"/api/steps/{agentId}/progress");
                        if (progress is not null)
                            newProgress[agentId] = (progress.Completed, progress.Total);
                    }
                }
                catch { /* skip this agent */ }
            }
            _groupedStepsByAgent = newGrouped;
            _stepProgress = newProgress;
        }
    }

    private record ProgressDto(int Completed, int Total);

    private void SelectAgent(string? agentId) => _selectedAgent = agentId;

    private void SetTypeFilter(string? filter) => _typeFilter = filter;

    private static string GetDisplayName(string agentId)
    {
        return agentId.Replace("-", " ").ToUpperInvariant() switch
        {
            var s when s.Contains("RESEARCH") => "🔬 Researcher",
            var s when s.Contains("PROGRAM") && s.Contains("MANAGER") => "📋 Program Manager",
            var s when s.Contains("ARCHITECT") => "🏗️ Architect",
            var s when s.Contains("SOFTWARE") => "👨‍💻 Software Engineer",
            var s when s.Contains("TEST") => "🧪 Test Engineer",
            _ => agentId
        };
    }

    private static string GetEventIcon(AgentReasoningEventType? eventType) => eventType switch
    {
        AgentReasoningEventType.Planning => "🎯",
        AgentReasoningEventType.Generating => "✍️",
        AgentReasoningEventType.Assessing => "🔍",
        AgentReasoningEventType.Refining => "🔄",
        AgentReasoningEventType.Decision => "✅",
        AgentReasoningEventType.Publishing => "📤",
        AgentReasoningEventType.Error => "❌",
        AgentReasoningEventType.HumanIntervention => "🙋",
        _ => "🧠"
    };

    private static string GetEventClass(AgentReasoningEventType eventType) => eventType switch
    {
        AgentReasoningEventType.Planning => "event-planning",
        AgentReasoningEventType.Generating => "event-generating",
        AgentReasoningEventType.Assessing => "event-assessing",
        AgentReasoningEventType.Refining => "event-refining",
        AgentReasoningEventType.Decision => "event-decision",
        AgentReasoningEventType.Publishing => "event-publishing",
        AgentReasoningEventType.Error => "event-error",
        AgentReasoningEventType.HumanIntervention => "event-human",
        _ => ""
    };

    private static string GetDecisionStatusClass(DecisionStatus status) => status switch
    {
        DecisionStatus.Pending => "decision-pending",
        DecisionStatus.Approved => "decision-approved",
        DecisionStatus.Rejected => "decision-rejected",
        DecisionStatus.AutoApproved => "decision-auto",
        _ => ""
    };

    private static string GetDecisionStatusIcon(DecisionStatus status) => status switch
    {
        DecisionStatus.Pending => "⏳",
        DecisionStatus.Approved => "✅",
        DecisionStatus.Rejected => "❌",
        DecisionStatus.AutoApproved => "🤖",
        _ => ""
    };

    private void ToggleStepAgent(string agentId)
    {
        if (!_expandedStepAgents.Remove(agentId))
            _expandedStepAgents.Add(agentId);
    }

    private void ToggleTaskGroup(string groupKey)
    {
        if (!_expandedTaskGroups.Remove(groupKey))
            _expandedTaskGroups.Add(groupKey);
    }

    private static string GetTaskGroupIcon(AgentTaskStepStatus status) => status switch
    {
        AgentTaskStepStatus.Completed => "✅",
        AgentTaskStepStatus.InProgress => "🔨",
        AgentTaskStepStatus.WaitingOnHuman => "⏳",
        AgentTaskStepStatus.Failed => "❌",
        _ => "⬜"
    };

    private static string GetStepStatusIcon(AgentTaskStepStatus status) => status switch
    {
        AgentTaskStepStatus.Completed => "✅",
        AgentTaskStepStatus.InProgress => "🔄",
        AgentTaskStepStatus.Pending => "⬜",
        AgentTaskStepStatus.Failed => "❌",
        AgentTaskStepStatus.Skipped => "⏭️",
        AgentTaskStepStatus.WaitingOnHuman => "⏳",
        _ => "⬜"
    };

    private static string FormatStepDuration(TimeSpan ts) => ts.TotalMinutes >= 1
        ? $"{ts.Minutes}m {ts.Seconds}s"
        : $"{ts.TotalSeconds:F1}s";

    private static string FormatStepCost(decimal cost) => cost switch
    {
        < 0.01m => "< $0.01",
        < 1m => cost.ToString("$0.00"),
        _ => cost.ToString("$#,##0.00")
    };

    private static string BuildStepTooltip(AgentSquad.Core.Agents.Steps.AgentTaskStep step)
    {
        var parts = new List<string> { step.Name };
        if (step.Status != AgentSquad.Core.Agents.Steps.AgentTaskStepStatus.Pending)
            parts.Add($"Status: {step.Status}");
        if (step.Elapsed.HasValue)
            parts.Add($"Duration: {FormatStepDuration(step.Elapsed.Value)}");
        if (!string.IsNullOrEmpty(step.ModelUsed))
            parts.Add($"Model: {step.ModelUsed}");
        if (step.LlmCallCount > 0)
            parts.Add($"LLM calls: {step.LlmCallCount}");
        if (step.EstimatedCost > 0)
            parts.Add($"Cost: {FormatStepCost(step.EstimatedCost)}");
        if (!string.IsNullOrEmpty(step.Description))
            parts.Add(step.Description.Length > 150 ? step.Description[..150] + "…" : step.Description);
        return string.Join("\n", parts);
    }

    private static string BuildTaskGroupTooltip(AgentSquad.Core.Agents.Steps.AgentTaskGroup group)
    {
        var parts = new List<string> { group.DisplayName, $"Progress: {group.Completed}/{group.Total} steps" };
        if (group.TotalElapsed.HasValue)
            parts.Add($"Total time: {FormatStepDuration(group.TotalElapsed.Value)}");
        if (group.TotalLlmCalls > 0)
            parts.Add($"Total LLM calls: {group.TotalLlmCalls}");
        if (group.TotalCost > 0)
            parts.Add($"Total cost: {FormatStepCost(group.TotalCost)}");
        return string.Join("\n", parts);
    }

    public void Dispose()
    {
        _disposed = true;
        _pollTimer?.Dispose();
    }
}
