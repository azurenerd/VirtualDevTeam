@page "/strategies"
@rendermode InteractiveServer
@using AgentSquad.Core.Strategies
@using AgentSquad.Core.Strategies.Contracts
@using AgentSquad.Dashboard.Services
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.Extensions.Logging
@implements IAsyncDisposable
@inject IStrategiesDataService StrategiesData
@inject NavigationManager Navigation
@inject ILogger<Strategies> Logger

<PageTitle>Virtual Dev Team — Frameworks</PageTitle>

<div class="dashboard-header" data-testid="page-strategies">
    <h1 title="Frameworks are pluggable AI coding agents (e.g., Baseline, GitHub Copilot CLI, Squad) that compete on each task. The best output wins.">Frameworks</h1>
    <div class="header-badges">
        <span class="header-badge @(_enabled?.MasterEnabled == true ? "" : "muted")" data-testid="strategies-enabled-badge"
              title="@(_enabled?.MasterEnabled == true ? "Multi-framework mode is ON — tasks are sent to multiple AI agents simultaneously" : "Multi-framework mode is OFF — only baseline code generation is active")">
            @(_enabled?.MasterEnabled == true ? "● Framework ON" : "○ Framework OFF")
        </span>
        <span class="header-badge" data-testid="strategies-active-count"
              title="Number of tasks and candidates currently being processed">
            Active: @_activeTasks.Count task@(_activeTasks.Count != 1 ? "s" : "") · @_activeTasks.Sum(t => t.Candidates.Count) candidates
        </span>
        <span class="header-badge" data-testid="strategies-recent-count"
              title="Number of recently completed tasks (persisted across restarts)">
            Recent: @_recentTasks.Count
        </span>
        <button class="ntl-refresh-btn @(_refreshing ? "spinning" : "")" @onclick="RefreshAsync" disabled="@_refreshing" title="Refresh active and recent task data" data-testid="strategies-refresh">
            <svg class="ntl-refresh-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M13.5 8a5.5 5.5 0 1 1-1.6-3.9M13.5 2.5v2h-2"/>
            </svg>
        </button>
    </div>
</div>

@if (_enabled?.MasterEnabled != true)
{
    <div class="alert-banner info" data-testid="strategies-disabled-banner">
        <strong>Frameworks are disabled.</strong> Baseline code generation is the
        only active path. Set <code>AgentSquad:StrategyFramework:Enabled = true</code>
        to enable multi-framework candidate runs.
    </div>
}

<section class="strategies-section">
    <h2 title="Tasks currently being processed — each task runs multiple framework candidates in parallel">Active Tasks</h2>
    @if (_activeTasks.Count == 0)
    {
        <div class="empty-state">No active framework candidates. Waiting for the next task&hellip;</div>
    }
    else
    {
        @foreach (var task in _activeTasks)
        {
            <div class="task-card" data-testid="strategies-task-card" data-task-id="@task.TaskId">
                <div class="task-header">
                    <div>
                        <span class="task-id" title="Unique identifier for this engineering task">@task.TaskId</span>
                        <span class="task-run" title="Run identifier — groups all candidates executing for this task">run @task.RunId</span>
                    </div>
                    <div class="task-elapsed" title="Time elapsed since task started">@FormatTaskElapsed(task)</div>
                </div>
                <div class="candidate-grid">
                    @foreach (var candidate in task.Candidates.Values.OrderBy(c => c.StrategyId.Equals("baseline", StringComparison.OrdinalIgnoreCase) ? 1 : 0).ThenBy(c => c.StrategyId))
                    {
                        var activeKey = $"{task.TaskId}_{candidate.StrategyId}";
                        var isActiveExpanded = _expandedActiveCandidates.Contains(activeKey);
                        <div class="candidate-card state-@(candidate.State.ToString().ToLowerInvariant()) @(isActiveExpanded ? "active-expanded" : "")"
                             data-testid="strategies-candidate-card" data-strategy-id="@candidate.StrategyId"
                             @onclick="() => ToggleActiveExpand(activeKey)">
                            <div class="candidate-head">
                                <span class="candidate-id" title="@StrategyTooltip(candidate.StrategyId)">
                                    @StrategyDisplayName(candidate.StrategyId)
                                </span>
                                <span class="candidate-state" title="@StateTooltip(candidate.State)">@candidate.State</span>
                            </div>
                            @if (candidate.ElapsedSec is double e)
                            {
                                <div class="candidate-timing" title="Execution duration and token usage for this candidate">
                                    ⏱ @FormatDuration(e)
                                    @if (candidate.TokensUsed.HasValue)
                                    {
                                        <span>· @(candidate.TokensUsed.Value.ToString("N0")) tok</span>
                                    }
                                    else if (candidate.State >= CandidateState.Completed)
                                    {
                                        <span class="muted" title="Token count not exposed by this framework — tool-call count shown in Activity tab">· tokens n/a</span>
                                    }
                                </div>
                            }
                            @if (candidate.State == CandidateState.Completed && candidate.Succeeded == true)
                            {
                                <div class="candidate-awaiting" title="This candidate finished generating code — waiting for all candidates to complete before evaluation begins">
                                    ⏳ Awaiting evaluation…
                                </div>
                            }
                            @if (candidate.ActivityLog.Count > 0)
                            {
                                <div class="candidate-activity-live" title="Latest activity from this framework's execution — click to expand full log">
                                    @if (candidate.State == CandidateState.Running)
                                    {
                                        <span class="activity-pulse">●</span>
                                    }
                                    else
                                    {
                                        <span class="activity-done">✓</span>
                                    }
                                    <span class="activity-last">@candidate.ActivityLog[^1].Message</span>
                                    <span class="activity-count" title="Total activity log entries captured">(@candidate.ActivityLog.Count)</span>
                                </div>
                                @if (!isActiveExpanded && candidate.ActivityLog.Count > 1)
                                {
                                    @* Show last 3 grouped entries as mini-log preview *@
                                    <div class="candidate-minilog">
                                        @foreach (var group in GroupConsecutive(candidate.ActivityLog).TakeLast(3))
                                        {
                                            <div class="minilog-entry">
                                                <span class="minilog-time">@group.Entry.Timestamp.ToLocalTime().ToString("h:mm:ss")</span>
                                                <span class="minilog-cat cd-activity-cat-@group.Entry.Category">@group.Entry.Category</span>
                                                <span class="minilog-msg">@group.Entry.Message</span>
                                                @if (group.Count > 1)
                                                {
                                                    <span class="activity-group-badge">(×@group.Count)</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            }
                            @if (candidate.State == CandidateState.Scored || candidate.State == CandidateState.Winner)
                            {
                                <div class="candidate-scores" title="LLM judge scores — Acceptance Criteria, Design quality, Readability, and Visuals (each 0–10)">
                                    <div title="Acceptance Criteria: How well the code meets the task requirements (0–10)">AC <span>@(candidate.AcScore ?? 0)</span></div>
                                    <div title="Design: Code architecture, patterns, and structural quality (0–10)">Des <span>@(candidate.DesignScore ?? 0)</span></div>
                                    <div title="Readability: Code clarity, naming, and maintainability (0–10)">Read <span>@(candidate.ReadabilityScore ?? 0)</span></div>
                                    @if (candidate.VisualsScore.HasValue)
                                    {
                                        <div title="Visuals: Visual quality of the application screenshot (0–10)" class="visuals-score">Vis <span>@candidate.VisualsScore.Value</span></div>
                                    }
                                </div>
                            }
                            else if (candidate.State == CandidateState.Evaluated && candidate.Survived == true)
                            {
                                <div class="candidate-scores muted" title="This candidate passed gate checks but was not scored by the LLM judge">@(candidate.JudgeSkippedReason ?? "not scored")</div>
                            }
                            else if (candidate.State == CandidateState.Evaluated && candidate.Survived == false)
                            {
                                <div class="candidate-gate-fail" title="This candidate's generated code failed a build/evaluation gate">
                                    ❌ Gate failed
                                    @if (!string.IsNullOrEmpty(candidate.FailureReason))
                                    {
                                        <span class="gate-fail-detail">@TruncateText(candidate.FailureReason, 120)</span>
                                    }
                                </div>
                            }
                            @if (candidate.Succeeded == false)
                            {
                                <div class="candidate-fail" title="Reason this candidate failed during execution">@candidate.FailureReason</div>
                            }

                            @* Expandable detail panel — same tabbed UI as Recent Completed *@
                            @if (isActiveExpanded)
                            {
                                <div class="candidate-detail-expanded" @onclick:stopPropagation="true">
                                    @{
                                        var tabKey = $"active_{task.TaskId}_{candidate.StrategyId}";
                                        var activeTab = _activeTabs.GetValueOrDefault(tabKey, "activity");
                                    }
                                    <div class="cd-tabs">
                                        <button class="cd-tab @(activeTab == "overview" ? "active" : "")" @onclick="@(() => SetTab(tabKey, "overview"))" @onclick:stopPropagation="true" title="Scores, metrics, and screenshot preview">Overview</button>
                                        <button class="cd-tab @(activeTab == "activity" ? "active" : "")" @onclick="@(() => SetTab(tabKey, "activity"))" @onclick:stopPropagation="true" title="Real-time activity log showing what the framework did step by step">
                                            Activity @if (candidate.ActivityLog.Count > 0) { <span class="cd-tab-badge">@candidate.ActivityLog.Count</span> }
                                        </button>
                                        <button class="cd-tab @(activeTab == "files" ? "active" : "")" @onclick="@(() => SetTab(tabKey, "files"))" @onclick:stopPropagation="true" title="Files created, modified, or deleted by this framework">
                                            Files @if (candidate.ExecutionSummary?.FilesChanged.Count > 0) { <span class="cd-tab-badge">@candidate.ExecutionSummary.FilesChanged.Count</span> }
                                        </button>
                                        <button class="cd-tab @(activeTab == "metrics" ? "active" : "")" @onclick="@(() => SetTab(tabKey, "metrics"))" @onclick:stopPropagation="true" title="Performance metrics">Metrics</button>
                                        <button class="cd-tab @(activeTab == "logs" ? "active" : "")" @onclick="@(() => SetTab(tabKey, "logs"))" @onclick:stopPropagation="true" title="Raw diagnostic logs">
                                            Logs @if (candidate.ExecutionSummary?.DiagnosticLog.Count > 0) { <span class="cd-tab-badge">@candidate.ExecutionSummary.DiagnosticLog.Count</span> }
                                        </button>
                                    </div>
                                    <div class="cd-tab-content">
                                        @if (activeTab == "overview")
                                        {
                                            @if (candidate.AcScore.HasValue || candidate.DesignScore.HasValue || candidate.ReadabilityScore.HasValue)
                                            {
                                                <div class="cd-scores">
                                                    <div class="cd-score-row" title="Does the generated code satisfy all acceptance criteria?">
                                                        <span class="cd-score-label">Acceptance</span>
                                                        <div class="cd-score-bar-bg"><div class="cd-score-bar" style="width: @((candidate.AcScore ?? 0) * 10)%"></div></div>
                                                        <span class="cd-score-val">@(candidate.AcScore ?? 0)/10</span>
                                                    </div>
                                                    <div class="cd-score-row" title="Code architecture, patterns, and structural quality">
                                                        <span class="cd-score-label">Design</span>
                                                        <div class="cd-score-bar-bg"><div class="cd-score-bar" style="width: @((candidate.DesignScore ?? 0) * 10)%"></div></div>
                                                        <span class="cd-score-val">@(candidate.DesignScore ?? 0)/10</span>
                                                    </div>
                                                    <div class="cd-score-row" title="Code clarity, naming, and maintainability">
                                                        <span class="cd-score-label">Readability</span>
                                                        <div class="cd-score-bar-bg"><div class="cd-score-bar" style="width: @((candidate.ReadabilityScore ?? 0) * 10)%"></div></div>
                                                        <span class="cd-score-val">@(candidate.ReadabilityScore ?? 0)/10</span>
                                                    </div>
                                                    @if (candidate.VisualsScore.HasValue)
                                                    {
                                                    <div class="cd-score-row">
                                                        <span class="cd-score-label">Visuals</span>
                                                        <div class="cd-score-bar-bg"><div class="cd-score-bar cd-score-bar-visuals" style="width: @(candidate.VisualsScore.Value * 10)%"></div></div>
                                                        <span class="cd-score-val">@candidate.VisualsScore.Value/10</span>
                                                    </div>
                                                    }
                                                    <div class="cd-score-total" title="Combined score (max @MaxScore(candidate))">Total: <strong>@TotalScore(candidate)</strong>/@MaxScore(candidate)</div>
                                                </div>
                                            }
                                            else if (candidate.Succeeded == false)
                                            {
                                                <div class="cd-no-scores">Not scored — strategy execution failed</div>
                                            }
                                            else if (candidate.State < CandidateState.Evaluated)
                                            {
                                                <div class="cd-no-scores">Scores available after evaluation completes</div>
                                            }

                                            <div class="cd-metrics">
                                                @if (candidate.ElapsedSec.HasValue) { <span class="cd-metric" title="Execution time">⏱ @FormatDuration(candidate.ElapsedSec.Value)</span> }
                                                @if (candidate.TokensUsed.HasValue) { <span class="cd-metric" title="Tokens used">🔤 @(candidate.TokensUsed.Value.ToString("N0")) tokens</span> }
                                                @if (candidate.ExecutionSummary is { } s)
                                                {
                                                    <span class="cd-metric">📁 @s.FilesChanged.Count files</span>
                                                    <span class="cd-metric">+@s.TotalLinesAdded / -@s.TotalLinesRemoved lines</span>
                                                }
                                            </div>

                                            @if (candidate.Succeeded == false && !string.IsNullOrEmpty(candidate.FailureReason))
                                            {
                                                <div class="cd-failure"><span class="cd-failure-label">Failure:</span> @candidate.FailureReason</div>
                                            }

                                            @if (!string.IsNullOrEmpty(candidate.ScreenshotBase64))
                                            {
                                                <div class="cd-screenshot">
                                                    <div class="cd-screenshot-label">Preview Screenshot (click to enlarge)</div>
                                                    <img src="data:image/png;base64,@candidate.ScreenshotBase64" alt="@candidate.StrategyId preview" class="cd-screenshot-img"
                                                         @onclick="() => OpenLightbox(candidate.ScreenshotBase64, candidate.StrategyId)" @onclick:stopPropagation="true" />
                                                </div>
                                            }
                                        }
                                        else if (activeTab == "activity")
                                        {
                                            @if (candidate.ActivityLog.Count > 0)
                                            {
                                                <div class="cd-activity-timeline">
                                                    @foreach (var group in GroupConsecutive(candidate.ActivityLog.Reverse()))
                                                    {
                                                        <div class="cd-activity-entry" @onclick="() => _selectedActivity = group.Entry" @onclick:stopPropagation="true" title="Click for full detail">
                                                            <span class="cd-activity-time">@group.Entry.Timestamp.ToLocalTime().ToString("h:mm:ss tt")</span>
                                                            <span class="cd-activity-cat cd-activity-cat-@group.Entry.Category">@group.Entry.Category</span>
                                                            <span class="cd-activity-msg">@group.Entry.Message</span>
                                                            @if (group.Count > 1)
                                                            {
                                                                <span class="activity-group-badge" title="@group.Count consecutive identical entries">(×@group.Count)</span>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="cd-empty-tab">No activity recorded yet</div>
                                            }
                                        }
                                        else if (activeTab == "files")
                                        {
                                            @if (candidate.ExecutionSummary?.FilesChanged is { Count: > 0 } files)
                                            {
                                                <div class="cd-file-tree">
                                                    @foreach (var file in files.OrderBy(f => f.Path))
                                                    {
                                                        <div class="cd-file-row">
                                                            <span class="cd-file-type cd-file-type-@(file.Type.ToLowerInvariant())">@FileTypeIcon(file.Type)</span>
                                                            <span class="cd-file-path" title="@file.Path">@file.Path</span>
                                                            @if (!file.IsBinary) { <span class="cd-file-stats">@if (file.LinesAdded > 0) { <span class="cd-file-add">+@file.LinesAdded</span> } @if (file.LinesRemoved > 0) { <span class="cd-file-del">-@file.LinesRemoved</span> }</span> }
                                                            else { <span class="cd-file-stats muted">binary</span> }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else { <div class="cd-empty-tab">No file changes recorded.</div> }
                                        }
                                        else if (activeTab == "metrics")
                                        {
                                            <div class="cd-metrics-detail">
                                                <div class="cd-metric-row"><span class="cd-metric-label">Elapsed Time</span><span class="cd-metric-value">@(candidate.ElapsedSec?.ToString("0.1") ?? "—")s</span></div>
                                                <div class="cd-metric-row"><span class="cd-metric-label">Tokens Used</span><span class="cd-metric-value">@(candidate.TokensUsed?.ToString("N0") ?? "unknown")</span></div>
                                                @if (candidate.ExecutionSummary is { } sm)
                                                {
                                                    <div class="cd-metric-row"><span class="cd-metric-label">Files Changed</span><span class="cd-metric-value">@sm.FilesChanged.Count</span></div>
                                                    <div class="cd-metric-row"><span class="cd-metric-label">Lines Added</span><span class="cd-metric-value cd-file-add">+@sm.TotalLinesAdded</span></div>
                                                    <div class="cd-metric-row"><span class="cd-metric-label">Lines Removed</span><span class="cd-metric-value cd-file-del">-@sm.TotalLinesRemoved</span></div>
                                                }
                                            </div>
                                        }
                                        else if (activeTab == "logs")
                                        {
                                            @if (candidate.ExecutionSummary?.DiagnosticLog is { Count: > 0 } log)
                                            {
                                                <div class="cd-log-viewer">
                                                    @foreach (var logLine in log) { <div class="cd-log-line">@logLine</div> }
                                                </div>
                                            }
                                            else { <div class="cd-empty-tab">No diagnostic logs captured.</div> }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                @{
                    var allEvaluated = task.Candidates.Values.All(c => c.State >= CandidateState.Evaluated);
                    var noWinner = string.IsNullOrEmpty(task.WinnerStrategyId);
                    var allGateFailed = task.Candidates.Values.All(c => c.Survived == false);
                }
                @if (allEvaluated && noWinner && allGateFailed)
                {
                    <div class="task-no-winner" title="All candidate patches failed build gate checks — no winner could be selected. The runner will fall back to legacy code path.">
                        ⚠️ No winner — all @task.Candidates.Count candidates failed build gates. Falling back to legacy path.
                    </div>
                }
                else if (allEvaluated && noWinner && task.Candidates.Values.Any(c => c.Survived == true))
                {
                    <div class="task-evaluating" title="Evaluation completed but winner not yet determined">
                        🔄 Evaluation complete — selecting winner…
                    </div>
                }
            </div>
        }
    }
</section>

<section class="strategies-section">
    <h2 title="Completed tasks with evaluation results — click a row to expand and see detailed candidate data">Recent Completed (last @_recentTasks.Count)</h2>
    @if (_recentTasks.Count == 0)
    {
        <div class="empty-state">No completed tasks yet.</div>
    }
    else
    {
        <table class="recent-table" data-testid="strategies-recent-table">
            <thead>
                <tr>
                    <th title="Click a row to expand/collapse details"></th>
                    <th title="Unique task identifier from the engineering plan">Task</th>
                    <th title="The framework that produced the best code for this task">Winner</th>
                    <th title="All frameworks that competed on this task">Candidates</th>
                    <th title="How the winner was selected (e.g., highest score, only survivor, tie-break rule)">Tie-break</th>
                    <th title="Time spent evaluating all candidates (gate checks + LLM judge scoring)">Eval</th>
                    <th title="When the task evaluation finished">Completed</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var task in _recentTasks)
                {
                    var isExpanded = _expandedTasks.Contains(task.TaskId);
                    <tr class="recent-row @(isExpanded ? "expanded" : "")" @onclick="() => ToggleExpand(task.TaskId)">
                        <td class="expand-toggle" title="@(isExpanded ? "Collapse details" : "Expand to see candidate details")">@(isExpanded ? "▾" : "▸")</td>
                        <td><span class="task-id" title="Task identifier">@task.TaskId</span></td>
                        <td>
                            @if (task.WinnerStrategyId is string w)
                            {
                                <span class="winner-badge" title="@StrategyTooltip(w) — won this task">@w</span>
                            }
                            else
                            {
                                <span class="muted" title="No candidate produced acceptable code for this task">— none —</span>
                            }
                        </td>
                        <td title="Frameworks that ran: @string.Join(", ", task.Candidates.Keys.Select(k => StrategyDisplayName(k)))">@string.Join(", ", task.Candidates.Keys)</td>
                        <td class="muted" title="Selection reason for the winning candidate">@task.TieBreakReason</td>
                        <td title="Total evaluation time including gate checks and LLM judge scoring">@(task.EvaluationElapsedSec.HasValue ? FormatDuration(task.EvaluationElapsedSec.Value) : "-")</td>
                        <td title="@(task.CompletedAt?.ToLocalTime().ToString("yyyy-MM-dd h:mm:ss tt") ?? "Not yet completed")">@(task.CompletedAt?.ToLocalTime().ToString("M/d h:mm tt") ?? "-")</td>
                    </tr>
                    @if (isExpanded)
                    {
                        <tr class="detail-row">
                            <td colspan="7">
                                <div class="candidate-detail-grid">
                                    @foreach (var candidate in task.Candidates.Values.OrderByDescending(c => TotalScore(c)).ThenBy(c => c.StrategyId.Equals("baseline", StringComparison.OrdinalIgnoreCase) ? 1 : 0).ThenBy(c => c.StrategyId))
                                    {
                                        var isWinner = string.Equals(task.WinnerStrategyId, candidate.StrategyId, StringComparison.OrdinalIgnoreCase);
                                        <div class="candidate-detail-card @(isWinner ? "is-winner" : "") @(candidate.Succeeded == false ? "is-failed" : "")">
                                            @* Header *@
                                            <div class="cd-header">
                                                <span class="cd-name" title="@StrategyTooltip(candidate.StrategyId)">
                                                    @if (isWinner) { <span class="cd-trophy" title="This framework won the task">🏆</span> }
                                                    @candidate.StrategyId
                                                </span>
                                                <span class="cd-state cd-state-@(candidate.State.ToString().ToLowerInvariant())" title="@StateTooltip(candidate.State)">@candidate.State</span>
                                            </div>

                                            @* Progress pipeline *@
                                            <div class="cd-pipeline" title="Execution pipeline: Start → Gate checks (build, tests, screenshots) → LLM Judge scoring → Winner selection">
                                                <span class="cd-pip @(candidate.State >= CandidateState.Running ? "pip-done" : "")" title="Framework started code generation">Started</span>
                                                <span class="cd-pip-arrow">→</span>
                                                <span class="cd-pip @(candidate.Survived == true || candidate.State >= CandidateState.Evaluated ? "pip-done" : candidate.Survived == false && candidate.State >= CandidateState.Evaluated ? "pip-fail" : candidate.Succeeded == false ? "pip-fail" : "")"
                                                      title="Gate checks: build success, test pass, and optional screenshot verification">
                                                    @(candidate.Survived == true ? "Gates ✓" : candidate.Survived == false && candidate.State >= CandidateState.Evaluated ? "Gate Failed ✗" : candidate.Succeeded == false ? "Failed ✗" : "Evaluating…")
                                                </span>
                                                <span class="cd-pip-arrow">→</span>
                                                <span class="cd-pip @(candidate.State >= CandidateState.Scored ? "pip-done" : candidate.State >= CandidateState.Evaluated && !string.IsNullOrEmpty(candidate.JudgeSkippedReason) ? "pip-skip" : "")"
                                                      title="LLM Judge: scores code on Acceptance Criteria, Design, and Readability (each 0–10)">
                                                    @if (candidate.State >= CandidateState.Scored)
                                                    {
                                                        @:Scored ✓
                                                    }
                                                    else if (candidate.State >= CandidateState.Evaluated && !string.IsNullOrEmpty(candidate.JudgeSkippedReason))
                                                    {
                                                        @:Judge skipped
                                                    }
                                                    else if (candidate.Survived == false && candidate.State >= CandidateState.Evaluated)
                                                    {
                                                        @:—
                                                    }
                                                    else
                                                    {
                                                        @:Scoring…
                                                    }
                                                </span>
                                                @if (isWinner)
                                                {
                                                    <span class="cd-pip-arrow">→</span>
                                                    <span class="cd-pip pip-winner" title="This framework produced the best code and was selected as the winner">Winner 🏆</span>
                                                }
                                            </div>

                                            @* Tabbed detail view *@
                                            @{
                                                var tabKey = $"{task.TaskId}_{candidate.StrategyId}";
                                                var activeTab = _activeTabs.GetValueOrDefault(tabKey, "overview");
                                            }
                                            <div class="cd-tabs">
                                                <button class="cd-tab @(activeTab == "overview" ? "active" : "")" @onclick="@(() => SetTab(tabKey, "overview"))" @onclick:stopPropagation="true" title="Scores, judge reasoning, key metrics, and screenshot preview">Overview</button>
                                                <button class="cd-tab @(activeTab == "activity" ? "active" : "")" @onclick="@(() => SetTab(tabKey, "activity"))" @onclick:stopPropagation="true" title="Real-time activity log showing what the framework did step by step">
                                                    Activity @if (candidate.ActivityLog.Count > 0) { <span class="cd-tab-badge">@candidate.ActivityLog.Count</span> }
                                                </button>
                                                <button class="cd-tab @(activeTab == "files" ? "active" : "")" @onclick="@(() => SetTab(tabKey, "files"))" @onclick:stopPropagation="true" title="Files created, modified, or deleted by this framework">
                                                    Files @if (candidate.ExecutionSummary?.FilesChanged.Count > 0) { <span class="cd-tab-badge">@candidate.ExecutionSummary.FilesChanged.Count</span> }
                                                </button>
                                                <button class="cd-tab @(activeTab == "metrics" ? "active" : "")" @onclick="@(() => SetTab(tabKey, "metrics"))" @onclick:stopPropagation="true" title="Detailed performance metrics: time, tokens, lines changed, patch size, and judge scores">Metrics</button>
                                                <button class="cd-tab @(activeTab == "logs" ? "active" : "")" @onclick="@(() => SetTab(tabKey, "logs"))" @onclick:stopPropagation="true" title="Raw diagnostic logs from the framework execution (stdout/stderr)">
                                                    Logs @if (candidate.ExecutionSummary?.DiagnosticLog.Count > 0) { <span class="cd-tab-badge">@candidate.ExecutionSummary.DiagnosticLog.Count</span> }
                                                </button>
                                            </div>

                                            <div class="cd-tab-content">
                                                @if (activeTab == "overview")
                                                {
                                                    @* Scores *@
                                                    @if (candidate.AcScore.HasValue || candidate.DesignScore.HasValue || candidate.ReadabilityScore.HasValue)
                                                    {
                                                        <div class="cd-scores">
                                                            <div class="cd-score-row" title="Does the generated code satisfy all acceptance criteria from the task?">
                                                                <span class="cd-score-label">Acceptance</span>
                                                                <div class="cd-score-bar-bg"><div class="cd-score-bar" style="width: @((candidate.AcScore ?? 0) * 10)%"></div></div>
                                                                <span class="cd-score-val">@(candidate.AcScore ?? 0)/10</span>
                                                            </div>
                                                            <div class="cd-score-row" title="Code architecture, patterns, separation of concerns, and structural quality">
                                                                <span class="cd-score-label">Design</span>
                                                                <div class="cd-score-bar-bg"><div class="cd-score-bar" style="width: @((candidate.DesignScore ?? 0) * 10)%"></div></div>
                                                                <span class="cd-score-val">@(candidate.DesignScore ?? 0)/10</span>
                                                            </div>
                                                            <div class="cd-score-row" title="Code clarity, naming conventions, comments, and long-term maintainability">
                                                                <span class="cd-score-label">Readability</span>
                                                                <div class="cd-score-bar-bg"><div class="cd-score-bar" style="width: @((candidate.ReadabilityScore ?? 0) * 10)%"></div></div>
                                                                <span class="cd-score-val">@(candidate.ReadabilityScore ?? 0)/10</span>
                                                            </div>
                                                            @if (candidate.VisualsScore.HasValue)
                                                            {
                                                            <div class="cd-score-row" title="Visual quality of the application screenshot (0–10)">
                                                                <span class="cd-score-label">Visuals</span>
                                                                <div class="cd-score-bar-bg"><div class="cd-score-bar cd-score-bar-visuals" style="width: @(candidate.VisualsScore.Value * 10)%"></div></div>
                                                                <span class="cd-score-val">@candidate.VisualsScore.Value/10</span>
                                                            </div>
                                                            }
                                                            <div class="cd-score-total" title="Combined score across all categories (max @MaxScore(candidate))">
                                                                Total: <strong>@TotalScore(candidate)</strong>/@MaxScore(candidate)
                                                            </div>
                                                        </div>
                                                    }
                                                    else if (candidate.Survived == false && candidate.State >= CandidateState.Evaluated)
                                                    {
                                                        <div class="cd-no-scores">Not scored — failed gate: @(candidate.FailureReason ?? "unknown")</div>
                                                    }
                                                    else if (!string.IsNullOrEmpty(candidate.JudgeSkippedReason))
                                                    {
                                                        <div class="cd-no-scores cd-judge-skipped">
                                                            No LLM judge scoring — <strong>@candidate.JudgeSkippedReason</strong>
                                                        </div>
                                                    }
                                                    else if (candidate.Succeeded == false)
                                                    {
                                                        <div class="cd-no-scores">Not scored — strategy execution failed</div>
                                                    }
                                                    else
                                                    {
                                                        <div class="cd-no-scores">Scores not available</div>
                                                    }

                                                    @* Judge Reasoning *@
                                                    @if (!string.IsNullOrEmpty(candidate.ExecutionSummary?.JudgeReasoning))
                                                    {
                                                        <div class="cd-reasoning">
                                                            <div class="cd-reasoning-label" title="The LLM judge's explanation for why it assigned these scores">Judge Reasoning</div>
                                                            <div class="cd-reasoning-text">@candidate.ExecutionSummary.JudgeReasoning</div>
                                                        </div>
                                                    }

                                                    @* Key metrics row *@
                                                    <div class="cd-metrics">
                                                        @if (candidate.ElapsedSec.HasValue)
                                                        {
                                                            <span class="cd-metric" title="Actual execution time for this framework's code generation">⏱ @FormatDuration(candidate.ElapsedSec.Value)</span>
                                                        }
                                                        @if (candidate.TokensUsed.HasValue)
                                                        {
                                                            <span class="cd-metric" title="Total LLM tokens consumed during code generation">🔤 @(candidate.TokensUsed.Value.ToString("N0")) tokens</span>
                                                        }
                                                        @if (candidate.ExecutionSummary is { } s)
                                                        {
                                                            <span class="cd-metric" title="Number of files created, modified, or deleted">📁 @s.FilesChanged.Count files</span>
                                                            <span class="cd-metric" title="Lines of code added vs removed">+@s.TotalLinesAdded / -@s.TotalLinesRemoved lines</span>
                                                        }
                                                    </div>

                                                    @* Failure reason *@
                                                    @if (candidate.Succeeded == false && !string.IsNullOrEmpty(candidate.FailureReason))
                                                    {
                                                        <div class="cd-failure">
                                                            <span class="cd-failure-label">Failure:</span> @candidate.FailureReason
                                                        </div>
                                                    }

                                                    @* Screenshot *@
                                                    @if (!string.IsNullOrEmpty(candidate.ScreenshotBase64))
                                                    {
                                                        <div class="cd-screenshot">
                                                            <div class="cd-screenshot-label">Preview Screenshot (click to enlarge)</div>
                                                            <img src="data:image/png;base64,@candidate.ScreenshotBase64" alt="@candidate.StrategyId preview" class="cd-screenshot-img"
                                                                 @onclick="() => OpenLightbox(candidate.ScreenshotBase64, candidate.StrategyId)" />
                                                        </div>
                                                    }
                                                    else if (candidate.State >= CandidateState.Evaluated)
                                                    {
                                                        <div class="cd-screenshot">
                                                            <div class="cd-screenshot-label">Preview Screenshot</div>
                                                            <div class="cd-no-screenshot">📷 No screenshot captured — app may not have started, or Playwright browser is not installed</div>
                                                        </div>
                                                    }
                                                }
                                                else if (activeTab == "activity")
                                                {
                                                    @if (candidate.ActivityLog.Count > 0)
                                                    {
                                                        <div class="cd-activity-timeline">
                                                            @foreach (var group in GroupConsecutive(candidate.ActivityLog.Reverse()))
                                                            {
                                                                <div class="cd-activity-entry" @onclick="() => _selectedActivity = group.Entry" @onclick:stopPropagation="true" title="Click for full detail">
                                                                    <span class="cd-activity-time">@group.Entry.Timestamp.ToLocalTime().ToString("h:mm:ss tt")</span>
                                                                    <span class="cd-activity-cat cd-activity-cat-@group.Entry.Category">@group.Entry.Category</span>
                                                                    <span class="cd-activity-msg">@group.Entry.Message</span>
                                                                    @if (group.Count > 1)
                                                                    {
                                                                        <span class="activity-group-badge" title="@group.Count consecutive identical entries">(×@group.Count)</span>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="cd-empty-tab">No activity recorded yet</div>
                                                    }
                                                }
                                                else if (activeTab == "files")
                                                {
                                                    @if (candidate.ExecutionSummary?.FilesChanged is { Count: > 0 } files)
                                                    {
                                                        <div class="cd-file-tree">
                                                            @foreach (var file in files.OrderBy(f => f.Path))
                                                            {
                                                                <div class="cd-file-row">
                                                                    <span class="cd-file-type cd-file-type-@(file.Type.ToLowerInvariant())">@FileTypeIcon(file.Type)</span>
                                                                    <span class="cd-file-path" title="@file.Path">@file.Path</span>
                                                                    @if (!file.IsBinary)
                                                                    {
                                                                        <span class="cd-file-stats">
                                                                            @if (file.LinesAdded > 0) { <span class="cd-file-add">+@file.LinesAdded</span> }
                                                                            @if (file.LinesRemoved > 0) { <span class="cd-file-del">-@file.LinesRemoved</span> }
                                                                        </span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="cd-file-stats muted">binary</span>
                                                                    }
                                                                </div>
                                                            }
                                                            <div class="cd-file-summary">
                                                                @files.Count file(s) · <span class="cd-file-add">+@files.Sum(f => f.LinesAdded)</span> <span class="cd-file-del">-@files.Sum(f => f.LinesRemoved)</span> · @FormatBytes(candidate.ExecutionSummary.PatchSizeBytes) patch
                                                            </div>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="cd-empty-tab">No file changes recorded.</div>
                                                    }
                                                }
                                                else if (activeTab == "metrics")
                                                {
                                                    <div class="cd-metrics-detail">
                                                        <div class="cd-metric-row" title="Wall-clock time the framework spent generating code">
                                                            <span class="cd-metric-label">Elapsed Time</span>
                                                            <span class="cd-metric-value">@(candidate.ElapsedSec?.ToString("0.1") ?? "—")s</span>
                                                        </div>
                                                        <div class="cd-metric-row" title="Total LLM tokens consumed (prompt + completion)">
                                                            <span class="cd-metric-label">Tokens Used</span>
                                                            <span class="cd-metric-value">@(candidate.TokensUsed?.ToString("N0") ?? "unknown")</span>
                                                        </div>
                                                        @if (candidate.ExecutionSummary is { } sm)
                                                        {
                                                            <div class="cd-metric-row" title="Total number of files created, modified, or deleted">
                                                                <span class="cd-metric-label">Files Changed</span>
                                                                <span class="cd-metric-value">@sm.FilesChanged.Count</span>
                                                            </div>
                                                            <div class="cd-metric-row" title="Total new lines of code added across all files">
                                                                <span class="cd-metric-label">Lines Added</span>
                                                                <span class="cd-metric-value cd-file-add">+@sm.TotalLinesAdded</span>
                                                            </div>
                                                            <div class="cd-metric-row" title="Total lines of code removed across all files">
                                                                <span class="cd-metric-label">Lines Removed</span>
                                                                <span class="cd-metric-value cd-file-del">-@sm.TotalLinesRemoved</span>
                                                            </div>
                                                            <div class="cd-metric-row" title="Total size of the git diff/patch produced">
                                                                <span class="cd-metric-label">Patch Size</span>
                                                                <span class="cd-metric-value">@FormatBytes(sm.PatchSizeBytes)</span>
                                                            </div>
                                                        }
                                                        @if (candidate.ExecutionSummary?.Scores is { } sc)
                                                        {
                                                            <div class="cd-metric-divider"></div>
                                                            <div class="cd-metric-row" title="LLM judge's combined score: Acceptance Criteria + Design + Readability (each 0–10, max 30)">
                                                                <span class="cd-metric-label">Judge Score</span>
                                                                <span class="cd-metric-value">@sc.Total / 30 (AC=@sc.AcceptanceCriteria, Design=@sc.Design, Read=@sc.Readability)</span>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                else if (activeTab == "logs")
                                                {
                                                    @if (candidate.ExecutionSummary?.DiagnosticLog is { Count: > 0 } log)
                                                    {
                                                        <div class="cd-log-viewer">
                                                            @foreach (var logLine in log)
                                                            {
                                                                <div class="cd-log-line">@logLine</div>
                                                            }
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="cd-empty-tab">No diagnostic logs captured.</div>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }
</section>

@* Screenshot lightbox modal *@
@if (_lightboxImage is not null)
{
    <div class="lightbox-overlay" @onclick="CloseLightbox">
        <div class="lightbox-content" @onclick:stopPropagation="true">
            <div class="lightbox-header">
                <span class="lightbox-title">@_lightboxTitle</span>
                <button class="lightbox-close" @onclick="CloseLightbox">✕</button>
            </div>
            <img src="data:image/png;base64,@_lightboxImage" alt="@_lightboxTitle" class="lightbox-img" />
        </div>
    </div>
}

@if (_selectedActivity is not null)
{
    <div class="activity-modal-overlay" @onclick="() => _selectedActivity = null">
        <div class="activity-modal" @onclick:stopPropagation="true">
            <div class="activity-modal-header">
                <span class="activity-modal-cat cd-activity-cat-@_selectedActivity.Category">@_selectedActivity.Category</span>
                <span class="activity-modal-time">@_selectedActivity.Timestamp.ToLocalTime().ToString("h:mm:ss.fff tt — MMM d")</span>
                <button class="activity-modal-close" @onclick="() => _selectedActivity = null">✕</button>
            </div>
            <div class="activity-modal-body">@_selectedActivity.Message</div>
        </div>
    </div>
}

<style>
    .strategies-section { margin: 1.5rem 0; }
    .strategies-section h2 { font-size: 1.1rem; margin: 0 0 .75rem; }
    .task-card { background: var(--card-bg, #1a1e26); border: 1px solid var(--border, #2d3240); border-radius: 6px; padding: 1rem; margin-bottom: 1rem; }
    .task-header { display: flex; justify-content: space-between; margin-bottom: .75rem; align-items: baseline; }
    .task-id { font-weight: 600; }
    .task-run { opacity: .55; font-size: .85em; margin-left: .5rem; font-family: monospace; }
    .task-elapsed { font-family: monospace; opacity: .7; }
    .candidate-grid { display: flex; flex-direction: column; gap: .75rem; }
    .candidate-card { border: 1px solid var(--border, #2d3240); border-radius: 5px; padding: .75rem; }
    .candidate-card.state-running { border-left: 3px solid #4dabf7; }
    .candidate-card.state-completed { border-left: 3px solid #51cf66; }
    .candidate-card.state-evaluated { border-left: 3px solid #ab9ae6; }
    .candidate-card.state-scored { border-left: 3px solid #ffd43b; }
    .candidate-card.state-winner { border-left: 3px solid gold; background: rgba(255, 215, 0, .08); }
    .candidate-head { display: flex; justify-content: space-between; margin-bottom: .25rem; font-weight: 500; }
    .candidate-state { font-size: .75em; opacity: .7; text-transform: uppercase; letter-spacing: .05em; }
    .candidate-timing { font-family: monospace; font-size: .85em; opacity: .8; }
    .candidate-scores { display: flex; gap: .5rem; font-size: .85em; margin-top: .35rem; }
    .candidate-scores div { flex: 1; background: rgba(255,255,255,.04); padding: .2rem .4rem; border-radius: 3px; }
    .candidate-scores span { font-weight: 600; margin-left: .15rem; }
    .candidate-scores .visuals-score span { color: #fab005; }
    .candidate-fail { color: #ff6b6b; font-size: .85em; margin-top: .35rem; }
    .candidate-gate-fail { color: #ff8787; font-size: .82em; margin-top: .35rem; background: rgba(255,107,107,.08); padding: .3rem .5rem; border-radius: 4px; border-left: 2px solid #ff6b6b; }
    .gate-fail-detail { display: block; font-size: .9em; opacity: .75; margin-top: .15rem; word-break: break-word; }
    .task-no-winner { background: rgba(255,107,107,.1); border-left: 3px solid #ff6b6b; padding: .5rem .75rem; margin-top: .5rem; border-radius: 4px; font-size: .85em; color: #ff8787; }
    .task-evaluating { background: rgba(77,171,247,.08); border-left: 3px solid #4dabf7; padding: .5rem .75rem; margin-top: .5rem; border-radius: 4px; font-size: .85em; color: #4dabf7; }
    .recent-table { width: 100%; border-collapse: collapse; }
    .recent-table th, .recent-table td { padding: .5rem; border-bottom: 1px solid var(--border, #2d3240); text-align: left; }
    .recent-table th { opacity: .7; font-weight: 500; font-size: .85em; text-transform: uppercase; letter-spacing: .05em; }
    .winner-badge { background: gold; color: #111; padding: .1rem .4rem; border-radius: 3px; font-weight: 600; font-size: .85em; }
    .empty-state { opacity: .6; padding: 1rem 0; font-style: italic; }
    .muted { opacity: .55; }
    .alert-banner { background: rgba(77, 171, 247, .08); border-left: 3px solid #4dabf7; padding: .75rem 1rem; border-radius: 4px; margin: 1rem 0; }

    /* Expandable recent rows */
    .recent-row { cursor: pointer; transition: background .15s; }
    .recent-row:hover { background: rgba(255,255,255,.03); }
    .recent-row.expanded { background: rgba(255,255,255,.02); }
    .expand-toggle { width: 1.5rem; text-align: center; opacity: .5; font-size: .85em; }
    .detail-row td { padding: 0 !important; border-bottom: 1px solid var(--border, #2d3240); }

    /* Candidate detail grid — vertical rows like active candidates */
    .candidate-detail-grid { display: flex; flex-direction: column; gap: .75rem; padding: .75rem 1rem 1rem; }
    .candidate-detail-card { background: var(--card-bg, #1a1e26); border: 1px solid var(--border, #2d3240); border-radius: 6px; padding: .85rem; transition: border-color .15s; }
    .candidate-detail-card.is-winner { border: 1px solid gold; background: rgba(255, 215, 0, .04); }
    .candidate-detail-card.is-failed { opacity: .7; }

    .cd-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: .5rem; }
    .cd-name { font-weight: 600; font-size: .95em; }
    .cd-trophy { margin-right: .25rem; }
    .cd-state { font-size: .7em; text-transform: uppercase; letter-spacing: .05em; padding: .15rem .4rem; border-radius: 3px; }
    .cd-state-running { background: rgba(77, 171, 247, .15); color: #4dabf7; }
    .cd-state-completed { background: rgba(81, 207, 102, .15); color: #51cf66; }
    .cd-state-evaluated { background: rgba(171, 154, 230, .15); color: #ab9ae6; }
    .cd-state-scored { background: rgba(255, 212, 59, .15); color: #ffd43b; }
    .cd-state-winner { background: rgba(255, 215, 0, .2); color: gold; }

    /* Progress pipeline */
    .cd-pipeline { display: flex; align-items: center; gap: .25rem; font-size: .75em; margin-bottom: .65rem; flex-wrap: wrap; }
    .cd-pip { padding: .15rem .35rem; border-radius: 3px; background: rgba(255,255,255,.05); opacity: .45; }
    .cd-pip.pip-done { opacity: 1; background: rgba(81, 207, 102, .12); color: #51cf66; }
    .cd-pip.pip-fail { opacity: 1; background: rgba(255, 107, 107, .12); color: #ff6b6b; }
    .cd-pip.pip-skip { opacity: .75; background: rgba(255, 212, 59, .1); color: #ffd43b; font-style: italic; }
    .cd-pip.pip-winner { opacity: 1; background: rgba(255, 215, 0, .15); color: gold; }
    .cd-pip-arrow { opacity: .3; }

    /* Score bars */
    .cd-scores { margin-bottom: .5rem; }
    .cd-score-row { display: flex; align-items: center; gap: .5rem; margin-bottom: .3rem; }
    .cd-score-label { width: 5.5rem; font-size: .75em; opacity: .65; text-align: right; }
    .cd-score-bar-bg { flex: 1; height: 6px; background: rgba(255,255,255,.06); border-radius: 3px; overflow: hidden; }
    .cd-score-bar { height: 100%; background: linear-gradient(90deg, #4dabf7, #51cf66); border-radius: 3px; transition: width .3s; }
    .cd-score-bar-visuals { background: linear-gradient(90deg, #fab005, #ff922b); }
    .cd-score-val { font-size: .75em; font-family: monospace; width: 2.5rem; opacity: .8; }
    .cd-score-total { text-align: right; font-size: .8em; margin-top: .25rem; opacity: .8; }
    .cd-no-scores { font-size: .8em; opacity: .4; font-style: italic; margin-bottom: .5rem; }
    .cd-judge-skipped { opacity: .6; color: #ffd43b; font-style: normal; }

    /* Metrics */
    .cd-metrics { display: flex; gap: .75rem; font-size: .8em; opacity: .7; margin-bottom: .35rem; }
    .cd-metric { font-family: monospace; }

    /* Failure */
    .cd-failure { font-size: .8em; color: #ff6b6b; background: rgba(255,107,107,.06); padding: .35rem .5rem; border-radius: 4px; margin-top: .35rem; }
    .cd-failure-label { font-weight: 600; }

    /* Screenshot */
    .cd-screenshot { margin-top: .5rem; }
    .cd-screenshot-label { font-size: .7em; text-transform: uppercase; letter-spacing: .05em; opacity: .5; margin-bottom: .3rem; }
    .cd-screenshot-img { width: 100%; border-radius: 4px; border: 1px solid var(--border, #2d3240); cursor: pointer; transition: transform .15s; }
    .cd-screenshot-img:hover { transform: scale(1.02); box-shadow: 0 4px 12px rgba(0,0,0,.4); }

    /* Tabs */
    .cd-tabs { display: flex; gap: .25rem; border-bottom: 1px solid var(--border, #2d3240); margin-bottom: .65rem; }
    .cd-tab { background: none; border: none; color: inherit; padding: .35rem .6rem; font-size: .75em; cursor: pointer; opacity: .5; border-bottom: 2px solid transparent; transition: opacity .15s, border-color .15s; font-family: inherit; }
    .cd-tab:hover { opacity: .8; }
    .cd-tab.active { opacity: 1; border-bottom-color: #4dabf7; }
    .cd-tab-badge { background: rgba(77, 171, 247, .2); color: #4dabf7; padding: .05rem .3rem; border-radius: 8px; font-size: .85em; margin-left: .25rem; }
    .cd-tab-content { min-height: 3rem; }

    /* Judge Reasoning */
    .cd-reasoning { margin-bottom: .5rem; }
    .cd-reasoning-label { font-size: .7em; text-transform: uppercase; letter-spacing: .05em; opacity: .5; margin-bottom: .25rem; }
    .cd-reasoning-text { font-size: .8em; line-height: 1.45; background: rgba(255,255,255,.03); padding: .5rem; border-radius: 4px; border-left: 2px solid rgba(77,171,247,.3); white-space: pre-wrap; }

    /* File tree */
    .cd-file-tree { font-family: 'Cascadia Code', 'Fira Code', monospace; font-size: .78em; }
    .cd-file-row { display: flex; align-items: center; gap: .5rem; padding: .2rem 0; border-bottom: 1px solid rgba(255,255,255,.03); }
    .cd-file-type { width: 1.2rem; text-align: center; font-size: .85em; }
    .cd-file-type-added { color: #51cf66; }
    .cd-file-type-modified { color: #ffd43b; }
    .cd-file-type-deleted { color: #ff6b6b; }
    .cd-file-type-renamed { color: #4dabf7; }
    .cd-file-path { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .cd-file-stats { text-align: right; white-space: nowrap; }
    .cd-file-add { color: #51cf66; }
    .cd-file-del { color: #ff6b6b; }
    .cd-file-summary { margin-top: .5rem; padding-top: .4rem; border-top: 1px solid var(--border, #2d3240); font-size: .85em; opacity: .7; }

    /* Metrics detail */
    .cd-metrics-detail { display: grid; gap: .35rem; }
