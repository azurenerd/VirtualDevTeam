@page "/strategies"
@rendermode InteractiveServer
@using AgentSquad.Core.Strategies
@using AgentSquad.Dashboard.Services
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.Extensions.Logging
@implements IAsyncDisposable
@inject IStrategiesDataService StrategiesData
@inject NavigationManager Navigation
@inject ILogger<Strategies> Logger

<PageTitle>AgentSquad — Agentic Frameworks</PageTitle>

<div class="dashboard-header" data-testid="page-strategies">
    <h1>Agentic Frameworks</h1>
    <div class="header-badges">
        <span class="header-badge @(_enabled?.MasterEnabled == true ? "" : "muted")" data-testid="strategies-enabled-badge">
            @(_enabled?.MasterEnabled == true ? "● Framework ON" : "○ Framework OFF")
        </span>
        <span class="header-badge" data-testid="strategies-active-count">
            Active: @_activeTasks.Count
        </span>
        <span class="header-badge" data-testid="strategies-recent-count">
            Recent: @_recentTasks.Count
        </span>
        <button class="ntl-refresh-btn @(_refreshing ? "spinning" : "")" @onclick="RefreshAsync" disabled="@_refreshing" title="Refresh" data-testid="strategies-refresh">
            <svg class="ntl-refresh-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M13.5 8a5.5 5.5 0 1 1-1.6-3.9M13.5 2.5v2h-2"/>
            </svg>
        </button>
    </div>
</div>

@if (_enabled?.MasterEnabled != true)
{
    <div class="alert-banner info" data-testid="strategies-disabled-banner">
        <strong>Agentic frameworks are disabled.</strong> Baseline code generation is the
        only active path. Set <code>AgentSquad:StrategyFramework:Enabled = true</code>
        to enable multi-framework candidate runs.
    </div>
}

<section class="strategies-section">
    <h2>Active Tasks</h2>
    @if (_activeTasks.Count == 0)
    {
        <div class="empty-state">No active framework candidates. Waiting for the next task&hellip;</div>
    }
    else
    {
        @foreach (var task in _activeTasks)
        {
            <div class="task-card" data-testid="strategies-task-card" data-task-id="@task.TaskId">
                <div class="task-header">
                    <div>
                        <span class="task-id">@task.TaskId</span>
                        <span class="task-run">run @task.RunId</span>
                    </div>
                    <div class="task-elapsed">@FormatElapsed(task.StartedAt)</div>
                </div>
                <div class="candidate-grid">
                    @foreach (var candidate in task.Candidates.Values.OrderBy(c => c.StrategyId))
                    {
                        <div class="candidate-card state-@(candidate.State.ToString().ToLowerInvariant())" data-testid="strategies-candidate-card" data-strategy-id="@candidate.StrategyId">
                            <div class="candidate-head">
                                <span class="candidate-id">
                                    @candidate.StrategyId
                                </span>
                                <span class="candidate-state">@candidate.State</span>
                            </div>
                            @if (candidate.ElapsedSec is double e)
                            {
                                <div class="candidate-timing">@e.ToString("0.0")s @(candidate.TokensUsed.HasValue ? $"· {candidate.TokensUsed} tok" : "· tokens n/a")</div>
                            }
                            @if (candidate.State == CandidateState.Scored || candidate.State == CandidateState.Winner)
                            {
                                <div class="candidate-scores">
                                    <div>AC <span>@(candidate.AcScore ?? 0)</span></div>
                                    <div>Des <span>@(candidate.DesignScore ?? 0)</span></div>
                                    <div>Read <span>@(candidate.ReadabilityScore ?? 0)</span></div>
                                </div>
                            }
                            @if (candidate.Succeeded == false)
                            {
                                <div class="candidate-fail">@candidate.FailureReason</div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }
</section>

<section class="strategies-section">
    <h2>Recent Completed (last @_recentTasks.Count)</h2>
    @if (_recentTasks.Count == 0)
    {
        <div class="empty-state">No completed tasks yet.</div>
    }
    else
    {
        <table class="recent-table" data-testid="strategies-recent-table">
            <thead>
                <tr>
                    <th></th>
                    <th>Task</th>
                    <th>Winner</th>
                    <th>Candidates</th>
                    <th>Tie-break</th>
                    <th>Eval</th>
                    <th>Completed</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var task in _recentTasks)
                {
                    var isExpanded = _expandedTasks.Contains(task.TaskId);
                    <tr class="recent-row @(isExpanded ? "expanded" : "")" @onclick="() => ToggleExpand(task.TaskId)">
                        <td class="expand-toggle">@(isExpanded ? "▾" : "▸")</td>
                        <td><span class="task-id">@task.TaskId</span></td>
                        <td>
                            @if (task.WinnerStrategyId is string w)
                            {
                                <span class="winner-badge">@w</span>
                            }
                            else
                            {
                                <span class="muted">— none —</span>
                            }
                        </td>
                        <td>@string.Join(", ", task.Candidates.Keys)</td>
                        <td class="muted">@task.TieBreakReason</td>
                        <td>@(task.EvaluationElapsedSec?.ToString("0.0") ?? "-")s</td>
                        <td>@(task.CompletedAt?.ToLocalTime().ToString("HH:mm:ss") ?? "-")</td>
                    </tr>
                    @if (isExpanded)
                    {
                        <tr class="detail-row">
                            <td colspan="7">
                                <div class="candidate-detail-grid">
                                    @foreach (var candidate in task.Candidates.Values.OrderByDescending(c => TotalScore(c)).ThenBy(c => c.StrategyId))
                                    {
                                        var isWinner = string.Equals(task.WinnerStrategyId, candidate.StrategyId, StringComparison.OrdinalIgnoreCase);
                                        <div class="candidate-detail-card @(isWinner ? "is-winner" : "") @(candidate.Succeeded == false ? "is-failed" : "")">
                                            @* Header *@
                                            <div class="cd-header">
                                                <span class="cd-name">
                                                    @if (isWinner) { <span class="cd-trophy">🏆</span> }
                                                    @candidate.StrategyId
                                                </span>
                                                <span class="cd-state cd-state-@(candidate.State.ToString().ToLowerInvariant())">@candidate.State</span>
                                            </div>

                                            @* Progress pipeline *@
                                            <div class="cd-pipeline">
                                                <span class="cd-pip @(candidate.State >= CandidateState.Running ? "pip-done" : "")">Started</span>
                                                <span class="cd-pip-arrow">→</span>
                                                <span class="cd-pip @(candidate.Succeeded == true || candidate.State >= CandidateState.Scored ? "pip-done" : candidate.Succeeded == false ? "pip-fail" : "")">
                                                    @(candidate.Succeeded == true ? "Built ✓" : candidate.Succeeded == false ? "Failed ✗" : "Building…")
                                                </span>
                                                <span class="cd-pip-arrow">→</span>
                                                <span class="cd-pip @(candidate.State >= CandidateState.Scored ? "pip-done" : "")">
                                                    @(candidate.State >= CandidateState.Scored ? "Scored ✓" : "Scoring…")
                                                </span>
                                                @if (isWinner)
                                                {
                                                    <span class="cd-pip-arrow">→</span>
                                                    <span class="cd-pip pip-winner">Winner 🏆</span>
                                                }
                                            </div>

                                            @* Scores *@
                                            @if (candidate.AcScore.HasValue || candidate.DesignScore.HasValue || candidate.ReadabilityScore.HasValue)
                                            {
                                                <div class="cd-scores">
                                                    <div class="cd-score-row">
                                                        <span class="cd-score-label">Acceptance</span>
                                                        <div class="cd-score-bar-bg"><div class="cd-score-bar" style="width: @((candidate.AcScore ?? 0) * 10)%"></div></div>
                                                        <span class="cd-score-val">@(candidate.AcScore ?? 0)/10</span>
                                                    </div>
                                                    <div class="cd-score-row">
                                                        <span class="cd-score-label">Design</span>
                                                        <div class="cd-score-bar-bg"><div class="cd-score-bar" style="width: @((candidate.DesignScore ?? 0) * 10)%"></div></div>
                                                        <span class="cd-score-val">@(candidate.DesignScore ?? 0)/10</span>
                                                    </div>
                                                    <div class="cd-score-row">
                                                        <span class="cd-score-label">Readability</span>
                                                        <div class="cd-score-bar-bg"><div class="cd-score-bar" style="width: @((candidate.ReadabilityScore ?? 0) * 10)%"></div></div>
                                                        <span class="cd-score-val">@(candidate.ReadabilityScore ?? 0)/10</span>
                                                    </div>
                                                    <div class="cd-score-total">
                                                        Total: <strong>@TotalScore(candidate)</strong>/30
                                                    </div>
                                                </div>
                                            }
                                            else if (candidate.Succeeded == false)
                                            {
                                                <div class="cd-no-scores">Not scored — did not pass build gate</div>
                                            }
                                            else
                                            {
                                                <div class="cd-no-scores">Scores not available</div>
                                            }

                                            @* Metrics *@
                                            <div class="cd-metrics">
                                                @if (candidate.ElapsedSec.HasValue)
                                                {
                                                    <span class="cd-metric">⏱ @(candidate.ElapsedSec.Value.ToString("0.1"))s</span>
                                                }
                                                @if (candidate.TokensUsed.HasValue)
                                                {
                                                    <span class="cd-metric">🔤 @(candidate.TokensUsed.Value.ToString("N0")) tokens</span>
                                                }
                                            </div>

                                            @* Failure reason *@
                                            @if (candidate.Succeeded == false && !string.IsNullOrEmpty(candidate.FailureReason))
                                            {
                                                <div class="cd-failure">
                                                    <span class="cd-failure-label">Failure:</span> @candidate.FailureReason
                                                </div>
                                            }

                                            @* Screenshot *@
                                            @if (!string.IsNullOrEmpty(candidate.ScreenshotBase64))
                                            {
                                                <div class="cd-screenshot">
                                                    <div class="cd-screenshot-label">Preview Screenshot</div>
                                                    <img src="data:image/png;base64,@candidate.ScreenshotBase64" alt="@candidate.StrategyId preview" class="cd-screenshot-img" />
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }
</section>

<style>
    .strategies-section { margin: 1.5rem 0; }
    .strategies-section h2 { font-size: 1.1rem; margin: 0 0 .75rem; }
    .task-card { background: var(--card-bg, #1a1e26); border: 1px solid var(--border, #2d3240); border-radius: 6px; padding: 1rem; margin-bottom: 1rem; }
    .task-header { display: flex; justify-content: space-between; margin-bottom: .75rem; align-items: baseline; }
    .task-id { font-weight: 600; }
    .task-run { opacity: .55; font-size: .85em; margin-left: .5rem; font-family: monospace; }
    .task-elapsed { font-family: monospace; opacity: .7; }
    .candidate-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: .75rem; }
    .candidate-card { border: 1px solid var(--border, #2d3240); border-radius: 5px; padding: .75rem; }
    .candidate-card.state-running { border-left: 3px solid #4dabf7; }
    .candidate-card.state-completed { border-left: 3px solid #51cf66; }
    .candidate-card.state-scored { border-left: 3px solid #ffd43b; }
    .candidate-card.state-winner { border-left: 3px solid gold; background: rgba(255, 215, 0, .08); }
    .candidate-head { display: flex; justify-content: space-between; margin-bottom: .25rem; font-weight: 500; }
    .candidate-state { font-size: .75em; opacity: .7; text-transform: uppercase; letter-spacing: .05em; }
    .candidate-timing { font-family: monospace; font-size: .85em; opacity: .8; }
    .candidate-scores { display: flex; gap: .5rem; font-size: .85em; margin-top: .35rem; }
    .candidate-scores div { flex: 1; background: rgba(255,255,255,.04); padding: .2rem .4rem; border-radius: 3px; }
    .candidate-scores span { font-weight: 600; margin-left: .15rem; }
    .candidate-fail { color: #ff6b6b; font-size: .85em; margin-top: .35rem; }
    .recent-table { width: 100%; border-collapse: collapse; }
    .recent-table th, .recent-table td { padding: .5rem; border-bottom: 1px solid var(--border, #2d3240); text-align: left; }
    .recent-table th { opacity: .7; font-weight: 500; font-size: .85em; text-transform: uppercase; letter-spacing: .05em; }
    .winner-badge { background: gold; color: #111; padding: .1rem .4rem; border-radius: 3px; font-weight: 600; font-size: .85em; }
    .empty-state { opacity: .6; padding: 1rem 0; font-style: italic; }
    .muted { opacity: .55; }
    .alert-banner { background: rgba(77, 171, 247, .08); border-left: 3px solid #4dabf7; padding: .75rem 1rem; border-radius: 4px; margin: 1rem 0; }

    /* Expandable recent rows */
    .recent-row { cursor: pointer; transition: background .15s; }
    .recent-row:hover { background: rgba(255,255,255,.03); }
    .recent-row.expanded { background: rgba(255,255,255,.02); }
    .expand-toggle { width: 1.5rem; text-align: center; opacity: .5; font-size: .85em; }
    .detail-row td { padding: 0 !important; border-bottom: 1px solid var(--border, #2d3240); }

    /* Candidate detail grid */
    .candidate-detail-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: .75rem; padding: .75rem 1rem 1rem; }
    .candidate-detail-card { background: var(--card-bg, #1a1e26); border: 1px solid var(--border, #2d3240); border-radius: 6px; padding: .85rem; transition: border-color .15s; }
    .candidate-detail-card.is-winner { border: 1px solid gold; background: rgba(255, 215, 0, .04); }
    .candidate-detail-card.is-failed { opacity: .7; }

    .cd-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: .5rem; }
    .cd-name { font-weight: 600; font-size: .95em; }
    .cd-trophy { margin-right: .25rem; }
    .cd-state { font-size: .7em; text-transform: uppercase; letter-spacing: .05em; padding: .15rem .4rem; border-radius: 3px; }
    .cd-state-running { background: rgba(77, 171, 247, .15); color: #4dabf7; }
    .cd-state-completed { background: rgba(81, 207, 102, .15); color: #51cf66; }
    .cd-state-scored { background: rgba(255, 212, 59, .15); color: #ffd43b; }
    .cd-state-winner { background: rgba(255, 215, 0, .2); color: gold; }

    /* Progress pipeline */
    .cd-pipeline { display: flex; align-items: center; gap: .25rem; font-size: .75em; margin-bottom: .65rem; flex-wrap: wrap; }
    .cd-pip { padding: .15rem .35rem; border-radius: 3px; background: rgba(255,255,255,.05); opacity: .45; }
    .cd-pip.pip-done { opacity: 1; background: rgba(81, 207, 102, .12); color: #51cf66; }
    .cd-pip.pip-fail { opacity: 1; background: rgba(255, 107, 107, .12); color: #ff6b6b; }
    .cd-pip.pip-winner { opacity: 1; background: rgba(255, 215, 0, .15); color: gold; }
    .cd-pip-arrow { opacity: .3; }

    /* Score bars */
    .cd-scores { margin-bottom: .5rem; }
    .cd-score-row { display: flex; align-items: center; gap: .5rem; margin-bottom: .3rem; }
    .cd-score-label { width: 5.5rem; font-size: .75em; opacity: .65; text-align: right; }
    .cd-score-bar-bg { flex: 1; height: 6px; background: rgba(255,255,255,.06); border-radius: 3px; overflow: hidden; }
    .cd-score-bar { height: 100%; background: linear-gradient(90deg, #4dabf7, #51cf66); border-radius: 3px; transition: width .3s; }
    .cd-score-val { font-size: .75em; font-family: monospace; width: 2.5rem; opacity: .8; }
    .cd-score-total { text-align: right; font-size: .8em; margin-top: .25rem; opacity: .8; }
    .cd-no-scores { font-size: .8em; opacity: .4; font-style: italic; margin-bottom: .5rem; }

    /* Metrics */
    .cd-metrics { display: flex; gap: .75rem; font-size: .8em; opacity: .7; margin-bottom: .35rem; }
    .cd-metric { font-family: monospace; }

    /* Failure */
    .cd-failure { font-size: .8em; color: #ff6b6b; background: rgba(255,107,107,.06); padding: .35rem .5rem; border-radius: 4px; margin-top: .35rem; }
    .cd-failure-label { font-weight: 600; }

    /* Screenshot */
    .cd-screenshot { margin-top: .5rem; }
    .cd-screenshot-label { font-size: .7em; text-transform: uppercase; letter-spacing: .05em; opacity: .5; margin-bottom: .3rem; }
    .cd-screenshot-img { width: 100%; border-radius: 4px; border: 1px solid var(--border, #2d3240); cursor: pointer; transition: transform .15s; }
    .cd-screenshot-img:hover { transform: scale(1.02); box-shadow: 0 4px 12px rgba(0,0,0,.4); }
</style>

@code {
    private IReadOnlyList<TaskSnapshot> _activeTasks = [];
    private IReadOnlyList<TaskSnapshot> _recentTasks = [];
    private EnabledStrategiesInfo? _enabled;
    private HubConnection? _hub;
    private bool _refreshing;
    private readonly HashSet<string> _expandedTasks = new();

    private void ToggleExpand(string taskId)
    {
        if (!_expandedTasks.Remove(taskId))
            _expandedTasks.Add(taskId);
    }

    private static int TotalScore(CandidateSnapshot c)
        => (c.AcScore ?? 0) + (c.DesignScore ?? 0) + (c.ReadabilityScore ?? 0);

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        try
        {
            _hub = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/agenthub"))
                .WithAutomaticReconnect()
                .Build();
            _hub.On<string, object>("StrategyEvent", async (_, _) => await InvokeAsync(RefreshAsync));
            await _hub.StartAsync();
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "SignalR connection for /strategies failed; falling back to manual refresh");
        }
    }

    private async Task RefreshAsync()
    {
        if (_refreshing) return;
        _refreshing = true;
        try
        {
            var active = StrategiesData.GetActiveTasksAsync();
            var recent = StrategiesData.GetRecentTasksAsync(50);
            var enabled = StrategiesData.GetEnabledAsync();
            await Task.WhenAll(active, recent, enabled);
            _activeTasks = active.Result;
            _recentTasks = recent.Result;
            _enabled = enabled.Result;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Strategies page refresh failed");
        }
        finally
        {
            _refreshing = false;
        }
    }

    private static string FormatElapsed(DateTimeOffset startedAt)
    {
        var d = DateTimeOffset.UtcNow - startedAt;
        if (d.TotalSeconds < 60) return $"{d.TotalSeconds:0}s";
        if (d.TotalMinutes < 60) return $"{(int)d.TotalMinutes}m {d.Seconds}s";
        return $"{(int)d.TotalHours}h {d.Minutes}m";
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
        {
            await _hub.DisposeAsync();
        }
    }
}
