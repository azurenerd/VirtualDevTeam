@code {
    private IReadOnlyList<TaskSnapshot> _activeTasks = [];
    private IReadOnlyList<TaskSnapshot> _recentTasks = [];
    private EnabledStrategiesInfo? _enabled;
    private HubConnection? _hub;
    private PeriodicTimer? _pollTimer;
    private bool _refreshing;
    private readonly HashSet<string> _expandedTasks = new();
    private readonly HashSet<string> _expandedActiveCandidates = new();
    private readonly Dictionary<string, string> _activeTabs = new();
    private string? _lightboxImage;
    private string? _lightboxTitle;
    private ActivityEntry? _selectedActivity;

    private void OpenLightbox(string base64, string title)
    {
        _lightboxImage = base64;
        _lightboxTitle = title;
    }

    private void CloseLightbox()
    {
        _lightboxImage = null;
        _lightboxTitle = null;
    }

    private void ToggleExpand(string taskId)
    {
        if (!_expandedTasks.Remove(taskId))
            _expandedTasks.Add(taskId);
    }

    private void ToggleActiveExpand(string key)
    {
        if (!_expandedActiveCandidates.Remove(key))
            _expandedActiveCandidates.Add(key);
    }

    private void SetTab(string key, string tab)
    {
        _activeTabs[key] = tab;
    }

    private static int TotalScore(CandidateSnapshot c)
        => (c.AcScore ?? 0) + (c.DesignScore ?? 0) + (c.ReadabilityScore ?? 0) + (c.VisualsScore ?? 0);

    private static int MaxScore(CandidateSnapshot c)
        => c.VisualsScore.HasValue ? 40 : 30;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        try
        {
            _hub = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/agenthub"))
                .WithAutomaticReconnect()
                .Build();
            _hub.On<string, object>("StrategyEvent", async (eventName, _) =>
            {
                // Activity events are high-frequency — just re-render from store, no full HTTP refresh.
                if (eventName == StrategyEvents.CandidateActivity)
                {
                    await InvokeAsync(StateHasChanged);
                }
                else
                {
                    await InvokeAsync(RefreshAsync);
                }
            });
            await _hub.StartAsync();
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "SignalR connection for /strategies failed; falling back to manual refresh");
        }

        // Polling fallback: ensures the page always refreshes even when SignalR events
        // don't reach this host (e.g. standalone dashboard at :5051 vs Runner at :5050).
        _pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(3));
        _ = PollLoopAsync();
    }

    private async Task PollLoopAsync()
    {
        try
        {
            while (_pollTimer is not null && await _pollTimer.WaitForNextTickAsync())
            {
                await InvokeAsync(RefreshAsync);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task RefreshAsync()
    {
        if (_refreshing) return;
        _refreshing = true;
        try
        {
            var active = StrategiesData.GetActiveTasksAsync();
            var recent = StrategiesData.GetRecentTasksAsync(50);
            var enabled = StrategiesData.GetEnabledAsync();
            await Task.WhenAll(active, recent, enabled);
            _activeTasks = active.Result;
            _recentTasks = recent.Result;
            _enabled = enabled.Result;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Strategies page refresh failed");
        }
        finally
        {
            _refreshing = false;
        }
    }

    private static string FormatTaskElapsed(TaskSnapshot task)
    {
        // For completed tasks, show actual execution duration (not wall-clock since start)
        if (task.CompletedAt is DateTimeOffset completed)
        {
            var d = completed - task.StartedAt;
            return FormatDuration(d.TotalSeconds);
        }
        // For running tasks, show live wall-clock
        return FormatElapsed(task.StartedAt);
    }

    private static string FormatElapsed(DateTimeOffset startedAt)
    {
        var d = DateTimeOffset.UtcNow - startedAt;
        if (d.TotalSeconds < 60) return $"{d.TotalSeconds:0}s";
        if (d.TotalMinutes < 60) return $"{(int)d.TotalMinutes}m {d.Seconds}s";
        return $"{(int)d.TotalHours}h {d.Minutes}m";
    }

    private static string FormatDuration(double totalSeconds)
    {
        if (totalSeconds < 60) return $"{totalSeconds:0.0}s";
        var ts = TimeSpan.FromSeconds(totalSeconds);
        if (ts.TotalMinutes < 60) return $"{(int)ts.TotalMinutes}m {ts.Seconds}s";
        return $"{(int)ts.TotalHours}h {ts.Minutes}m {ts.Seconds}s";
    }

    private static string FileTypeIcon(string type) => type switch
    {
        "Added" => "+",
        "Modified" => "~",
        "Deleted" => "−",
        "Renamed" => "→",
        _ => "?",
    };

    private static string FormatBytes(int bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:0.1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):0.1} MB",
    };

    private static string StrategyTooltip(string strategyId) => strategyId.ToLowerInvariant() switch
    {
        "baseline" => "Baseline: Direct LLM code generation without external tools — the simplest, fastest approach",
        "copilot-cli" => "GitHub Copilot CLI: Uses the GitHub Copilot CLI tool for autonomous code generation with tool use",
        "squad" => "Squad: External agentic framework by Brady Gaster — a multi-agent virtual dev team",
        "mcp-enhanced" => "MCP Enhanced: Uses Model Context Protocol servers for richer tool access during generation",
        _ => $"{strategyId}: External framework registered as a pluggable code generation strategy",
    };

    private static string StrategyDisplayName(string strategyId) => strategyId.ToLowerInvariant() switch
    {
        "baseline" => "Baseline",
        "copilot-cli" => "GitHub Copilot CLI",
        "squad" => "Squad",
        "mcp-enhanced" => "MCP Enhanced",
        _ => strategyId,
    };

    private static string StateTooltip(CandidateState state) => state switch
    {
        CandidateState.Pending => "Pending: Waiting to start execution",
        CandidateState.Running => "Running: Framework is actively generating code",
        CandidateState.Completed => "Completed: Code generation finished, awaiting evaluation",
        CandidateState.Evaluated => "Evaluated: Gate checks (build, test) have run",
        CandidateState.Scored => "Scored: LLM judge has rated the code quality",
        CandidateState.Winner => "Winner: This candidate was selected as the best solution",
        _ => state.ToString(),
    };

    private static string TruncateText(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text)) return "";
        var cleaned = text.Replace("\r\n", " ").Replace("\n", " ").Replace("\r", " ").Trim();
        return cleaned.Length <= maxLength ? cleaned : cleaned[..maxLength] + "…";
    }

    /// <summary>Groups consecutive activity entries with identical messages into a single row with a count.</summary>
    private sealed record GroupedActivity(ActivityEntry Entry, int Count);

    private static List<GroupedActivity> GroupConsecutive(IEnumerable<ActivityEntry> entries)
    {
        var result = new List<GroupedActivity>();
        GroupedActivity? current = null;
        foreach (var e in entries)
        {
            if (current is not null && current.Entry.Message == e.Message && current.Entry.Category == e.Category)
            {
                current = current with { Count = current.Count + 1, Entry = e };
            }
            else
            {
                if (current is not null) result.Add(current);
                current = new GroupedActivity(e, 1);
            }
        }
        if (current is not null) result.Add(current);
        return result;
    }

    public async ValueTask DisposeAsync()
    {
        _pollTimer?.Dispose();
        _pollTimer = null;
        if (_hub is not null)
        {
            await _hub.DisposeAsync();
        }
    }
