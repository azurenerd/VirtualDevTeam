@page "/agent/{*AgentId}"
@rendermode InteractiveServer
@using AgentSquad.Core.Agents
@using AgentSquad.Core.Agents.Steps
@using AgentSquad.Core.GitHub
@using AgentSquad.Core.Persistence
@using AgentSquad.Dashboard.Services
@using AgentSquad.Orchestrator
@using Microsoft.Extensions.DependencyInjection
@implements IDisposable
@inject IDashboardDataService DataService
@inject IServiceProvider ServiceProvider
@inject NavigationManager Navigation
@inject DashboardMode DashboardMode

<PageTitle>AgentSquad — @(_agent?.DisplayName ?? "Agent Detail")</PageTitle>

<div class="detail-toolbar" data-testid="page-agent-detail">
    <button class="detail-back-btn" @onclick="GoBack" data-testid="agent-detail-back">
        <span class="back-arrow">←</span> Back to Overview
    </button>
</div>

@if (_agent is null)
{
    <div class="empty-state">
        <div class="empty-icon">🔍</div>
        <div class="empty-text">Agent not found</div>
        <div class="empty-sub">Agent "@AgentId" does not exist or has been terminated</div>
    </div>
}
else
{
    var statusClass = $"status-{_agent.Status.ToString().ToLowerInvariant()}";
    var roleClass = $"role-{_agent.Role.ToString().ToLowerInvariant()}";

    <div class="detail-page">
        <!-- Hero Section -->
        <div class="detail-hero">
            <div class="detail-avatar-wrapper">
                <div class="detail-avatar @roleClass">
                    @GetRoleInitials(_agent.Role)
                </div>
                <div class="detail-status-ring @statusClass"></div>
            </div>
            <div class="detail-hero-info">
                <h1 class="detail-agent-name">@_agent.DisplayName</h1>
                <div class="detail-meta-row">
                    <span class="detail-role-badge">@FormatRole(_agent.Role, _agent.Specialty)</span>
                    <span class="detail-model-badge">@_agent.ModelTier</span>
                    <span class="status-badge @statusClass">
                        <span class="status-dot"></span>
                        @_agent.Status
                    </span>
                </div>
                @if (_agent.Capabilities.Count > 0)
                {
                    <div class="agent-capabilities" style="margin-top: 6px;">
                        @foreach (var cap in _agent.Capabilities)
                        {
                            <span class="capability-tag">@cap</span>
                        }
                    </div>
                }
                <div class="detail-status-time">
                    Status since @_agent.LastStatusChange.ToString("HH:mm:ss UTC") · @FormatDuration(DateTime.UtcNow - _agent.LastStatusChange) ago
                </div>
            </div>
            <div class="detail-hero-actions">
                @if (_spawnManager is not null)
                {
                @if (_agent.Status is AgentStatus.Working or AgentStatus.Online)
                {
                    <button class="detail-btn btn-pause" @onclick="PauseAgent" disabled="@_actionInProgress" data-testid="agent-action-pause">
                        ⏸ Pause
                    </button>
                }
                @if (_agent.Status == AgentStatus.Paused)
                {
                    <button class="detail-btn btn-resume" @onclick="ResumeAgent" disabled="@_actionInProgress" data-testid="agent-action-resume">
                        ▶ Resume
                    </button>
                }
                @if (_agent.Status is not (AgentStatus.Terminated or AgentStatus.Offline))
                {
                    <button class="detail-btn btn-terminate" @onclick="TerminateAgent" disabled="@_actionInProgress" data-testid="agent-action-terminate">
                        ⏹ Terminate
                    </button>
                }
                }
            </div>
        </div>

        <!-- Info Grid -->
        <div class="detail-grid">
            <!-- Current Task Card -->
            <div class="detail-card">
                <div class="detail-card-title">Current Task</div>
                <div class="detail-card-body">
                    @if (_agent.Status == AgentStatus.Working || _agent.Status == AgentStatus.Idle)
                    {
                        @if (!string.IsNullOrEmpty(_agent.StatusReason))
                        {
                            <div class="detail-task-active">
                                <span class="detail-field-label">Activity</span>
                                <span class="detail-task-text">@_agent.StatusReason</span>
                            </div>
                        }
                        @if (GetEffectivePrNumber() is { } detectedPr)
                        {
                            var prUrl = $"https://github.com/{DataService.RepositoryFullName}/pull/{detectedPr}";
                            <div class="detail-task-active">
                                <span class="detail-field-label">Pull Request</span>
                                <a class="detail-pr-link" href="@prUrl" target="_blank" rel="noopener noreferrer" data-testid="agent-detail-pr-link" data-pr-number="@detectedPr">
                                    PR #@detectedPr
                                    <span class="external-icon">↗</span>
                                </a>
                            </div>
                        }
                        @if (_agent.Status == AgentStatus.Working)
                        {
                            <div class="detail-task-duration">
                                <span class="detail-field-label">Time on Task</span>
                                <span class="detail-duration-value task-active">@FormatDuration(DateTime.UtcNow - _agent.LastStatusChange)</span>
                            </div>
                        }
                        @if (string.IsNullOrEmpty(_agent.StatusReason) && _agent.AssignedPullRequest is null)
                        {
                            <div class="detail-idle-message">Waiting for work</div>
                        }
                    }
                    else
                    {
                        <div class="detail-idle-message">No task assigned — agent is @_agent.Status.ToString().ToLowerInvariant()</div>
                    }
                </div>
            </div>

            <!-- Token Usage / Cost Card -->
            <div class="detail-card">
                <div class="detail-card-title">Estimated Usage & Cost (MSRP)</div>
                <div class="detail-card-body">
                    <div class="detail-metric-row">
                        <span class="detail-field-label">Prompt Tokens</span>
                        <span class="detail-metric-value">@FormatTokenCount(_agent.EstPromptTokens)</span>
                    </div>
                    <div class="detail-metric-row">
                        <span class="detail-field-label">Completion Tokens</span>
                        <span class="detail-metric-value">@FormatTokenCount(_agent.EstCompletionTokens)</span>
                    </div>
                    <div class="detail-metric-row">
                        <span class="detail-field-label">AI Calls</span>
                        <span class="detail-metric-value">@_agent.AiCalls</span>
                    </div>
                    <div class="detail-metric-row">
                        <span class="detail-field-label">Est. Cost</span>
                        <span class="detail-metric-value cost-value">@FormatCost(_agent.EstimatedCost)</span>
                    </div>
                    @if (_agent.ActiveModel is { Length: > 0 })
                    {
                        <div class="detail-metric-row">
                            <span class="detail-field-label">Model</span>
                            <span class="detail-metric-value mono">@_agent.ActiveModel</span>
                        </div>
                    }
                    <div class="detail-placeholder-note">Estimates based on ~4 chars/token × MSRP pricing</div>
                </div>
            </div>

            <!-- Agent Info Card -->
            <div class="detail-card">
                <div class="detail-card-title">Agent Info</div>
                <div class="detail-card-body">
                    <div class="detail-metric-row">
                        <span class="detail-field-label">Agent ID</span>
                        <span class="detail-metric-value mono">@_agent.Id</span>
                    </div>
                    <div class="detail-metric-row">
                        <span class="detail-field-label">Created</span>
                        <span class="detail-metric-value">@_agent.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss UTC")</span>
                    </div>
                    <div class="detail-metric-row">
                        <span class="detail-field-label">Model Tier</span>
                        <span class="detail-metric-value">@_agent.ModelTier</span>
                    </div>
                </div>
            </div>
        </div>

        @* ── Current Task Steps (grouped by task) ── *@
        @if (_taskGroups.Count > 0)
        {
            var pct = _stepTotal > 0 ? (int)(100.0 * _stepCompleted / _stepTotal) : 0;
            <div class="step-card">
                <div class="step-card-header">
                    <div class="step-card-title">Task Steps</div>
                    <span class="step-card-progress-label">@_stepCompleted / @_stepTotal steps</span>
                </div>
                <div class="step-progress-bar">
                    <div class="step-progress-fill" style="width: @(pct)%"></div>
                </div>
                @foreach (var group in _taskGroups)
                {
                    // Auto-expand active/waiting groups UNLESS the user explicitly collapsed them.
                    var userExplicitlyCollapsed = _userCollapsedDetailGroups.Contains(group.TaskId);
                    var isGroupExpanded = !userExplicitlyCollapsed
                        && (_expandedDetailGroups.Contains(group.TaskId)
                            || group.Status == AgentTaskStepStatus.InProgress
                            || group.Status == AgentTaskStepStatus.WaitingOnHuman);
                    var groupPct = group.Total > 0 ? (int)(100.0 * group.Completed / group.Total) : 0;

                    <div class="step-task-group @(group.Status == AgentTaskStepStatus.InProgress ? "step-task-active" : "")">
                        <div class="step-task-header" @onclick="() => ToggleDetailGroup(group.TaskId)">
                            <span class="step-task-chevron @(isGroupExpanded ? "expanded" : "")">▶</span>
                            <span class="step-task-icon">@GetTaskGroupIcon(group.Status)</span>
                            <span class="step-task-name">@group.DisplayName</span>
                            <div class="step-task-meta">
                                <span class="step-task-progress">@group.Completed/@group.Total</span>
                                @if (group.TotalElapsed.HasValue)
                                {
                                    <span class="step-elapsed">@FormatStepDuration(group.TotalElapsed.Value)</span>
                                }
                                @if (group.TotalLlmCalls > 0)
                                {
                                    <span class="step-llm-count">@group.TotalLlmCalls calls</span>
                                }
                            </div>
                        </div>
                        @if (isGroupExpanded)
                        {
                            <div class="step-task-body">
                                <div class="step-task-progress-bar">
                                    <div class="step-progress-fill" style="width: @(groupPct)%"></div>
                                </div>
                                <div class="step-list">
                                    @{ var topLevelSteps = group.Steps.Where(s => s.ParentStepId is null).ToList(); }
                                    @foreach (var step in topLevelSteps)
                                    {
                                        @if (step.IsContainer)
                                        {
                                            // Container step: render as an expandable sub-section with child steps
                                            var containerId = $"container-{step.Id}";
                                            var containerExpanded = _expandedContainerSteps.Contains(step.Id)
                                                || step.Status == AgentTaskStepStatus.InProgress;
                                            var childSteps = group.Steps.Where(s => s.ParentStepId == step.Id).ToList();
                                            var childCompleted = childSteps.Count(s => s.Status is AgentTaskStepStatus.Completed or AgentTaskStepStatus.Skipped);
                                            <div class="step-item step-container @(step.Status == AgentTaskStepStatus.InProgress ? "step-active" : "")" title="@BuildStepTooltip(step)">
                                                <div class="step-container-header" @onclick="() => ToggleContainerStep(step.Id)">
                                                    <span class="step-container-chevron @(containerExpanded ? "expanded" : "")">▶</span>
                                                    <span class="step-icon">@GetStepIcon(step.Status)</span>
                                                    <span class="step-name">@step.Name</span>
                                                    <div class="step-meta">
                                                        <span class="step-child-count">@childCompleted/@childSteps.Count strategies</span>
                                                        @if (step.Elapsed.HasValue)
                                                        {
                                                            <span class="step-elapsed">@FormatStepDuration(step.Elapsed.Value)</span>
                                                        }
                                                        @if (!string.IsNullOrEmpty(step.Description))
                                                        {
                                                            <span class="step-strategy-winner">@step.Description</span>
                                                        }
                                                    </div>
                                                </div>
                                                @if (containerExpanded && childSteps.Count > 0)
                                                {
                                                    <div class="step-children">
                                                        @foreach (var child in childSteps)
                                                        {
                                                            <div class="step-item step-child @GetStrategyStepClass(child)" title="@BuildStepTooltip(child)">
                                                                <span class="step-icon">@GetStrategyIcon(child)</span>
                                                                <span class="step-name">@child.Name</span>
                                                                <div class="step-meta">
                                                                    @if (child.Elapsed.HasValue)
                                                                    {
                                                                        <span class="step-elapsed">@FormatStepDuration(child.Elapsed.Value)</span>
                                                                    }
                                                                    @if (!string.IsNullOrEmpty(child.Description) && child.Status == AgentTaskStepStatus.Failed)
                                                                    {
                                                                        <span class="step-failure-reason" title="@child.Description">❌ @TruncateText(child.Description, 60)</span>
                                                                    }
                                                                </div>
                                                                @if (child.SubSteps.Count > 0)
                                                                {
                                                                    <div class="step-substeps">
                                                                        @foreach (var sub in child.SubSteps)
                                                                        {
                                                                            <div class="step-substep">@sub.Description</div>
                                                                        }
                                                                    </div>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            // Regular (leaf) step — original rendering
                                            <div class="step-item @(step.Status == AgentTaskStepStatus.InProgress ? "step-active" : "")" title="@BuildStepTooltip(step)">
                                                <span class="step-icon">@GetStepIcon(step.Status)</span>
                                                <span class="step-name @(step.Status == AgentTaskStepStatus.Pending ? "step-name-pending" : "")">@step.Name</span>
                                                <div class="step-meta">
                                                    @if (!string.IsNullOrEmpty(step.ModelUsed) && step.LlmCallCount > 0)
                                                    {
                                                        <span class="step-model-badge">@step.ModelUsed</span>
                                                    }
                                                    @if (step.Elapsed.HasValue)
                                                    {
                                                        <span class="step-elapsed">@FormatStepDuration(step.Elapsed.Value)</span>
                                                    }
                                                    @if (step.LlmCallCount > 0)
                                                    {
                                                        <span class="step-llm-count">@step.LlmCallCount calls</span>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                @{ var totalLlm = _taskGroups.Sum(g => g.TotalLlmCalls);
                   var totalCost = _taskGroups.Sum(g => g.TotalCost); }
                @if (totalLlm > 0 || totalCost > 0)
                {
                    <div class="step-totals">
                        <span class="step-totals-label">Totals</span>
                        @if (totalLlm > 0)
                        {
                            <span class="step-llm-count">@totalLlm LLM calls</span>
                        }
                        @if (totalCost > 0)
                        {
                            <span class="step-cost">@FormatStepCost(totalCost)</span>
                        }
                    </div>
                }
            </div>
        }

        <!-- Activity Log -->
        <div class="detail-card detail-log-card">
            <div class="detail-card-header-row">
                <div class="detail-card-title">Activity Log</div>
                <div class="detail-log-filters">
                    <button class="log-filter-btn @(_activeFilter is null ? "active" : "")" @onclick="() => SetFilter(null)">
                        All
                    </button>
                    <button class="log-filter-btn filter-task @(_activeFilter == "task" ? "active" : "")" @onclick='() => SetFilter("task")'>
                        Task
                    </button>
                    <button class="log-filter-btn filter-status @(_activeFilter == "status" ? "active" : "")" @onclick='() => SetFilter("status")'>
                        Status
                    </button>
                    <button class="log-filter-btn filter-system @(_activeFilter == "system" ? "active" : "")" @onclick='() => SetFilter("system")'>
                        System
                    </button>
                    <button class="log-filter-btn filter-message @(_activeFilter == "message" ? "active" : "")" @onclick='() => SetFilter("message")'>
                        Message
                    </button>
                    <button class="log-filter-btn filter-github @(_activeFilter == "github" ? "active" : "")" @onclick='() => SetFilter("github")'>
                        GitHub
                    </button>
                </div>
            </div>
            <div class="detail-card-body">
                <div class="detail-log-list">
                    @foreach (var entry in GetFilteredLog())
                    {
                        <div class="detail-log-entry">
                            <span class="log-timestamp">@entry.Timestamp.ToString("HH:mm:ss")</span>
                            <span class="log-badge log-badge-@entry.EventType">@entry.EventType</span>
                            <span class="log-message">@entry.Details</span>
                        </div>
                    }
                    @if (GetFilteredLog().Count == 0)
                    {
                        <div class="detail-idle-message">
                            @if (_activeFilter is not null)
                            {
                                <span>No @_activeFilter events recorded</span>
                            }
                            else
                            {
                                <span>No activity recorded yet</span>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string AgentId { get; set; } = "";

    private AgentSnapshot? _agent;
    private bool _actionInProgress;
    private List<ActivityLogEntry> _activityLog = [];
    private string? _activeFilter;
    private System.Threading.Timer? _refreshTimer;

    // Step tracking state
    private IAgentTaskTracker? _taskTracker;
    private HttpClient? _stepHttp;
    private List<AgentTaskGroup> _taskGroups = [];
    private HashSet<string> _expandedDetailGroups = new();
    // Tracks task groups the user has explicitly collapsed so we stop force-expanding
    // them just because their status is InProgress/WaitingOnHuman.
    private HashSet<string> _userCollapsedDetailGroups = new();
    // Tracks which container steps (strategy groups) are expanded
    private HashSet<string> _expandedContainerSteps = new();
    private int _stepCompleted;
    private int _stepTotal;

    protected override void OnInitialized()
    {
        _spawnManager = ServiceProvider.GetService<AgentSpawnManager>();
        if (!DashboardMode.IsStandalone)
        {
            _taskTracker = ServiceProvider.GetService<IAgentTaskTracker>();
        }
        if (_taskTracker is null)
        {
            var factory = ServiceProvider.GetService<IHttpClientFactory>();
            _stepHttp = factory?.CreateClient("RunnerApi");
        }
        RefreshData();
        DataService.OnChange += OnDataChanged;

        // Live-updating timer for duration display
        _refreshTimer = new System.Threading.Timer(_ =>
        {
            _ = InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    protected override void OnParametersSet()
    {
        RefreshData();
    }

    private void RefreshData()
    {
        _agent = DataService.GetAgentSnapshot(AgentId);
        _ = LoadActivityLogAsync();
        _ = LoadStepsAsync();
    }

    private async Task LoadStepsAsync()
    {
        try
        {
            if (_taskTracker is not null)
            {
                _taskGroups = _taskTracker.GetGroupedSteps(AgentId).ToList();
                (_stepCompleted, _stepTotal) = _taskTracker.GetProgress(AgentId);
            }
            else if (_stepHttp is not null)
            {
                var options = new System.Text.Json.JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                };
                var groupResp = await _stepHttp.GetAsync($"/api/steps/{AgentId}/grouped");
                if (groupResp.IsSuccessStatusCode)
                {
                    var groups = await groupResp.Content.ReadFromJsonAsync<List<AgentTaskGroup>>(options);
                    if (groups is not null) _taskGroups = groups;
                }

                var progResp = await _stepHttp.GetAsync($"/api/steps/{AgentId}/progress");
                if (progResp.IsSuccessStatusCode)
                {
                    var progress = await progResp.Content.ReadFromJsonAsync<StepProgressDto>(options);
                    if (progress is not null)
                    {
                        _stepCompleted = progress.Completed;
                        _stepTotal = progress.Total;
                    }
                }
            }
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"LoadStepsAsync failed for {AgentId}: {ex.Message}");
        }
    }

    private record StepProgressDto(int Completed, int Total);

    private async Task LoadActivityLogAsync()
    {
        try
        {
            var entries = await DataService.GetActivityLogAsync(AgentId, 200);
            _activityLog = entries.ToList();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Silently handle — the log will just be empty
        }
    }

    private List<ActivityLogEntry> GetFilteredLog()
    {
        if (_activeFilter is null)
            return _activityLog;

        return _activityLog
            .Where(e => e.EventType.Equals(_activeFilter, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private void SetFilter(string? filter)
    {
        _activeFilter = filter;
    }

    private async void OnDataChanged()
    {
        _agent = DataService.GetAgentSnapshot(AgentId);
        await LoadActivityLogAsync();
    }

    private void GoBack() => Navigation.NavigateTo("/");

    private AgentSpawnManager? _spawnManager;

    private async Task PauseAgent()
    {
        if (_spawnManager is null) return;
        _actionInProgress = true;
        try
        {
            await _spawnManager.PauseAgentAsync(AgentId);
        }
        finally
        {
            _actionInProgress = false;
        }
    }

    private async Task ResumeAgent()
    {
        if (_spawnManager is null) return;
        _actionInProgress = true;
        try
        {
            await _spawnManager.ResumeAgentAsync(AgentId);
        }
        finally
        {
            _actionInProgress = false;
        }
    }

    private async Task TerminateAgent()
    {
        if (_spawnManager is null) return;
        _actionInProgress = true;
        try
        {
            await _spawnManager.TerminateAgentAsync(AgentId);
        }
        finally
        {
            _actionInProgress = false;
        }
    }

    private static string GetRoleInitials(AgentRole role) => role switch
    {
        AgentRole.ProgramManager => "PM",
        AgentRole.Researcher => "RS",
        AgentRole.Architect => "AR",
        AgentRole.SoftwareEngineer => "SWE",
        AgentRole.TestEngineer => "TE",
        _ => "??"
    };

    private static string FormatRole(AgentRole role, string? specialty = null) => role switch
    {
        AgentRole.ProgramManager => "Program Manager",
        AgentRole.Researcher => "Researcher",
        AgentRole.Architect => "Architect",
        AgentRole.SoftwareEngineer => "Software Engineer",
        AgentRole.TestEngineer => "Test Engineer",
        AgentRole.Custom when !string.IsNullOrEmpty(specialty) => "SME Specialist",
        _ => role.ToString()
    };

    private static string FormatDuration(TimeSpan ts) => ts.TotalHours >= 1
        ? $"{ts.Hours}h {ts.Minutes}m"
        : ts.TotalMinutes >= 1
            ? $"{ts.Minutes}m {ts.Seconds}s"
            : $"{ts.Seconds}s";

    private static string FormatTokenCount(int tokens) => tokens switch
    {
        0 => "—",
        < 1000 => tokens.ToString("N0"),
        < 1_000_000 => $"{tokens / 1000.0:N1}K",
        _ => $"{tokens / 1_000_000.0:N2}M"
    };

    private string? GetEffectivePrNumber()
        => ExtractPrNumber(_agent?.StatusReason) ?? _agent?.AssignedPullRequest;

    private static string? ExtractPrNumber(string? statusReason)
    {
        if (statusReason is null) return null;
        var match = System.Text.RegularExpressions.Regex.Match(statusReason, @"PR #(\d+)");
        return match.Success ? match.Groups[1].Value : null;
    }

    private static string FormatCost(decimal cost) => cost switch
    {
        0m => "—",
        < 0.01m => $"< $0.01",
        < 1m => cost.ToString("$0.00"),
        _ => cost.ToString("$#,##0.00")
    };

    private static string GetStepIcon(AgentTaskStepStatus status) => status switch
    {
        AgentTaskStepStatus.Completed => "✅",
        AgentTaskStepStatus.InProgress => "🔄",
        AgentTaskStepStatus.Pending => "⬜",
        AgentTaskStepStatus.Failed => "❌",
        AgentTaskStepStatus.Skipped => "⏭️",
        AgentTaskStepStatus.WaitingOnHuman => "⏳",
        _ => "⬜"
    };

    private static string GetTaskGroupIcon(AgentTaskStepStatus status) => status switch
    {
        AgentTaskStepStatus.Completed => "✅",
        AgentTaskStepStatus.InProgress => "🔨",
        AgentTaskStepStatus.WaitingOnHuman => "⏳",
        AgentTaskStepStatus.Failed => "❌",
        _ => "⬜"
    };

    private void ToggleDetailGroup(string taskId)
    {
        // Determine the effective current state so the click always flips it,
        // even when the group is force-expanded due to InProgress status.
        var group = _taskGroups.FirstOrDefault(g => g.TaskId == taskId);
        var autoExpand = group is not null
            && (group.Status == AgentTaskStepStatus.InProgress
                || group.Status == AgentTaskStepStatus.WaitingOnHuman);
        var userCollapsed = _userCollapsedDetailGroups.Contains(taskId);
        var currentlyExpanded = !userCollapsed
            && (_expandedDetailGroups.Contains(taskId) || autoExpand);

        if (currentlyExpanded)
        {
            // Collapse: clear any manual-expand, and record explicit collapse so auto-expand stops.
            _expandedDetailGroups.Remove(taskId);
            if (autoExpand)
                _userCollapsedDetailGroups.Add(taskId);
        }
        else
        {
            // Expand: clear any user-collapse, then add to manual-expand set.
            _userCollapsedDetailGroups.Remove(taskId);
            _expandedDetailGroups.Add(taskId);
        }
    }

    private void ToggleContainerStep(string stepId)
    {
        if (!_expandedContainerSteps.Remove(stepId))
            _expandedContainerSteps.Add(stepId);
    }

    private static string GetStrategyIcon(AgentTaskStep child) => child.Status switch
    {
        AgentTaskStepStatus.InProgress => "🔬",
        AgentTaskStepStatus.Completed => "🏆",
        AgentTaskStepStatus.Skipped => "⏭️",
        AgentTaskStepStatus.Failed => "💥",
        _ => "🧪"
    };

    private static string GetStrategyStepClass(AgentTaskStep child) => child.Status switch
    {
        AgentTaskStepStatus.InProgress => "step-active step-strategy-running",
        AgentTaskStepStatus.Completed => "step-strategy-winner",
        AgentTaskStepStatus.Skipped => "step-strategy-skipped",
        AgentTaskStepStatus.Failed => "step-strategy-failed",
        _ => ""
    };

    private static string TruncateText(string text, int maxLength)
        => text.Length <= maxLength ? text : text[..maxLength] + "…";

    private static string FormatStepDuration(TimeSpan ts) => ts.TotalMinutes >= 1
        ? $"{ts.Minutes}m {ts.Seconds}s"
        : $"{ts.TotalSeconds:F1}s";

    private static string FormatStepCost(decimal cost) => cost switch
    {
        < 0.01m => "< $0.01",
        < 1m => cost.ToString("$0.00"),
        _ => cost.ToString("$#,##0.00")
    };

    private static string BuildStepTooltip(AgentSquad.Core.Agents.Steps.AgentTaskStep step)
    {
        var parts = new List<string> { step.Name };
        if (step.Status != AgentSquad.Core.Agents.Steps.AgentTaskStepStatus.Pending)
            parts.Add($"Status: {step.Status}");
        if (step.Elapsed.HasValue)
            parts.Add($"Duration: {FormatStepDuration(step.Elapsed.Value)}");
        if (!string.IsNullOrEmpty(step.ModelUsed))
            parts.Add($"Model: {step.ModelUsed}");
        if (step.LlmCallCount > 0)
            parts.Add($"LLM calls: {step.LlmCallCount}");
        if (step.EstimatedCost > 0)
            parts.Add($"Cost: {FormatStepCost(step.EstimatedCost)}");
        if (!string.IsNullOrEmpty(step.Description))
            parts.Add(step.Description.Length > 150 ? step.Description[..150] + "…" : step.Description);
        return string.Join("\n", parts);
    }

    public void Dispose()
    {
        DataService.OnChange -= OnDataChanged;
        _refreshTimer?.Dispose();
    }
}
