    // Human Interaction helpers
    private void ApplyHumanPreset(HumanInteractionPreset preset)
    {
        _config?.HumanInteraction.ApplyPreset(preset);
        StateHasChanged();
    }

    private bool IsPresetActive(HumanInteractionPreset preset)
    {
        if (_config is null) return false;
        var hi = _config.HumanInteraction;
        if (!hi.Enabled) return preset == HumanInteractionPreset.FullAuto;
        return preset switch
        {
            HumanInteractionPreset.Supervised =>
                hi.Enabled && hi.Gates.Values.Any(g => g.RequiresHuman) && hi.Gates.Values.Any(g => !g.RequiresHuman),
            HumanInteractionPreset.FullControl =>
                hi.Enabled && hi.Gates.Values.All(g => g.RequiresHuman),
            _ => false
        };
    }

    private GateConfig GetOrCreateGate(string gateId)
    {
        if (_config is null) return new GateConfig();
        if (!_config.HumanInteraction.Gates.TryGetValue(gateId, out var gate))
        {
            gate = new GateConfig();
            _config.HumanInteraction.Gates[gateId] = gate;
        }
        return gate;
    }

    /// <summary>Deep-copy via JSON round-trip so edits don't touch live config.</summary>
    private static AgentSquadConfig DeepCopy(AgentSquadConfig src)
    {
        var json = System.Text.Json.JsonSerializer.Serialize(src);
        return System.Text.Json.JsonSerializer.Deserialize<AgentSquadConfig>(json) ?? new();
    }

