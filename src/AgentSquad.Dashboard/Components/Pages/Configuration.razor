@page "/configuration"
@using AgentSquad.Core.Configuration
@using AgentSquad.Core.Workspace
@using AgentSquad.Dashboard.Services
@using Microsoft.Extensions.Options
@using AgentSquad.Core.Prompts
@using AgentSquad.Core.GitHub.Models
@inject IConfigurationService ConfigService
@inject IDashboardDataService DataService
@inject IPromptTemplateService PromptService
@inject IOptions<AgentSquadConfig> SquadConfig
@inject ILogger<Configuration> Logger
@rendermode InteractiveServer

<div class="page-header">
    <h1 class="page-title">⚙️ Configuration</h1>
    <div class="header-badges">
        @if (_saveSuccess)
        {
            <span class="badge badge-success">✓ Saved</span>
        }
        @if (_saveError is not null)
        {
            <span class="badge badge-error">⚠ Error</span>
        }
    </div>
</div>

@if (_loading)
{
    <div class="config-loading">Loading configuration...</div>
}
else if (_config is not null)
{
    <div class="config-container">
        @* ═══════════════════════════════════════════════════════════════════
           CONFIGURATION EDITOR
           ═══════════════════════════════════════════════════════════════════ *@
        <div class="config-section-header">
            <span class="config-section-icon">📝</span>
            <div>
                <h2 class="config-section-title">Application Settings</h2>
                <p class="config-section-desc">Configure AgentSquad behavior, models, and agent settings. Changes are saved to appsettings.json.</p>
            </div>
        </div>

        @* ── Project Settings ── *@
        <div class="config-card">
            <div class="config-card-header" @onclick="() => _projectExpanded = !_projectExpanded">
                <span class="config-card-icon">🏗️</span>
                <span class="config-card-title">Project</span>
                <span class="config-card-chevron @(_projectExpanded ? "expanded" : "")">▶</span>
            </div>
            @if (_projectExpanded)
            {
                <div class="config-card-body">
                    <div class="config-field">
                        <label title="The display name for this project. Used in logs, dashboard, and agent conversations.">Project Name</label>
                        <input type="text" @bind="_config.Project.Name" class="config-input"
                            title="A short, human-readable name for the project. Shown in the dashboard header and agent logs." />
                    </div>
                    <div class="config-field">
                        <label title="A brief description of what the project does. Provided to agents as context for code generation and decision-making.">Description</label>
                        <textarea @bind="_config.Project.Description" class="config-textarea" rows="3"
                            title="Describe the project's purpose, tech stack, and goals. Agents read this to understand what they're building."></textarea>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="The GitHub repository in 'owner/repo' format (e.g., 'myorg/myproject'). All agent PRs, issues, and code go here.">GitHub Repo</label>
                            <input type="text" @bind="_config.Project.GitHubRepo" class="config-input" placeholder="owner/repo"
                                title="Format: owner/repo. This is the target repository where agents create PRs, issues, and push code." />
                        </div>
                        <div class="config-field">
                            <label title="The primary branch (e.g., 'main' or 'master'). Agent PRs target this branch and file operations reference it.">Default Branch</label>
                            <input type="text" @bind="_config.Project.DefaultBranch" class="config-input"
                                title="The main/trunk branch name. Agent PRs will target this branch." />
                        </div>
                    </div>
                    <div class="config-field">
                        <label title="GitHub Personal Access Token (PAT) used for all GitHub API operations. Needs repo, issues, and workflow scopes.">GitHub Token (PAT)</label>
                        <div class="config-pat-row">
                            <div class="config-secret-field">
                                <input type="@(_showToken ? "text" : "password")" @bind="_config.Project.GitHubToken" class="config-input"
                                    title="A GitHub PAT with repo, issues, and workflow scopes. Used for creating PRs, issues, reading code, and cleanup operations." />
                                <button class="config-secret-toggle" @onclick="() => _showToken = !_showToken"
                                    title="@(_showToken ? "Hide token" : "Show token")">@(_showToken ? "🙈" : "👁️")</button>
                            </div>
                            <button class="config-validate-btn @(_patValidation?.Success == true ? "config-validate-success" : "")"
                                @onclick="ValidatePat" disabled="@_validatingPat"
                                title="Test the PAT token against the repo specified above to verify access.">
                                @if (_validatingPat)
                                {
                                    <span class="config-spinner config-spinner-sm"></span>
                                }
                                else if (_patValidation?.Success == true)
                                {
                                    <span>✓ Verified</span>
                                }
                                else
                                {
                                    <span>🔑 Verify Access</span>
                                }
                            </button>
                        </div>
                        @if (_patIsFromSecrets)
                        {
                            <p class="config-hint">🔐 Token loaded from <strong>User Secrets</strong> (not stored in appsettings.json). Manage via: <code>dotnet user-secrets set "AgentSquad:Project:GitHubToken" "your-pat"</code></p>
                        }
                        @if (_patValidation is not null)
                        {
                            @if (_patValidation.Success)
                            {
                                <div class="config-pat-result config-pat-success">
                                    <span>✅ Connected as <strong>@_patValidation.AuthenticatedUser</strong> → <strong>@_patValidation.RepoName</strong></span>
                                    <span class="config-pat-detail">@(_patValidation.IsPrivate ? "🔒 Private" : "🌐 Public") · Branch: @_patValidation.DefaultBranch</span>
                                    @if (!string.IsNullOrEmpty(_patValidation.RepoDescription))
                                    {
                                        <span class="config-pat-desc">@_patValidation.RepoDescription</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="config-pat-result config-pat-error">
                                    <span>❌ @_patValidation.Error</span>
                                </div>
                            }
                        }
                    </div>
                    <div class="config-field">
                        <label title="The primary technology stack (e.g., '.NET 8', 'React + Node.js'). Agents use this to pick appropriate frameworks, patterns, and test tools.">Tech Stack</label>
                        <input type="text" @bind="_config.Project.TechStack" class="config-input"
                            title="e.g., '.NET 8', 'React + TypeScript', 'Python FastAPI'. Guides agent decisions about project structure, dependencies, and test frameworks." />
                    </div>
                    <div class="config-field">
                        <label title="Your GitHub username. Used to identify executive-level requests in issues and for at-mentions in PR reviews.">Executive GitHub Username</label>
                        <input type="text" @bind="_config.Project.ExecutiveGitHubUsername" class="config-input"
                            title="The GitHub username of the project lead. Issues created by this user get 'executive-request' priority." />
                    </div>
                    <div class="config-field">
                        <label title="Optional custom prompt for the Researcher agent. Leave empty to use the auto-generated research prompt based on project description.">Research Prompt <span class="config-hint">(optional — overrides default)</span></label>
                        <textarea @bind="_config.Project.ResearchPrompt" class="config-textarea" rows="3" placeholder="Leave empty for auto-generated prompt"
                            title="Custom instructions for the Researcher agent. If blank, a prompt is auto-generated from the project description. Use this to focus research on specific topics."></textarea>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field" title="When enabled, Researcher/PM/Architect produce minimal 1-paragraph documents using only the project description and tech stack. Dramatically reduces startup time for testing.">
                            <label>Quick Document Creation</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.Project.QuickDocumentCreation" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                        <div class="config-field">
                            <label title="SHA of the baseline commit representing the clean repo state. Used by cleanup to reset files via Git Trees API. Leave empty to use preserve-files fallback.">Baseline Commit SHA <span class="config-hint">(optional)</span></label>
                            <input type="text" @bind="_config.Project.BaselineCommitSha" class="config-input" placeholder="e.g. 0196a03..."
                                title="The commit SHA to restore files from during cleanup. Set after initial repo setup." />
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── Copilot CLI Settings ── *@
        <div class="config-card">
            <div class="config-card-header" @onclick="() => _copilotExpanded = !_copilotExpanded">
                <span class="config-card-icon">🤖</span>
                <span class="config-card-title">Copilot CLI</span>
                <span class="config-card-chevron @(_copilotExpanded ? "expanded" : "")">▶</span>
            </div>
            @if (_copilotExpanded)
            {
                <div class="config-card-body">
                    <div class="config-field-row">
                        <div class="config-field" title="When enabled, all AI calls route through the GitHub Copilot CLI instead of direct API keys. Requires 'copilot' CLI v1.0.18+ installed.">
                            <label>Enabled</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.CopilotCli.Enabled" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                        <div class="config-field" title="Uses a faster, cheaper model for non-critical operations like status updates and simple classifications. Reduces cost without sacrificing quality on important tasks.">
                            <label>Fast Mode</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.CopilotCli.FastMode" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                        <div class="config-field" title="Sends the entire multi-turn conversation as a single prompt instead of multiple turns. Can improve coherence but uses more tokens per request.">
                            <label>Single-Pass Mode</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.CopilotCli.SinglePassMode" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field" title="Suppresses CLI banners, progress indicators, and decorative output. Cleaner logs but less visibility into what the CLI is doing.">
                            <label>Silent Mode</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.CopilotCli.SilentMode" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                        <div class="config-field" title="Uses '--output-format json' for structured JSONL responses. More reliable parsing but some models may not support it.">
                            <label>JSON Output</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.CopilotCli.JsonOutput" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                        <div class="config-field" title="Automatically responds 'y' to any interactive prompts from the CLI. Required for unattended operation. Disable only for debugging.">
                            <label>Auto-Approve Prompts</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.CopilotCli.AutoApprovePrompts" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="The default AI model for standard operations. Uses dot notation (e.g., 'claude-sonnet-4.6', 'gpt-5.2').">Model Name</label>
                            <input type="text" @bind="_config.CopilotCli.ModelName" class="config-input"
                                title="Default model ID. Examples: claude-sonnet-4.6, claude-opus-4.6, gpt-5.2. Model IDs use dots, not dashes." />
                        </div>
                        <div class="config-field">
                            <label title="A smaller/faster model used when Fast Mode is enabled. Typically a 'haiku' or 'mini' variant.">Fast Mode Model</label>
                            <input type="text" @bind="_config.CopilotCli.FastModeModel" class="config-input"
                                title="Cheaper model for fast-mode operations. Examples: claude-haiku-4.5, gpt-5.4-mini." />
                        </div>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="Maximum number of simultaneous Copilot CLI processes. Higher = more parallelism but more system resources.">Max Concurrent Requests</label>
                            <input type="number" @bind="_config.CopilotCli.MaxConcurrentRequests" class="config-input config-input-number" min="1" max="20"
                                title="Controls the SemaphoreSlim limit for parallel CLI invocations. Default: 4. Increase if agents are waiting too long for AI responses." />
                        </div>
                        <div class="config-field">
                            <label title="How long to wait for a single CLI request before timing out. Complex prompts (architecture, code generation) may need more time.">Request Timeout (seconds)</label>
                            <input type="number" @bind="_config.CopilotCli.RequestTimeoutSeconds" class="config-input config-input-number" min="30" max="7200"
                                title="Per-request timeout. Default: 300s (5 min). Increase for complex multi-turn conversations. Max: 7200s (2 hours)." />
                        </div>
                        <div class="config-field">
                            <label title="Number of automatic retries on transient failures (timeouts, rate limits). Each retry waits progressively longer.">Max Retries</label>
                            <input type="number" @bind="_config.CopilotCli.MaxRetries" class="config-input config-input-number" min="0" max="10"
                                title="Retry count for failed CLI invocations. Default: 2. Set to 0 to fail fast on errors." />
                        </div>
                    </div>
                    <div class="config-field">
                        <label title="Full path to the 'copilot' executable. Usually auto-detected from PATH. Set manually if installed in a non-standard location.">Executable Path</label>
                        <input type="text" @bind="_config.CopilotCli.ExecutablePath" class="config-input"
                            title="Override the CLI executable location. Leave as 'copilot' to use PATH discovery. Example: 'C:\\Program Files\\GitHub CLI\\copilot.exe'" />
                    </div>
                    <div class="config-field">
                        <label title="Controls how much 'thinking' the model does before responding. Higher = better quality but slower and more expensive.">Reasoning Effort</label>
                        <select @bind="_copilotReasoningEffort" class="config-select"
                            title="Model reasoning depth. Low: fastest/cheapest. Medium: balanced. High: thorough. XHigh: maximum quality (slowest).">
                            <option value="">(default)</option>
                            <option value="low">Low</option>
                            <option value="medium">Medium</option>
                            <option value="high">High</option>
                            <option value="xhigh">XHigh</option>
                        </select>
                    </div>
                </div>
            }
        </div>

        @* ── Agent Settings ── *@
        <div class="config-card">
            <div class="config-card-header" @onclick="() => _agentsExpanded = !_agentsExpanded">
                <span class="config-card-icon">👥</span>
                <span class="config-card-title">Agents</span>
                <span class="config-card-chevron @(_agentsExpanded ? "expanded" : "")">▶</span>
            </div>
            @if (_agentsExpanded)
            {
                <div class="config-card-body">
                    <p class="config-hint" style="margin-bottom: 12px;" title="Each agent can be assigned a model tier, role customization, MCP servers, and knowledge links. Click an agent to expand its configuration.">
                        Configure each agent's model tier, role behavior, MCP tools, and knowledge sources. Click an agent to expand.
                    </p>
                    <div class="config-agent-grid">
                        @foreach (var agent in GetAgentEntries())
                        {
                            var agentName = agent.Name;
                            var isExpanded = IsAgentPanelExpanded(agentName);
                            <div class="config-agent-accordion">
                                <div class="config-agent-row" title="@GetAgentTooltip(agentName)" @onclick="() => ToggleAgentPanel(agentName)" style="cursor: pointer;">
                                    <div class="config-agent-name">
                                        <span class="config-agent-chevron @(isExpanded ? "expanded" : "")">▶</span>
                                        @agentName
                                        @if (!string.IsNullOrWhiteSpace(agent.Config.RoleDescription) || agent.Config.McpServers.Count > 0 || agent.Config.KnowledgeLinks.Count > 0)
                                        {
                                            <span class="config-agent-customized" title="This agent has custom role configuration">✦</span>
                                        }
                                    </div>
                                    <div class="config-agent-controls" @onclick:stopPropagation="true">
                                        <select @bind="agent.Config.ModelTier" class="config-select config-select-sm"
                                            title="AI model quality tier. Premium: best quality (Opus-class). Standard: good balance (Sonnet-class). Budget: cheapest (GPT-mini). Local: Ollama self-hosted.">
                                            <option value="premium">Premium</option>
                                            <option value="standard">Standard</option>
                                            <option value="budget">Budget</option>
                                            <option value="local">Local</option>
                                        </select>
                                        <label class="config-toggle config-toggle-sm" title="Enable or disable this agent. Disabled agents won't be spawned at startup.">
                                            <input type="checkbox" @bind="agent.Config.Enabled" />
                                            <span class="config-toggle-slider"></span>
                                        </label>
                                    </div>
                                </div>
                                @if (isExpanded)
                                {
                                    <div class="config-agent-details" @onclick:stopPropagation="true">
                                        @* Role Description *@
                                        <div class="config-field">
                                            <label title="Custom role description that augments the agent's default persona. This is prepended to every AI system prompt, giving the agent a specialized identity and behavioral guidelines. Leave empty to use the default role.">
                                                Role Description <span class="config-hint">(augments default persona)</span>
                                            </label>
                                            <textarea @bind="agent.Config.RoleDescription" class="config-textarea" rows="3"
                                                placeholder="e.g., 'You specialize in security-first architecture. Always consider OWASP top 10 in your designs...'"
                                                title="Custom instructions prepended to every AI prompt for this agent. Defines specialized behavior, domain expertise, or organizational standards."></textarea>
                                        </div>

                                        @* MCP Servers *@
                                        <div class="config-field">
                                            <label title="MCP (Model Context Protocol) servers extend the agent's capabilities with external tools. Each server name is passed as --mcp-server to the Copilot CLI.">
                                                MCP Servers <span class="config-hint">(tool integrations)</span>
                                            </label>
                                            @for (var i = 0; i < agent.Config.McpServers.Count; i++)
                                            {
                                                var idx = i;
                                                <div class="config-list-item">
                                                    <input type="text" value="@agent.Config.McpServers[idx]"
                                                        @onchange="e => UpdateMcpServer(agent.Config, idx, e.Value?.ToString() ?? string.Empty)"
                                                        class="config-input" placeholder="server-name"
                                                        title="MCP server name (e.g., 'filesystem', 'github', 'database')" />
                                                    <button class="config-btn-remove" @onclick="() => RemoveMcpServer(agent.Config, idx)" title="Remove this MCP server">✕</button>
                                                </div>
                                            }
                                            <button class="config-btn-add" @onclick="() => AddMcpServer(agent.Config)" title="Add an MCP server for this agent">
                                                + Add MCP Server
                                            </button>
                                        </div>

                                        @* Knowledge Links *@
                                        <div class="config-field">
                                            <label title="URLs to documentation, wikis, or reference pages. Content is fetched once at agent startup and summarized into compact context that informs the agent's decisions.">
                                                Knowledge Links <span class="config-hint">(reference documentation)</span>
                                            </label>
                                            @for (var i = 0; i < agent.Config.KnowledgeLinks.Count; i++)
                                            {
                                                var idx = i;
                                                <div class="config-list-item">
                                                    <input type="text" value="@agent.Config.KnowledgeLinks[idx]"
                                                        @onchange="e => UpdateKnowledgeLink(agent.Config, idx, e.Value?.ToString() ?? string.Empty)"
                                                        class="config-input" placeholder="https://docs.example.com/standards"
                                                        title="URL to a documentation page. Content is fetched and summarized at agent startup." />
                                                    <button class="config-btn-remove" @onclick="() => RemoveKnowledgeLink(agent.Config, idx)" title="Remove this knowledge link">✕</button>
                                                </div>
                                            }
                                            <button class="config-btn-add" @onclick="() => AddKnowledgeLink(agent.Config)" title="Add a knowledge link for this agent">
                                                + Add Knowledge Link
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @* ── Custom Agents ── *@
                    <div class="config-custom-agents-section">
                        <div class="config-section-divider">
                            <span>Custom Agents</span>
                        </div>
                        @if (_config!.Agents.CustomAgents.Count == 0)
                        {
                            <p class="config-hint" style="margin: 8px 0;">No custom agents configured. Add one to extend your team with specialized roles.</p>
                        }
                        else
                        {
                            <div class="config-agent-grid">
                                @foreach (var customAgent in _config.Agents.CustomAgents)
                                {
                                    var agentKey = $"custom:{customAgent.Name}";
                                    var isExpanded = IsAgentPanelExpanded(agentKey);
                                    <div class="config-agent-accordion">
                                        <div class="config-agent-row" @onclick="() => ToggleAgentPanel(agentKey)" style="cursor: pointer;">
                                            <div class="config-agent-name">
                                                <span class="config-agent-chevron @(isExpanded ? "expanded" : "")">▶</span>
                                                <span class="config-custom-agent-badge">Custom</span>
                                                @if (string.IsNullOrWhiteSpace(customAgent.Name))
                                                {
                                                    <em style="opacity: 0.5;">(unnamed)</em>
                                                }
                                                else
                                                {
                                                    @customAgent.Name
                                                }
                                                @if (!string.IsNullOrWhiteSpace(customAgent.RoleDescription) || customAgent.McpServers.Count > 0 || customAgent.KnowledgeLinks.Count > 0)
                                                {
                                                    <span class="config-agent-customized" title="This agent has custom role configuration">✦</span>
                                                }
                                            </div>
                                            <div class="config-agent-controls" @onclick:stopPropagation="true">
                                                <select @bind="customAgent.ModelTier" class="config-select config-select-sm"
                                                    title="AI model quality tier for this custom agent.">
                                                    <option value="premium">Premium</option>
                                                    <option value="standard">Standard</option>
                                                    <option value="budget">Budget</option>
                                                    <option value="local">Local</option>
                                                </select>
                                                <label class="config-toggle config-toggle-sm" title="Enable or disable this custom agent.">
                                                    <input type="checkbox" @bind="customAgent.Enabled" />
                                                    <span class="config-toggle-slider"></span>
                                                </label>
                                                <button class="config-btn-remove" style="margin-left: 8px;"
                                                    @onclick="() => RemoveCustomAgent(customAgent)"
                                                    title="Remove this custom agent">✕</button>
                                            </div>
                                        </div>
                                        @if (isExpanded)
                                        {
                                            <div class="config-agent-details" @onclick:stopPropagation="true">
                                                @* Agent Name *@
                                                <div class="config-field">
                                                    <label title="Unique name for this custom agent. Used as its display name and for task assignment matching.">
                                                        Agent Name <span class="config-hint">(required)</span>
                                                    </label>
                                                    <input type="text" @bind="customAgent.Name" class="config-input"
                                                        placeholder="e.g., Security Reviewer, API Specialist, DevOps Engineer"
                                                        title="The agent's display name. Must be unique across all custom agents." />
                                                </div>

                                                @* Role Description *@
                                                <div class="config-field">
                                                    <label title="Define this agent's persona, expertise, and behavioral guidelines. This is the primary way to shape what the custom agent does and how it thinks.">
                                                        Role Description <span class="config-hint">(defines persona — highly recommended)</span>
                                                    </label>
                                                    <textarea @bind="customAgent.RoleDescription" class="config-textarea" rows="4"
                                                        placeholder="e.g., 'You are a Security Reviewer specializing in OWASP top 10, dependency vulnerability scanning, and secure coding practices. Review all PRs for security concerns...'"
                                                        title="The agent's core persona. This is prepended to every AI prompt and defines the agent's identity, expertise, and approach."></textarea>
                                                </div>

                                                @* MCP Servers *@
                                                <div class="config-field">
                                                    <label title="MCP servers extend this agent's tool capabilities.">
                                                        MCP Servers <span class="config-hint">(tool integrations)</span>
                                                    </label>
                                                    @for (var i = 0; i < customAgent.McpServers.Count; i++)
                                                    {
                                                        var idx = i;
                                                        <div class="config-list-item">
                                                            <input type="text" value="@customAgent.McpServers[idx]"
                                                                @onchange="e => UpdateMcpServer(customAgent, idx, e.Value?.ToString() ?? string.Empty)"
                                                                class="config-input" placeholder="server-name"
                                                                title="MCP server name" />
                                                            <button class="config-btn-remove" @onclick="() => RemoveMcpServer(customAgent, idx)" title="Remove this MCP server">✕</button>
                                                        </div>
                                                    }
                                                    <button class="config-btn-add" @onclick="() => AddMcpServer(customAgent)" title="Add an MCP server">
                                                        + Add MCP Server
                                                    </button>
                                                </div>

                                                @* Knowledge Links *@
                                                <div class="config-field">
                                                    <label title="URLs to documentation or reference pages for this agent's context.">
                                                        Knowledge Links <span class="config-hint">(reference documentation)</span>
                                                    </label>
                                                    @for (var i = 0; i < customAgent.KnowledgeLinks.Count; i++)
                                                    {
                                                        var idx = i;
                                                        <div class="config-list-item">
                                                            <input type="text" value="@customAgent.KnowledgeLinks[idx]"
                                                                @onchange="e => UpdateKnowledgeLink(customAgent, idx, e.Value?.ToString() ?? string.Empty)"
                                                                class="config-input" placeholder="https://docs.example.com/standards"
                                                                title="URL to a documentation page" />
                                                            <button class="config-btn-remove" @onclick="() => RemoveKnowledgeLink(customAgent, idx)" title="Remove this knowledge link">✕</button>
                                                        </div>
                                                    }
                                                    <button class="config-btn-add" @onclick="() => AddKnowledgeLink(customAgent)" title="Add a knowledge link">
                                                        + Add Knowledge Link
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        <button class="config-btn-add config-btn-add-agent" @onclick="AddCustomAgent"
                            title="Add a new custom agent with its own role, model tier, MCP servers, and knowledge links">
                            + Add Custom Agent
                        </button>
                    </div>
                </div>
            }
        </div>

        @* ── Engineer Pool ── *@
        <div class="config-card">
            <div class="config-card-header" @onclick="() => _poolExpanded = !_poolExpanded">
                <span class="config-card-icon">🏊</span>
                <span class="config-card-title">Engineer Pool</span>
                <span class="config-card-chevron @(_poolExpanded ? "expanded" : "")">▶</span>
            </div>
            @if (_poolExpanded)
            {
                <div class="config-card-body">
                    <p class="config-hint" style="margin-bottom: 12px;" title="Controls how many ADDITIONAL engineers can be dynamically spawned beyond the core PE. The core PE (rank 0) is always created.">
                        Configure the pool of additional engineers that can be spawned for parallel development. The core PE is always active.
                    </p>
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="Additional Principal Engineers beyond the core PE. PEs handle high-complexity tasks requiring architectural awareness. Uses premium tier.">Principal Engineers</label>
                            <input type="number" @bind="_config.Limits.EngineerPool.PrincipalEngineerPool" class="config-input config-input-number" min="0" max="10"
                                title="Number of ADDITIONAL PEs to spawn (the core PE always exists). Each uses premium-tier AI. Recommended: 1-3 for large projects." />
                            <span class="config-hint">Additional PEs (premium tier)</span>
                        </div>
                        <div class="config-field">
                            <label title="Additional Senior Engineers for standard-complexity tasks. Good balance of quality and cost. Uses standard tier.">Senior Engineers</label>
                            <input type="number" @bind="_config.Limits.EngineerPool.SeniorEngineerPool" class="config-input config-input-number" min="0" max="10"
                                title="Senior Engineers handle moderate-complexity tasks. Each uses standard-tier AI. Set to 0 to disable SE spawning." />
                            <span class="config-hint">Additional SEs (standard tier)</span>
                        </div>
                        <div class="config-field">
                            <label title="Additional Junior Engineers for simple, well-defined tasks. Cheapest option. Uses budget or local tier.">Junior Engineers</label>
                            <input type="number" @bind="_config.Limits.EngineerPool.JuniorEngineerPool" class="config-input config-input-number" min="0" max="10"
                                title="Junior Engineers handle simple tasks (boilerplate, scaffolding). Uses budget/local-tier AI. Set to 0 to disable JE spawning." />
                            <span class="config-hint">Additional JEs (budget/local tier)</span>
                        </div>
                    </div>
                    <div class="config-pool-summary">
                        Total additional engineers: <strong>@(_config.Limits.EngineerPool.PrincipalEngineerPool + _config.Limits.EngineerPool.SeniorEngineerPool + _config.Limits.EngineerPool.JuniorEngineerPool)</strong>
                        (+ 1 core PE always active)
                    </div>
                </div>
            }
        </div>

        @* ── Limits ── *@
        <div class="config-card">
            <div class="config-card-header" @onclick="() => _limitsExpanded = !_limitsExpanded">
                <span class="config-card-icon">📏</span>
                <span class="config-card-title">Limits</span>
                <span class="config-card-chevron @(_limitsExpanded ? "expanded" : "")">▶</span>
            </div>
            @if (_limitsExpanded)
            {
                <div class="config-card-body">
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="Maximum number of agents that can run simultaneously. Includes core agents + spawned engineers.">Max Concurrent Agents</label>
                            <input type="number" @bind="_config.Limits.MaxConcurrentAgents" class="config-input config-input-number" min="1" max="50"
                                title="Upper bound on total running agents. Default: 10. Increase for large projects with many parallel tasks." />
                        </div>
                        <div class="config-field">
                            <label title="How long an agent can run before being forcefully stopped. Prevents runaway agents from consuming resources indefinitely.">Agent Timeout (minutes)</label>
                            <input type="number" @bind="_config.Limits.AgentTimeoutMinutes" class="config-input config-input-number" min="5" max="240"
                                title="Per-agent timeout. Default: 60 min. Complex tasks (architecture, large PRs) may need more. Max: 240 min (4 hours)." />
                        </div>
                        <div class="config-field">
                            <label title="How often agents poll GitHub for new issues, PR comments, and review feedback. Lower = more responsive but more API calls.">GitHub Poll Interval (seconds)</label>
                            <input type="number" @bind="_config.Limits.GitHubPollIntervalSeconds" class="config-input config-input-number" min="5" max="300"
                                title="Polling frequency for GitHub API. Default: 30s. Lower values use more API rate limit. Minimum: 5s." />
                        </div>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="Maximum total tokens (input + output) across all agents per day. Prevents runaway costs. Set high for active development.">Max Daily Token Budget</label>
                            <input type="number" @bind="_config.Limits.MaxDailyTokenBudget" class="config-input config-input-number" min="10000"
                                title="Daily token spending cap across all agents. Default: 1,000,000. Set to a high value if using Copilot CLI (no direct cost)." />
                        </div>
                        <div class="config-field">
                            <label title="Maximum back-and-forth exchanges between agents when clarifying requirements. Prevents infinite loops of agents asking each other questions.">Max Clarification Round-Trips</label>
                            <input type="number" @bind="_config.Limits.MaxClarificationRoundTrips" class="config-input config-input-number" min="1" max="20"
                                title="Cap on clarification exchanges between agents. Default: 3. Higher = more thorough but slower progression." />
                        </div>
                        <div class="config-field">
                            <label title="Maximum times an agent can rework code after a review rejection. Prevents endless fix-review cycles.">Max Rework Cycles</label>
                            <input type="number" @bind="_config.Limits.MaxReworkCycles" class="config-input config-input-number" min="1" max="10"
                                title="Max code rework iterations after review feedback. Default: 3. After this, the agent escalates or marks as blocked." />
                        </div>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="Minimum time an agent must spend on a task before it can self-complete. Prevents premature completion of complex tasks.">Self-Completion Threshold (min)</label>
                            <input type="number" @bind="_config.Limits.SelfCompletionThresholdMinutes" class="config-input config-input-number" min="1" max="120"
                                title="Agents can't mark their own task complete until this much time has passed. Encourages thorough work. Default: 5 min." />
                        </div>
                        <div class="config-field">
                            <label title="Minimum number of parallelizable tasks required before the orchestrator will spawn a new engineer. Prevents spawning for small workloads.">Min Tasks for New Engineer</label>
                            <input type="number" @bind="_config.Limits.MinParallelizableTasksForNewEngineer" class="config-input config-input-number" min="1" max="20"
                                title="Task threshold for auto-scaling. Default: 2. The spawn manager won't create new engineers unless this many tasks are waiting." />
                        </div>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="Max rework cycles for Architect when architecture review requests changes.">Max Architect Rework</label>
                            <input type="number" @bind="_config.Limits.MaxArchitectReworkCycles" class="config-input config-input-number" min="1" max="10"
                                title="How many times the Architect can revise Architecture.md after PE feedback. Default: 3." />
                        </div>
                        <div class="config-field">
                            <label title="Max rework cycles for PM when PM spec review requests changes.">Max PM Rework</label>
                            <input type="number" @bind="_config.Limits.MaxPmReworkCycles" class="config-input config-input-number" min="1" max="10"
                                title="How many times the PM can revise PMSpec.md after feedback. Default: 3." />
                        </div>
                        <div class="config-field">
                            <label title="Max rework cycles for Test Engineer when tests fail build/review.">Max Test Rework</label>
                            <input type="number" @bind="_config.Limits.MaxTestReworkCycles" class="config-input config-input-number" min="1" max="10"
                                title="How many times the TE can fix failed tests before giving up. Default: 2." />
                        </div>
                        <div class="config-field">
                            <label title="Max rounds of source bug fix attempts before escalating to human.">Max Source Bug Rounds</label>
                            <input type="number" @bind="_config.Limits.MaxSourceBugRounds" class="config-input config-input-number" min="1" max="10"
                                title="How many times the engineer can attempt to fix a source bug found by TE. Default: 2." />
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── Dashboard Settings ── *@
        <div class="config-card">
            <div class="config-card-header" @onclick="() => _dashboardExpanded = !_dashboardExpanded">
                <span class="config-card-icon">📊</span>
                <span class="config-card-title">Dashboard</span>
                <span class="config-card-chevron @(_dashboardExpanded ? "expanded" : "")">▶</span>
            </div>
            @if (_dashboardExpanded)
            {
                <div class="config-card-body">
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="The port the Runner process listens on (hosts API + embedded dashboard). Requires restart.">Runner Port</label>
                            <input type="number" @bind="_config.Dashboard.Port" class="config-input config-input-number" min="1024" max="65535"
                                title="Runner HTTP port (API + embedded dashboard). Default: 5050. Requires app restart." />
                        </div>
                        <div class="config-field">
                            <label title="The port the standalone Dashboard.Host process listens on. Requires restart.">Dashboard Port</label>
                            <input type="number" @bind="_config.Dashboard.StandalonePort" class="config-input config-input-number" min="1024" max="65535"
                                title="Standalone dashboard HTTP port. Default: 5051. Requires app restart." />
                        </div>
                        <div class="config-field" title="Enables real-time push updates to the dashboard via SignalR WebSockets. When off, the dashboard uses polling instead.">
                            <label>Enable SignalR</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.Dashboard.EnableSignalR" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── Workspace Settings ── *@
        <div class="config-card">
            <div class="config-card-header" @onclick="() => _workspaceExpanded = !_workspaceExpanded">
                <span class="config-card-icon">🔧</span>
                <span class="config-card-title">Workspace</span>
                <span class="config-card-chevron @(_workspaceExpanded ? "expanded" : "")">▶</span>
            </div>
            @if (_workspaceExpanded)
            {
                <div class="config-card-body">
                    <div class="config-field">
                        <label title="Root directory where agent workspaces are created. Each agent gets a subdirectory here for local git clones and builds.">Root Path</label>
                        <input type="text" @bind="_config.Workspace.RootPath" class="config-input" placeholder="C:\Agents"
                            title="Base directory for all agent workspaces. Each agent clones the repo into {RootPath}/{agent-id}/. Ensure sufficient disk space." />
                    </div>
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="Shell command to build the project. Run in the workspace root after code changes. Must exit 0 on success.">Build Command</label>
                            <input type="text" @bind="_config.Workspace.BuildCommand" class="config-input"
                                title="e.g., 'dotnet build', 'npm run build', 'make'. Executed in the agent's workspace directory." />
                        </div>
                        <div class="config-field">
                            <label title="Shell command to run tests. Executed after successful build. Must exit 0 when all tests pass.">Test Command</label>
                            <input type="text" @bind="_config.Workspace.TestCommand" class="config-input"
                                title="e.g., 'dotnet test', 'npm test', 'pytest'. Agents use this to validate their code changes before creating PRs." />
                        </div>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="Test workflow mode: 'inline' pushes tests to source PR, 'separate' creates a separate test PR.">Test Workflow</label>
                            <select @bind="_config.Workspace.TestWorkflow" class="config-input">
                                <option value="inline">Inline (tests in source PR)</option>
                                <option value="separate">Separate (test PR per source PR)</option>
                            </select>
                        </div>
                        <div class="config-field">
                            <label title="Command to start the application for UI/E2E testing. Leave empty if not using UI tests.">App Start Command <span class="config-hint">(for UI tests)</span></label>
                            <input type="text" @bind="_config.Workspace.AppStartCommand" class="config-input" placeholder="e.g. dotnet run --project src/MyApp"
                                title="Shell command to start the app for Playwright tests. The app must be running before UI tests execute." />
                        </div>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="Base URL of the running application for UI tests.">App Base URL</label>
                            <input type="text" @bind="_config.Workspace.AppBaseUrl" class="config-input" placeholder="http://localhost:5000"
                                title="URL where the running app is accessible for Playwright tests. Default: http://localhost:5000" />
                        </div>
                        <div class="config-field">
                            <label title="How long to wait for the app to start before running UI tests.">App Startup Timeout (sec)</label>
                            <input type="number" @bind="_config.Workspace.AppStartupTimeoutSeconds" class="config-input config-input-number" min="10" max="300"
                                title="Seconds to wait for the app to start responding before timing out. Default: 90." />
                        </div>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="Maximum time for a build command before it's killed. Prevents hung builds from blocking agents.">Build Timeout (sec)</label>
                            <input type="number" @bind="_config.Workspace.BuildTimeoutSeconds" class="config-input config-input-number" min="10" max="600"
                                title="Build timeout in seconds. Default: 120. Increase for large solutions or first-time NuGet restore." />
                        </div>
                        <div class="config-field">
                            <label title="Maximum time for a test command before it's killed. Prevents hung test suites from blocking agents.">Test Timeout (sec)</label>
                            <input type="number" @bind="_config.Workspace.TestTimeoutSeconds" class="config-input config-input-number" min="10" max="600"
                                title="Test timeout in seconds. Default: 180. Increase for large test suites or integration tests." />
                        </div>
                        <div class="config-field">
                            <label title="How many times to retry a failed build before giving up. Each retry includes AI-assisted fix attempts.">Max Build Retries</label>
                            <input type="number" @bind="_config.Workspace.MaxBuildRetries" class="config-input config-input-number" min="0" max="10"
                                title="Build retry count with AI fix attempts between retries. Default: 3. Set to 0 to fail immediately on build errors." />
                        </div>
                        <div class="config-field">
                            <label title="How many times to retry failed tests before giving up.">Max Test Retries</label>
                            <input type="number" @bind="_config.Workspace.MaxTestRetries" class="config-input config-input-number" min="0" max="10"
                                title="Test retry count. Default: 3. Set to 0 to fail immediately on test failures." />
                        </div>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field" title="Enable Playwright-based end-to-end UI tests. When on, the Test Engineer can generate and run browser-based tests.">
                            <label>Enable UI Tests</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.Workspace.EnableUITests" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                        <div class="config-field" title="When enabled, only UI/E2E tests are generated (skips unit and integration). Useful for UI-focused projects.">
                            <label>UI Tests Only</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.Workspace.UITestsOnly" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                        <div class="config-field" title="Capture screenshots during UI test runs for visual verification.">
                            <label>Capture Screenshots</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.Workspace.CaptureScreenshots" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                        <div class="config-field" title="Run Playwright browser tests in headless mode (no visible browser window). Always recommended for CI/agent environments.">
                            <label>Playwright Headless</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.Workspace.PlaywrightHeadless" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                        <div class="config-field" title="Automatically delete agent workspace directories when the project completes. Frees disk space but loses local build caches.">
                            <label>Cleanup on Complete</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.Workspace.CleanupOnProjectComplete" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="Git user.name for commits made by agents in their workspaces. Shows up in git log and PR commit history.">Git User Name</label>
                            <input type="text" @bind="_config.Workspace.GitUserName" class="config-input"
                                title="The git author name used for agent commits. e.g., 'AgentSquad Bot'" />
                        </div>
                        <div class="config-field">
                            <label title="Git user.email for commits made by agents. Should be a valid email or a noreply address.">Git User Email</label>
                            <input type="text" @bind="_config.Workspace.GitUserEmail" class="config-input"
                                title="The git author email used for agent commits. e.g., 'agentsquad@noreply.github.com'" />
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── Human Interaction Settings ── *@
        <div class="config-card">
            <div class="config-card-header" @onclick="() => _humanInteractionExpanded = !_humanInteractionExpanded">
                <span class="config-card-icon">🧑‍💼</span>
                <span class="config-card-title">Human Interaction</span>
                <span class="config-card-chevron @(_humanInteractionExpanded ? "expanded" : "")">▶</span>
            </div>
            @if (_humanInteractionExpanded)
            {
                <div class="config-card-body">
                    <div class="config-field" title="Master switch for human interaction gates. When off, all gates auto-proceed and agents run fully autonomously — no pauses, no approvals, no waiting. When on, you control which workflow checkpoints require your review before agents continue.">
                        <label>Enable Human Checkpoints</label>
                        <label class="config-toggle">
                            <input type="checkbox" @bind="_config.HumanInteraction.Enabled" />
                            <span class="config-toggle-slider"></span>
                        </label>
                        <span class="config-hint">When enabled, individual gates below can pause for human approval</span>
                    </div>

                    <div class="config-preset-bar">
                        <span class="config-preset-label">Presets:</span>
                        <button class="config-preset-btn @(!_config.HumanInteraction.Enabled ? "config-preset-active" : "")"
                            @onclick="() => ApplyHumanPreset(HumanInteractionPreset.FullAuto)"
                            title="All gates auto-proceed. Agents operate fully autonomously with zero human involvement. Best for trusted projects, overnight runs, or when you want maximum speed. No pauses, no approvals — agents make all decisions end-to-end.">
                            🤖 Full Auto
                        </button>
                        <button class="config-preset-btn @(IsPresetActive(HumanInteractionPreset.Supervised) ? "config-preset-active" : "")"
                            @onclick="() => ApplyHumanPreset(HumanInteractionPreset.Supervised)"
                            title="Critical gates require human approval: PM Spec, Architecture, Engineering Plan, Final PR Approval, and Deployment. Routine gates (research, task assignment, individual reviews) auto-proceed. Best balance of oversight and speed — you review the important decisions while agents handle day-to-day work.">
                            👁️ Supervised
                        </button>
                        <button class="config-preset-btn @(IsPresetActive(HumanInteractionPreset.FullControl) ? "config-preset-active" : "")"
                            @onclick="() => ApplyHumanPreset(HumanInteractionPreset.FullControl)"
                            title="Every gate requires human approval. Maximum oversight — agents pause at every workflow checkpoint and wait for your go-ahead. Best for sensitive projects, learning the system, or when you want to review every decision. Significantly slower since agents wait for you at each step.">
                            🛡️ Full Control
                        </button>
                    </div>

                    @if (_config.HumanInteraction.Enabled)
                    {
                        @foreach (var phaseGroup in GateIds.AllGates.GroupBy(g => g.Phase))
                        {
                            <div class="config-gate-phase">
                                <h4 class="config-gate-phase-title">@phaseGroup.Key</h4>
                                <div class="config-gate-grid">
                                    @foreach (var gate in phaseGroup)
                                    {
                                        var gateConfig = GetOrCreateGate(gate.Id);
                                        <div class="config-gate-item" title="@gate.Description">
                                            <div class="config-gate-header">
                                                <label class="config-toggle config-toggle-sm">
                                                    <input type="checkbox" @bind="gateConfig.RequiresHuman" />
                                                    <span class="config-toggle-slider"></span>
                                                </label>
                                                <span class="config-gate-name">@gate.Name</span>
                                            </div>
                                            <span class="config-gate-badge @(gateConfig.RequiresHuman ? "config-gate-human" : "config-gate-auto")">
                                                @(gateConfig.RequiresHuman ? "👤 Human" : "🤖 Auto")
                                            </span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="config-gate-disabled-notice">
                            <span>🤖 All gates are set to <strong>Full Auto</strong> — agents operate autonomously without human checkpoints.</span>
                        </div>
                    }
                </div>
            }
        </div>

        @* ═══════════════════════════════════════════════════════════════════
           SME AGENTS — dynamic specialist agents
           ═══════════════════════════════════════════════════════════════════ *@
        <div class="config-divider"></div>

        <div class="config-section-header">
            <span class="config-section-icon">🧠</span>
            <div>
                <h2 class="config-section-title">SME Agent System</h2>
                <p class="config-section-desc">
                    Configure dynamic specialist (SME) agents that can be created by the PM or PE during workflow.
                    MCP servers provide tool capabilities; templates define reusable specialist roles.
                </p>
            </div>
        </div>

        <div class="config-card">
            <div class="config-card-body">
                <div class="config-field-row">
                    <div class="config-field" title="When enabled, PM can propose team composition and PE can request specialist agents">
                        <label>SME System Enabled</label>
                        <label class="config-toggle">
                            <input type="checkbox" @bind="_config.SmeAgents.Enabled" />
                            <span class="config-toggle-slider"></span>
                        </label>
                    </div>
                    <div class="config-field" title="Maximum number of SME agents that can run simultaneously">
                        <label>Max Total SME Agents</label>
                        <input type="number" class="config-input config-input-number"
                               @bind="_config.SmeAgents.MaxTotalSmeAgents" min="1" max="20" />
                    </div>
                    <div class="config-field" title="Allow PM/PE to create new SME definitions at runtime (still human-gated)">
                        <label>Allow Agent-Created Definitions</label>
                        <label class="config-toggle">
                            <input type="checkbox" @bind="_config.SmeAgents.AllowAgentCreatedDefinitions" />
                            <span class="config-toggle-slider"></span>
                        </label>
                    </div>
                    <div class="config-field" title="Save agent-created definitions to JSON for reuse across runs">
                        <label>Persist Definitions</label>
                        <label class="config-toggle">
                            <input type="checkbox" @bind="_config.SmeAgents.PersistDefinitions" />
                            <span class="config-toggle-slider"></span>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        @* MCP Servers *@
        <div class="config-card">
            <div class="config-card-header" @onclick="() => _mcpServersExpanded = !_mcpServersExpanded">
                <span class="config-card-icon">🔌</span>
                <span class="config-card-title">Registered MCP Servers</span>
                <span class="config-card-chevron @(_mcpServersExpanded ? "expanded" : "")">▶</span>
            </div>
            @if (_mcpServersExpanded)
            {
                <div class="config-card-body">
                    <p class="config-hint" style="margin-bottom: 0.75rem">
                        MCP servers provide tools (GitHub, fetch, filesystem, etc.) that agents can use.
                        Configure in appsettings.json → McpServers section.
                    </p>
                    @if (_config.McpServers.Count == 0)
                    {
                        <p class="config-hint"><em>No MCP servers configured. Add to appsettings.json → McpServers section.</em></p>
                    }
                    else
                    {
                        <div class="mcp-server-list">
                            @foreach (var (name, server) in _config.McpServers)
                            {
                                <div class="mcp-server-card">
                                    <div class="mcp-server-name">
                                        <span class="mcp-transport-badge">@server.Transport</span>
                                        @name
                                    </div>
                                    <div class="mcp-server-desc">@server.Description</div>
                                    @if (server.ProvidedCapabilities.Count > 0)
                                    {
                                        <div class="mcp-capabilities">
                                            @foreach (var cap in server.ProvidedCapabilities)
                                            {
                                                <span class="mcp-cap-tag">@cap</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        @* SME Templates *@
        <div class="config-card">
            <div class="config-card-header" @onclick="() => _smeTemplatesExpanded = !_smeTemplatesExpanded">
                <span class="config-card-icon">📋</span>
                <span class="config-card-title">SME Templates</span>
                <span class="config-card-chevron @(_smeTemplatesExpanded ? "expanded" : "")">▶</span>
            </div>
            @if (_smeTemplatesExpanded)
            {
                <div class="config-card-body">
                    <p class="config-hint" style="margin-bottom: 0.75rem">
                        Pre-configured specialist roles. The PM can activate these during team composition.
                        Configure in appsettings.json → SmeAgents → Templates section.
                    </p>
                    @if (_config.SmeAgents.Templates.Count == 0)
                    {
                        <p class="config-hint"><em>No SME templates configured.</em></p>
                    }
                    else
                    {
                        <div class="sme-template-list">
                            @foreach (var (id, template) in _config.SmeAgents.Templates)
                            {
                                <div class="sme-template-card">
                                    <div class="sme-template-header">
                                        <span class="sme-template-name">@template.RoleName</span>
                                        <span class="sme-template-id">@id</span>
                                    </div>
                                    <div class="sme-template-details">
                                        <span>Tier: @template.ModelTier</span>
                                        <span>Mode: @template.WorkflowMode</span>
                                        <span>Max: @template.MaxInstances</span>
                                    </div>
                                    @if (template.Capabilities.Count > 0)
                                    {
                                        <div class="mcp-capabilities">
                                            @foreach (var cap in template.Capabilities)
                                            {
                                                <span class="mcp-cap-tag">@cap</span>
                                            }
                                        </div>
                                    }
                                    @if (template.McpServers.Count > 0)
                                    {
                                        <div class="sme-template-servers">
                                            MCP: @string.Join(", ", template.McpServers)
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        @* ── Review Settings ── *@
        <div class="config-card">
            <div class="config-card-header" @onclick="() => _reviewExpanded = !_reviewExpanded">
                <span class="config-card-icon">🔍</span>
                <span class="config-card-title">PR Review</span>
                <span class="config-card-chevron @(_reviewExpanded ? "expanded" : "")">▶</span>
            </div>
            @if (_reviewExpanded)
            {
                <div class="config-card-body">
                    <div class="config-field-row">
                        <div class="config-field" title="When enabled, the Architect posts inline code comments on specific lines in PRs instead of only a summary comment. Comments appear directly on the diff, making feedback more actionable for engineers.">
                            <label>Enable Inline Comments</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.Review.EnableInlineComments" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                        <div class="config-field" title="When enabled, the Architect includes a risk assessment (LOW/MEDIUM/HIGH) with each PR review. Risk levels indicate the scope of impact: LOW = cosmetic changes, MEDIUM = modifies shared models or APIs, HIGH = breaking changes or security-sensitive code.">
                            <label>Enable Risk Assessment</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.Review.EnableRiskAssessment" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="The minimum risk level that triggers a human review gate. When a PR's risk meets or exceeds this threshold, the Architect adds a 'human-review-required' label and pauses before promoting the PR. Remove the label on GitHub to allow the pipeline to continue. Set to 'None' to disable human risk gating.">Min Risk Level for Human Review</label>
                            <select @bind="_minRiskLevel" class="config-input"
                                title="The minimum risk level that triggers a human review gate. When a PR's risk meets or exceeds this threshold, the Architect adds a 'human-review-required' label and pauses before promoting the PR. Remove the label on GitHub to allow the pipeline to continue. Set to 'None' to disable human risk gating.">
                                <option value="None">None</option>
                                <option value="Low">Low</option>
                                <option value="Medium">Medium</option>
                                <option value="High">High</option>
                            </select>
                        </div>
                        <div class="config-field">
                            <label title="Maximum number of inline comments the Architect can post per review. Prevents overwhelming PRs with too many comments. Only the highest-priority comments are included when the limit is reached.">Max Inline Comments Per Review</label>
                            <input type="number" @bind="_config.Review.MaxInlineCommentsPerReview" class="config-input config-input-number" min="1" max="50"
                                title="Maximum number of inline comments the Architect can post per review. Prevents overwhelming PRs with too many comments. Only the highest-priority comments are included when the limit is reached." />
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── Decision Gating Settings ── *@
        <div class="config-card">
            <div class="config-card-header" @onclick="() => _decisionGatingExpanded = !_decisionGatingExpanded">
                <span class="config-card-icon">🚦</span>
                <span class="config-card-title">Decision Gating</span>
                <span class="config-card-chevron @(_decisionGatingExpanded ? "expanded" : "")">▶</span>
            </div>
            @if (_decisionGatingExpanded)
            {
                <div class="config-card-body">
                    <div class="config-field-row">
                        <div class="config-field" title="When enabled, agents pause before executing impactful decisions and present a structured analysis with alternatives. Decisions are classified by impact level (XS to XL) and only those at or above the MinimumGateLevel require explicit approval.">
                            <label>Enabled</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.DecisionGating.Enabled" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                        <div class="config-field" title="When enabled, gated decisions include a generated implementation plan showing exactly what changes will be made before proceeding.">
                            <label>Require Plan for Gated</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.DecisionGating.RequirePlanForGated" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="The minimum decision impact level that triggers a gate. Decisions below this level auto-proceed. XS = trivial naming/formatting. S = single-file changes. M = multi-file refactors. L = architectural changes. XL = breaking/irreversible changes.">Minimum Gate Level</label>
                            <select @bind="_config.DecisionGating.MinimumGateLevel" class="config-input"
                                title="The minimum decision impact level that triggers a gate. Decisions below this level auto-proceed. XS = trivial naming/formatting. S = single-file changes. M = multi-file refactors. L = architectural changes. XL = breaking/irreversible changes.">
                                <option value="None">None</option>
                                <option value="XS">XS</option>
                                <option value="S">S</option>
                                <option value="M">M</option>
                                <option value="L">L</option>
                                <option value="XL">XL</option>
                            </select>
                        </div>
                        <div class="config-field">
                            <label title="What happens when a gated decision times out waiting for approval. 'auto-approve' = proceed anyway. 'block' = mark agent as blocked. 'escalate' = create an executive-request issue.">Timeout Fallback Action</label>
                            <select @bind="_config.DecisionGating.TimeoutFallbackAction" class="config-input"
                                title="What happens when a gated decision times out waiting for approval. 'auto-approve' = proceed anyway. 'block' = mark agent as blocked. 'escalate' = create an executive-request issue.">
                                <option value="auto-approve">auto-approve</option>
                                <option value="block">block</option>
                                <option value="escalate">escalate</option>
                            </select>
                        </div>
                    </div>
                    <div class="config-field-row">
                        <div class="config-field">
                            <label title="Maximum number of AI deliberation turns when evaluating a decision. More turns = more thorough analysis but slower. Default: 2.">Max Decision Turns</label>
                            <input type="number" @bind="_config.DecisionGating.MaxDecisionTurns" class="config-input config-input-number" min="1" max="10"
                                title="Maximum number of AI deliberation turns when evaluating a decision. More turns = more thorough analysis but slower. Default: 2." />
                        </div>
                        <div class="config-field">
                            <label title="How long to wait for human approval before taking the fallback action. 0 = wait indefinitely. Default: 0 minutes.">Gate Timeout (minutes)</label>
                            <input type="number" @bind="_config.DecisionGating.GateTimeoutMinutes" class="config-input config-input-number" min="0" max="1440"
                                title="How long to wait for human approval before taking the fallback action. 0 = wait indefinitely. Default: 0 minutes." />
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── Agentic Loop Settings ── *@
        <div class="config-card">
            <div class="config-card-header" @onclick="() => _agenticLoopExpanded = !_agenticLoopExpanded">
                <span class="config-card-icon">🔄</span>
                <span class="config-card-title">Agentic Loop</span>
                <span class="config-card-chevron @(_agenticLoopExpanded ? "expanded" : "")">▶</span>
            </div>
            @if (_agenticLoopExpanded)
            {
                <div class="config-card-body">
                    <div class="config-field-row">
                        <div class="config-field" title="When enabled, agents perform iterative self-assessment after generating documents or code. Each iteration critiques and refines the output, improving quality at the cost of additional AI calls.">
                            <label>Enabled</label>
                            <label class="config-toggle">
                                <input type="checkbox" @bind="_config.AgenticLoop.Enabled" />
                                <span class="config-toggle-slider"></span>
                            </label>
                        </div>
                        <div class="config-field">
                            <label title="Maximum number of self-assessment refinement iterations. Default: 2. Higher values produce more polished output but cost more tokens and take longer.">Max Iterations</label>
                            <input type="number" @bind="_config.AgenticLoop.MaxIterations" class="config-input config-input-number" min="1" max="10"
                                title="Maximum number of self-assessment refinement iterations. Default: 2. Higher values produce more polished output but cost more tokens and take longer." />
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── Save Button ── *@
        <div class="config-save-bar">
            @if (_saveError is not null)
            {
                <div class="config-save-error">⚠️ @_saveError</div>
            }
            <button class="config-save-btn" @onclick="SaveConfig" disabled="@_saving">
                @if (_saving)
                {
                    <span class="config-spinner"></span>
                    <span>Saving...</span>
                }
                else
                {
                    <span>💾 Save Configuration</span>
                }
            </button>
        </div>

        @* ═══════════════════════════════════════════════════════════════════
           PROMPT TEMPLATE EDITOR
           ═══════════════════════════════════════════════════════════════════ *@
        <div class="config-divider"></div>

        <div class="config-section-header">
            <span class="config-section-icon">📝</span>
            <div>
                <h2 class="config-section-title">Prompt Templates</h2>
                <p class="config-section-desc">Edit agent AI prompts. Changes are hot-reloaded automatically — no restart required.</p>
            </div>
        </div>

        @if (_promptRoles is not null)
        {
            @foreach (var role in _promptRoles)
            {
                <div class="config-card">
                    <div class="config-card-header" @onclick="() => TogglePromptRole(role)"
                        title="@GetPromptRoleTooltip(role)">
                        <span class="config-card-icon">🤖</span>
                        <span class="config-card-title">@FormatRoleName(role)</span>
                        <span class="config-card-badge">@(GetTemplateCount(role)) templates</span>
                        <span class="config-card-chevron @(_expandedPromptRoles.Contains(role) ? "expanded" : "")">▶</span>
                    </div>
                    @if (_expandedPromptRoles.Contains(role))
                    {
                        <div class="config-card-body">
                            @if (_promptTemplates.TryGetValue(role, out var templates))
                            {
                                    @foreach (var tmpl in templates)
                                    {
                                        var key = tmpl;
                                        var displayName = tmpl.Contains('/') ? tmpl[(tmpl.LastIndexOf('/') + 1)..] : tmpl;
                                    <div class="prompt-template-item">
                                        <div class="prompt-template-header" @onclick="() => TogglePromptTemplate(key)">
                                            <span class="prompt-template-name">@displayName</span>
                                            @if (_promptMetadata.TryGetValue(key, out var meta))
                                            {
                                                <span class="prompt-template-desc">@meta.Description</span>
                                            }
                                            <span class="config-card-chevron @(_expandedPromptTemplates.Contains(key) ? "expanded" : "")">▶</span>
                                        </div>
                                        @if (_expandedPromptTemplates.Contains(key))
                                        {
                                            <div class="prompt-template-editor">
                                                <textarea class="prompt-textarea" rows="15"
                                                    value="@GetPromptContent(key)"
                                                    @oninput="e => SetPromptContent(key, e.Value?.ToString() ?? string.Empty)"></textarea>
                                                <div class="prompt-template-actions">
                                                    <button class="prompt-save-btn" @onclick="() => SavePromptTemplate(key)"
                                                        disabled="@(!_modifiedPrompts.Contains(key))">
                                                        💾 Save
                                                    </button>
                                                    <button class="prompt-reset-btn" @onclick="() => ResetPromptTemplate(key)">
                                                        🔄 Reset to Default
                                                    </button>
                                                    @if (_promptSaveSuccess == key)
                                                    {
                                                        <span class="badge badge-success">✓ Saved</span>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="config-empty">Loading templates...</div>
                            }
                        </div>
                    }
                </div>
            }
        }

        @* ═══════════════════════════════════════════════════════════════════
           GITHUB REPO CLEANUP — separated from config
           ═══════════════════════════════════════════════════════════════════ *@
        <div class="config-divider"></div>

        <div class="config-section-header config-section-danger">
            <span class="config-section-icon">🧹</span>
            <div>
                <h2 class="config-section-title">GitHub Repository Cleanup</h2>
                <p class="config-section-desc">
                    Dangerous operation — permanently closes all issues and PRs, and deletes all code from
                    <strong>@_config.Project.GitHubRepo</strong>. This cannot be undone.
                </p>
            </div>
        </div>

        <div class="config-card config-card-danger">
            <div class="config-card-body">
                <div class="cleanup-info">
                    <div class="cleanup-repo">
                        <span class="cleanup-repo-icon">📦</span>
                        <span class="cleanup-repo-name">@_config.Project.GitHubRepo</span>
                        <span class="cleanup-branch">(@_config.Project.DefaultBranch)</span>
                    </div>
                    <p class="cleanup-warning">
                        ⚠️ This will close all open issues, close all open pull requests, delete all agent branches,
                        and remove all files from the <code>@_config.Project.DefaultBranch</code> branch.
                    </p>
                </div>

                <button class="cleanup-scan-btn" @onclick="ScanRepo" disabled="@_scanning">
                    @if (_scanning)
                    {
                        <span class="config-spinner"></span>
                        <span>Scanning repository...</span>
                    }
                    else
                    {
                        <span>🔍 Scan Repository</span>
                    }
                </button>

                @if (_cleanupSummary is not null)
                {
                    <div class="cleanup-summary">
                        <div class="cleanup-stat-grid">
                            <div class="cleanup-stat">
                                <div class="cleanup-stat-value">@_cleanupSummary.FileCount</div>
                                <div class="cleanup-stat-label">Files</div>
                            </div>
                            <div class="cleanup-stat">
                                <div class="cleanup-stat-value">@_cleanupSummary.OpenIssues</div>
                                <div class="cleanup-stat-label">Open Issues</div>
                            </div>
                            <div class="cleanup-stat">
                                <div class="cleanup-stat-value">@_cleanupSummary.OpenPrs</div>
                                <div class="cleanup-stat-label">Open PRs</div>
                            </div>
                            <div class="cleanup-stat">
                                <div class="cleanup-stat-value">@_cleanupSummary.TotalIssues</div>
                                <div class="cleanup-stat-label">Total Issues</div>
                            </div>
                        </div>

                        <button class="cleanup-execute-btn" @onclick="ShowCleanupModal"
                            title="Stop all agents, clean the repository, reset workflow state, and restart a fresh project">
                            🔄 Clean &amp; Restart Project
                        </button>
                    </div>
                }
            </div>
        </div>

        @if (_cleanupResult is not null)
        {
            <div class="config-card @(_cleanupResult.Success ? "" : "config-card-danger")">
                <div class="config-card-body">
                    <h3 class="cleanup-result-title">@(_cleanupResult.Success ? "✅ Clean & Restart Complete" : "⚠️ Cleanup Completed with Errors")</h3>
                    <div class="cleanup-result-stats">
                        <span>Agents stopped: <strong>@_cleanupResult.AgentsStopped</strong></span>
                        <span>Issues deleted: <strong>@_cleanupResult.IssuesDeleted</strong></span>
                        @if (_cleanupResult.IssuesClosed > 0)
                        {
                            <span>Issues closed (delete failed): <strong>@_cleanupResult.IssuesClosed</strong></span>
                        }
                        <span>PRs closed: <strong>@_cleanupResult.PrsClosed</strong></span>
                        <span>PRs labeled "tested": <strong>@_cleanupResult.PrsLabeled</strong></span>
                        <span>Files deleted: <strong>@_cleanupResult.FilesDeleted</strong></span>
                        <span>Files preserved: <strong>@_cleanupResult.FilesPreserved</strong></span>
                        <span>Branches deleted: <strong>@_cleanupResult.BranchesDeleted</strong></span>
                        <span>Agents restarted: <strong>@_cleanupResult.AgentsStarted</strong></span>
                    </div>
                    @if (_cleanupResult.Success)
                    {
                        <p style="margin-top:8px;color:#3fb950;">🚀 A fresh project is now running — agents are starting from the Research phase.</p>
                    }
                    @if (_cleanupResult.Errors.Count > 0)
                    {
                        <details class="cleanup-errors">
                            <summary>@_cleanupResult.Errors.Count error(s)</summary>
                            <ul>
                                @foreach (var err in _cleanupResult.Errors)
                                {
                                    <li>@err</li>
                                }
                            </ul>
                        </details>
                    }
                </div>
            </div>
        }
    </div>
}

@* ═══════════════════════════════════════════════════════════════════
   CONFIRMATION MODAL — fully inlined styles to avoid any CSS conflicts.
   Only Cancel/✕ dismiss it (correct UX for destructive actions).
   ═══════════════════════════════════════════════════════════════════ *@
@if (_showModal)
{
    <div style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.6);z-index:9999;display:flex;align-items:center;justify-content:center;">
        <div style="background:#161b22;border:1px solid #30363d;border-radius:12px;width:600px;max-width:90vw;max-height:85vh;overflow-y:auto;box-shadow:0 16px 48px rgba(0,0,0,0.4);">
            <div class="modal-header modal-header-danger">
                <h3 class="modal-title">⚠️ Clean &amp; Restart Project</h3>
                <button class="modal-close" @onclick="HideCleanupModal">✕</button>
            </div>
            <div class="modal-body">
                <div class="modal-repo-badge">
                    <span class="cleanup-repo-icon">📦</span>
                    <strong>@_config?.Project.GitHubRepo</strong>
                </div>

                <div class="modal-impact">
                    <h4>This will clean the repo and kick off a fresh project:</h4>
                    <ul class="modal-impact-list">
                        <li class="impact-info">🛑 <strong>Stop all running agents</strong> (PM, Researcher, Architect, PE, TE)</li>
                        <li class="impact-danger">Delete <strong>@(_cleanupSummary?.TotalIssues ?? 0)</strong> issues (@(_cleanupSummary?.OpenIssues ?? 0) open, @(_cleanupSummary?.ClosedIssues ?? 0) closed)</li>
                        <li class="impact-danger">Close <strong>@(_cleanupSummary?.OpenPrs ?? 0)</strong> open pull requests</li>
                        <li class="impact-warning">Label <strong>@(_cleanupSummary?.MergedPrs ?? 0)</strong> merged PRs as "tested"</li>
                        <li class="impact-danger">Delete all agent branches</li>
                        <li class="impact-danger">Delete <strong>@(_cleanupSummary?.FileCount ?? 0)</strong> files from <code>@_config?.Project.DefaultBranch</code></li>
                        <li class="impact-info">🔄 <strong>Reset workflow state</strong> to Initialization (clear all signals &amp; checkpoints)</li>
                        <li class="impact-success">🚀 <strong>Restart all agents</strong> — begins a new project using current configuration</li>
                    </ul>
                    <p class="modal-project-note">
                        📋 <strong>New project:</strong> "@(_config?.Project.Name)" — agents will start fresh from Research phase
                        using the Project Description and settings configured above.
                    </p>
                    <p class="modal-irreversible">🚫 This action <strong>cannot be undone</strong>.</p>
                </div>

                <div class="modal-caveats">
                    <label class="modal-caveats-label">
                        Exceptions / Caveats <span class="config-hint">(optional)</span>
                    </label>
                    <textarea @bind="_cleanupCaveats" class="config-textarea modal-caveats-input"
                        rows="3" placeholder="e.g., Leave the Design.html file in the code, but remove everything else."></textarea>
                    <span class="config-hint">Mention any files or patterns to preserve. Files matching names you mention will be kept.</span>
                </div>
            </div>
            <div class="modal-footer">
                <button class="modal-cancel-btn" @onclick="HideCleanupModal">Cancel</button>
                <button class="modal-approve-btn" @onclick="ExecuteCleanup" disabled="@_cleaningUp">
                    @if (_cleaningUp)
                    {
                        <span class="config-spinner config-spinner-light"></span>
                        <span>@_cleanupPhase</span>
                    }
                    else
                    {
                        <span>🗑️ Clean &amp; Restart Project</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private AgentSquadConfig? _config;
    private bool _loading = true;
    private bool _saving;
    private bool _saveSuccess;
    private string? _saveError;

    // Section expand states
    private bool _projectExpanded = true;
    private bool _copilotExpanded = true;
    private bool _agentsExpanded = true;
    private bool _poolExpanded = true;
    private bool _limitsExpanded;
    private bool _dashboardExpanded;
    private bool _workspaceExpanded;
    private bool _humanInteractionExpanded;
    private bool _mcpServersExpanded;
    private bool _smeTemplatesExpanded;
    private bool _reviewExpanded;
    private bool _decisionGatingExpanded;
    private bool _agenticLoopExpanded;

    // Per-agent accordion expansion tracking
    private readonly HashSet<string> _expandedAgentPanels = new();

    // Secret visibility
    private bool _showToken;
    private bool _patIsFromSecrets;

    // Copilot reasoning effort helper (nullable string)
    private string _copilotReasoningEffort
    {
        get => _config?.CopilotCli.ReasoningEffort ?? "";
        set { if (_config is not null) _config.CopilotCli.ReasoningEffort = string.IsNullOrEmpty(value) ? null : value; }
    }

    // Review risk level helper (enum ↔ string binding)
    private string _minRiskLevel
    {
        get => _config?.Review.MinRiskLevelForHumanReview.ToString() ?? "None";
        set { if (_config is not null) _config.Review.MinRiskLevelForHumanReview = Enum.Parse<ReviewRiskLevel>(value); }
    }

    // Cleanup state
    private CleanupSummary? _cleanupSummary;
    private CleanupResult? _cleanupResult;
    private bool _scanning;
    private bool _showModal;
    private string _cleanupCaveats = "";
    private bool _cleaningUp;
    private string _cleanupPhase = "Cleaning up...";

    // PAT validation state
    private PatValidationResult? _patValidation;
    private bool _validatingPat;

    // Prompt template editor state
    private List<string>? _promptRoles;
    private readonly Dictionary<string, List<string>> _promptTemplates = new();
    private readonly Dictionary<string, Core.Prompts.PromptMetadata> _promptMetadata = new();
    private readonly Dictionary<string, string> _promptContents = new();
    private readonly HashSet<string> _expandedPromptRoles = new();
    private readonly HashSet<string> _expandedPromptTemplates = new();
    private readonly HashSet<string> _modifiedPrompts = new();
    private string? _promptSaveSuccess;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Deep-copy the config so edits don't affect the running system until save
            var current = ConfigService.GetCurrentConfig();
            _config = DeepCopy(current);

            // Detect if PAT came from User Secrets (non-empty PAT but appsettings.json has empty value)
            _patIsFromSecrets = !string.IsNullOrEmpty(_config.Project.GitHubToken);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load configuration");
        }
        finally
        {
            _loading = false;
        }

        // Scan repo in background so stats are ready when user scrolls down
        await Task.Yield(); // ensure UI renders before long network call
        _ = ScanRepoBackground();
        _ = LoadPromptRolesBackground();
    }

    private async Task ScanRepoBackground()
    {
        try
        {
            _scanning = true;
            await InvokeAsync(StateHasChanged);
            _cleanupSummary = await ConfigService.ScanRepoForCleanupAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Background repo scan failed");
        }
        finally
        {
            _scanning = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SaveConfig()
    {
        if (_config is null) return;
        _saving = true;
        _saveSuccess = false;
        _saveError = null;

        try
        {
            await ConfigService.SaveConfigAsync(_config);
            DataService.RefreshActiveModels();
            _saveSuccess = true;
            _ = Task.Run(async () =>
            {
                await Task.Delay(3000);
                _saveSuccess = false;
                await InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
            Logger.LogError(ex, "Failed to save configuration");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ScanRepo()
    {
        _scanning = true;
        _cleanupSummary = null;
        _cleanupResult = null;
        StateHasChanged();

        try
        {
            _cleanupSummary = await ConfigService.ScanRepoForCleanupAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to scan repo");
        }
        finally
        {
            _scanning = false;
        }
    }

    private void ShowCleanupModal() => _showModal = true;
    private void HideCleanupModal() => _showModal = false;

    private async Task ExecuteCleanup()
    {
        _cleaningUp = true;
        _cleanupPhase = "Stopping agents...";
        StateHasChanged();

        try
        {
            // Run cleanup in a background task so we can update UI with phase progress
            _cleanupResult = await Task.Run(async () =>
            {
                var result = await ConfigService.ExecuteCleanupAsync(_cleanupCaveats);
                return result;
            });

            _showModal = false;
            _cleanupSummary = null; // clear stale scan

            // After cleanup + restart, re-scan for the (now empty) repo state
            _ = Task.Run(async () =>
            {
                await Task.Delay(2000); // let agents settle
                await InvokeAsync(async () =>
                {
                    await ScanRepoBackground();
                    StateHasChanged();
                });
            });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Cleanup failed");
            _cleanupResult = new CleanupResult
            {
                Errors = { $"Cleanup failed: {ex.Message}" }
            };
        }
        finally
        {
            _cleaningUp = false;
            _cleanupPhase = "Cleaning up...";
        }
    }

