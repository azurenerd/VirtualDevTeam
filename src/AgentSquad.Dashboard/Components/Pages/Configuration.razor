    private async Task LoadPromptRolesBackground()
    {
        try
        {
            var roles = PromptService.ListRoles();
            _promptRoles = roles.OrderBy(r => r).ToList();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load prompt roles");
        }
    }

    private async void TogglePromptRole(string role)
    {
        if (!_expandedPromptRoles.Remove(role))
        {
            _expandedPromptRoles.Add(role);
            // Lazy-load templates for this role
            if (!_promptTemplates.ContainsKey(role))
            {
                var templates = PromptService.ListTemplates(role);
                _promptTemplates[role] = templates.OrderBy(t => t).ToList();
            }
        }
        await InvokeAsync(StateHasChanged);
    }

    private async void TogglePromptTemplate(string key)
    {
        if (!_expandedPromptTemplates.Remove(key))
        {
            _expandedPromptTemplates.Add(key);
            // Lazy-load content and metadata
            if (!_promptContents.ContainsKey(key))
            {
                try
                {
                    var content = await PromptService.GetRawContentAsync(key);
                    _promptContents[key] = content ?? "";

                    var metadata = await PromptService.GetMetadataAsync(key);
                    if (metadata is not null)
                    {
                        _promptMetadata[key] = metadata;
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Failed to load prompt template {Key}", key);
                    _promptContents[key] = $"Error loading template: {ex.Message}";
                }
            }
        }
        await InvokeAsync(StateHasChanged);
    }

    private string GetPromptContent(string key) =>
        _promptContents.TryGetValue(key, out var content) ? content : "";

    private void SetPromptContent(string key, string value)
    {
        _promptContents[key] = value;
        _modifiedPrompts.Add(key);
    }

    private int GetTemplateCount(string role) =>
        _promptTemplates.TryGetValue(role, out var t) ? t.Count : 0;

    private async Task SavePromptTemplate(string key)
    {
        try
        {
            if (_promptContents.TryGetValue(key, out var content))
            {
                await PromptService.SaveRawContentAsync(key, content);
                _modifiedPrompts.Remove(key);
                _promptSaveSuccess = key;
                StateHasChanged();
                _ = ClearPromptSaveSuccess(key);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save prompt template {Key}", key);
        }
    }

    private async Task ResetPromptTemplate(string key)
    {
        try
        {
            var promptsBase = Path.GetFullPath(SquadConfig.Value.Prompts.BasePath);
            var defaultsPath = Path.Combine(Path.GetDirectoryName(promptsBase)!, "prompts-defaults");
            var defaultFile = Path.Combine(defaultsPath, key + ".md");
            if (File.Exists(defaultFile))
            {
                var defaultContent = await File.ReadAllTextAsync(defaultFile);
                await PromptService.SaveRawContentAsync(key, defaultContent);
                _promptContents[key] = defaultContent;
                _modifiedPrompts.Remove(key);
                _promptSaveSuccess = key;
                StateHasChanged();
                _ = ClearPromptSaveSuccess(key);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to reset prompt template {Key}", key);
        }
    }

    private async Task ClearPromptSaveSuccess(string key)
    {
        await Task.Delay(2000);
        if (_promptSaveSuccess == key)
        {
            _promptSaveSuccess = null;
            await InvokeAsync(StateHasChanged);
        }
    }

