@page "/engineering-plan"
@using AgentSquad.Dashboard.Services
@using Microsoft.JSInterop
@inject EngineeringPlanDataService PlanService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer
@implements IAsyncDisposable

<div class="ep-page">
    @* ── Header ──────────────────────────────────────────────── *@
    <div class="ep-header">
        <div class="ep-header-left">
            <h1 class="ep-title">🗺️ Engineering Plan</h1>
            @if (_plan is not null && _plan.Stats.Total > 0)
            {
                <div class="ep-progress-wrap">
                    <div class="ep-progress-bar">
                        <div class="ep-progress-fill" style="width: @(_plan.Stats.ProgressPercent)%"></div>
                    </div>
                    <span class="ep-progress-text">@(_plan.Stats.ProgressPercent)%</span>
                </div>
            }
        </div>
        <div class="ep-header-badges">
            @if (_plan is not null)
            {
                <span class="badge badge-ep-done">✅ @_plan.Stats.Done Done</span>
                <span class="badge badge-ep-progress">🔄 @_plan.Stats.InProgress In Progress</span>
                <span class="badge badge-ep-pending">⏳ @(_plan.Stats.Pending + _plan.Stats.Blocked) Pending</span>
                <span class="badge badge-ep-total">📦 @_plan.Stats.Total Total</span>
            }
        </div>
    </div>

    @* ── Toolbar ─────────────────────────────────────────────── *@
    <div class="ep-toolbar">
        <div class="ep-toolbar-group">
            <button class="ep-btn" @onclick="RefreshAsync" title="Refresh data">
                🔄 Refresh
            </button>
            <button class="ep-btn" @onclick="FitGraph" title="Fit graph to viewport">
                🔲 Fit
            </button>
            <button class="ep-btn" @onclick="ZoomIn" title="Zoom in">➕</button>
            <button class="ep-btn" @onclick="ZoomOut" title="Zoom out">➖</button>
        </div>
        <div class="ep-toolbar-group">
            <span class="ep-toolbar-label">Layout:</span>
            <button class="ep-btn @(_layout == "dagre" ? "ep-btn-active" : "")" @onclick='() => ChangeLayout("dagre")'>
                ↕️ Hierarchy
            </button>
            <button class="ep-btn @(_layout == "breadthfirst" ? "ep-btn-active" : "")" @onclick='() => ChangeLayout("breadthfirst")'>
                🌳 Tree
            </button>
            <button class="ep-btn @(_layout == "circle" ? "ep-btn-active" : "")" @onclick='() => ChangeLayout("circle")'>
                ⭕ Circle
            </button>
        </div>
        @if (_lastRefresh.HasValue)
        {
            <span class="ep-toolbar-timestamp">
                Updated @_lastRefresh.Value.ToLocalTime().ToString("HH:mm:ss")
                @if (_autoRefresh)
                {
                    <span class="ep-auto-badge">AUTO</span>
                }
            </span>
        }
    </div>

    @* ── Main Content Area ───────────────────────────────────── *@
    <div class="ep-content">
        @if (_loading)
        {
            <div class="ep-loading">
                <div class="ep-spinner"></div>
                <span>Loading engineering plan...</span>
            </div>
        }
        else if (_plan is null || _plan.Stats.Total == 0)
        {
            <div class="ep-empty">
                <div class="ep-empty-icon">🗺️</div>
                <h2>No Engineering Tasks Yet</h2>
                <p>Engineering tasks will appear here once the Principal Engineer creates the engineering plan.</p>
            </div>
        }
        else
        {
            @* Graph Canvas *@
            <div id="cy" class="ep-graph-container"></div>

            @* Legend *@
            <div class="ep-legend">
                <div class="ep-legend-title">Status</div>
                <div class="ep-legend-item"><span class="ep-legend-dot" style="background:#3fb950"></span> Done</div>
                <div class="ep-legend-item"><span class="ep-legend-dot ep-dot-pulse" style="background:#00d4ff"></span> In Progress</div>
                <div class="ep-legend-item"><span class="ep-legend-dot" style="background:#d29922"></span> Assigned</div>
                <div class="ep-legend-item"><span class="ep-legend-dot" style="background:#484f58"></span> Pending</div>
                <div class="ep-legend-title" style="margin-top:8px">Complexity</div>
                <div class="ep-legend-item"><span class="ep-legend-rect ep-rect-lg"></span> High</div>
                <div class="ep-legend-item"><span class="ep-legend-rect ep-rect-md"></span> Medium</div>
                <div class="ep-legend-item"><span class="ep-legend-rect ep-rect-sm"></span> Low</div>
                <div class="ep-legend-hint">Double-click → GitHub</div>
            </div>
        }

        @* ── Detail Panel (slide-out) ────────────────────────── *@
        @if (_selectedNode is not null)
        {
            <div class="ep-detail-panel @(_detailOpen ? "open" : "")">
                <div class="ep-detail-header">
                    <h3>@StatusIcon(_selectedNode.Status) #@_selectedNode.IssueNumber</h3>
                    <button class="ep-detail-close" @onclick="CloseDetail">✕</button>
                </div>
                <div class="ep-detail-body">
                    <div class="ep-detail-title">@_selectedNode.Title</div>

                    <div class="ep-detail-row">
                        <span class="ep-detail-label">Status</span>
                        <span class="ep-detail-badge ep-status-@_selectedNode.Status.ToLower()">@_selectedNode.Status</span>
                    </div>

                    @if (!string.IsNullOrEmpty(_selectedNode.Complexity))
                    {
                        <div class="ep-detail-row">
                            <span class="ep-detail-label">Complexity</span>
                            <span class="ep-detail-value">@_selectedNode.Complexity</span>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_selectedNode.AssignedTo))
                    {
                        <div class="ep-detail-row">
                            <span class="ep-detail-label">Assigned To</span>
                            <span class="ep-detail-value">👤 @_selectedNode.AssignedTo</span>
                        </div>
                    }

                    @if (_selectedNode.PullRequestNumber.HasValue)
                    {
                        <div class="ep-detail-row">
                            <span class="ep-detail-label">Pull Request</span>
                            <a class="ep-detail-link" href="@GetPrUrl(_selectedNode.PullRequestNumber.Value)" target="_blank">
                                PR #@_selectedNode.PullRequestNumber
                            </a>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_selectedNode.IssueUrl))
                    {
                        <div class="ep-detail-row">
                            <a class="ep-btn ep-btn-github" href="@_selectedNode.IssueUrl" target="_blank">
                                🔗 View on GitHub
                            </a>
                        </div>
                    }

                    @* Dependencies *@
                    @{
                        var deps = _plan?.Edges.Where(e => e.Target == _selectedNode.Id && e.Label == "blocks").ToList();
                        var dependents = _plan?.Edges.Where(e => e.Source == _selectedNode.Id && e.Label == "blocks").ToList();
                    }
                    @if (deps?.Count > 0)
                    {
                        <div class="ep-detail-section">
                            <span class="ep-detail-label">Depends On</span>
                            @foreach (var dep in deps)
                            {
                                var depNode = _plan?.Nodes.FirstOrDefault(n => n.Id == dep.Source);
                                if (depNode is not null)
                                {
                                    <div class="ep-dep-chip" @onclick="() => SelectNodeById(depNode.Id)">
                                        @StatusIcon(depNode.Status) #@depNode.IssueNumber @depNode.Title
                                    </div>
                                }
                            }
                        </div>
                    }
                    @if (dependents?.Count > 0)
                    {
                        <div class="ep-detail-section">
                            <span class="ep-detail-label">Blocks</span>
                            @foreach (var dep in dependents)
                            {
                                var depNode = _plan?.Nodes.FirstOrDefault(n => n.Id == dep.Target);
                                if (depNode is not null)
                                {
                                    <div class="ep-dep-chip" @onclick="() => SelectNodeById(depNode.Id)">
                                        @StatusIcon(depNode.Status) #@depNode.IssueNumber @depNode.Title
                                    </div>
                                }
                            }
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_selectedNode.Description))
                    {
                        <div class="ep-detail-section">
                            <span class="ep-detail-label">Description</span>
                            <div class="ep-detail-desc">@_selectedNode.Description</div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    private EngineeringPlanViewModel? _plan;
    private TaskNode? _selectedNode;
    private bool _detailOpen;
    private bool _loading = true;
    private bool _autoRefresh = true;
    private string _layout = "dagre";
    private DateTime? _lastRefresh;
    private System.Timers.Timer? _refreshTimer;
    private DotNetObjectReference<EngineeringPlan>? _objRef;
    private bool _graphInitialized;
    private string _repoUrl = "";

    protected override async Task OnInitializedAsync()
    {
        _objRef = DotNetObjectReference.Create(this);
        _plan = await PlanService.GetPlanAsync(ct: default);
        _lastRefresh = DateTime.UtcNow;
        _loading = false;

        // Derive repo URL from first issue URL
        var firstUrl = _plan?.Nodes.FirstOrDefault()?.IssueUrl ?? "";
        if (firstUrl.Contains("/issues/"))
            _repoUrl = firstUrl[..firstUrl.IndexOf("/issues/")];

        // Auto-refresh timer
        _refreshTimer = new System.Timers.Timer(30_000);
        _refreshTimer.Elapsed += async (_, _) =>
        {
            if (_autoRefresh)
            {
                await RefreshDataOnlyAsync();
            }
        };
        _refreshTimer.Start();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_plan is not null && _plan.Stats.Total > 0 && !_graphInitialized)
        {
            try
            {
                // Small delay to ensure DOM is fully painted after Blazor diff
                await Task.Delay(150);
                await JS.InvokeVoidAsync("EngineeringPlan.init", "cy", _objRef);
                await PushGraphDataAsync();
                _graphInitialized = true;
            }
            catch (Exception ex)
            {
                // JS interop can fail during prerendering; allow retry on next render
                Console.WriteLine($"[EngineeringPlan] Graph init failed: {ex.Message}");
            }
        }
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        StateHasChanged();

        _plan = await PlanService.GetPlanAsync(forceRefresh: true);
        _lastRefresh = DateTime.UtcNow;
        _loading = false;

        if (_graphInitialized)
            await PushGraphDataAsync();

        StateHasChanged();
    }

    private async Task RefreshDataOnlyAsync()
    {
        try
        {
            _plan = await PlanService.GetPlanAsync(forceRefresh: true);
            _lastRefresh = DateTime.UtcNow;

            if (_graphInitialized)
                await InvokeAsync(async () =>
                {
                    await PushGraphDataAsync();
                    StateHasChanged();
                });
        }
        catch { /* Suppress timer errors */ }
    }

    private async Task PushGraphDataAsync()
    {
        if (_plan is null) return;

        var nodes = _plan.Nodes.Select(n => new
        {
            id = n.Id,
            issueNumber = n.IssueNumber,
            title = n.Title,
            status = n.Status,
            nodeType = n.NodeType,
            complexity = n.Complexity,
            assignedTo = n.AssignedTo ?? "",
            prNumber = n.PullRequestNumber,
            issueUrl = n.IssueUrl
        });

        var edges = _plan.Edges.Select(e => new
        {
            source = e.Source,
            target = e.Target,
            label = e.Label
        });

        var nodesJson = System.Text.Json.JsonSerializer.Serialize(nodes);
        var edgesJson = System.Text.Json.JsonSerializer.Serialize(edges);

        await JS.InvokeVoidAsync("EngineeringPlan.update", nodesJson, edgesJson);
    }

    [JSInvokable]
    public Task OnNodeClicked(string nodeDataJson)
    {
        try
        {
            var data = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(nodeDataJson);
            var issueNumber = data.GetProperty("issueNumber").GetInt32();
            _selectedNode = _plan?.Nodes.FirstOrDefault(n => n.IssueNumber == issueNumber);
            _detailOpen = _selectedNode is not null;
            InvokeAsync(StateHasChanged);
        }
        catch { /* Ignore parse errors */ }
        return Task.CompletedTask;
    }

    private async Task SelectNodeById(string nodeId)
    {
        _selectedNode = _plan?.Nodes.FirstOrDefault(n => n.Id == nodeId);
        _detailOpen = _selectedNode is not null;
        if (_graphInitialized && _selectedNode is not null)
        {
            await JS.InvokeVoidAsync("EngineeringPlan.highlightNode", nodeId);
        }
    }

    private void CloseDetail()
    {
        _detailOpen = false;
        _selectedNode = null;
        _ = JS.InvokeVoidAsync("EngineeringPlan.clearHighlights");
    }

    private async Task FitGraph() => await JS.InvokeVoidAsync("EngineeringPlan.fitGraph");
    private async Task ZoomIn() => await JS.InvokeVoidAsync("EngineeringPlan.zoomIn");
    private async Task ZoomOut() => await JS.InvokeVoidAsync("EngineeringPlan.zoomOut");

    private async Task ChangeLayout(string layout)
    {
        _layout = layout;
        await JS.InvokeVoidAsync("EngineeringPlan.changeLayout", layout);
    }

    private string GetPrUrl(int prNumber) => string.IsNullOrEmpty(_repoUrl) ? "#" : $"{_repoUrl}/pull/{prNumber}";

    private static string StatusIcon(string status) => status switch
    {
        "Done" => "✅",
        "InProgress" => "🔄",
        "Assigned" => "👤",
        "Blocked" => "🔒",
        _ => "⏳"
    };

    public async ValueTask DisposeAsync()
    {
        _refreshTimer?.Stop();
        _refreshTimer?.Dispose();
        if (_graphInitialized)
        {
            try { await JS.InvokeVoidAsync("EngineeringPlan.destroy"); } catch { }
        }
        _objRef?.Dispose();
    }
}
