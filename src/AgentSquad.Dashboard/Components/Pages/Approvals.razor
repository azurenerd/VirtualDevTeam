@page "/approvals"
@rendermode InteractiveServer
@using AgentSquad.Core.Notifications
@using AgentSquad.Core.Agents.Decisions
@using AgentSquad.Dashboard.Services
@implements IDisposable
@inject IServiceProvider ServiceProvider

<PageTitle>AgentSquad — Approvals</PageTitle>

<div class="dashboard-header">
    <h1>🚦 Approvals</h1>
    <div class="header-badges">
        <span class="header-badge @(_openCount > 0 ? "warning" : "healthy")">
            @_openCount Open
        </span>
        @if (_pendingDecisionCount > 0)
        {
            <span class="header-badge warning">⚖️ @_pendingDecisionCount Decision Gates</span>
        }
        <span class="header-badge">@_resolvedCount Resolved</span>
    </div>
</div>

<div class="approval-filters">
    <button class="filter-btn @(_filter == NotificationFilter.Open ? "active" : "")"
            @onclick="() => SetFilter(NotificationFilter.Open)">
        Open @if (_openCount > 0) { <span class="filter-count">@_openCount</span> }
    </button>
    <button class="filter-btn @(_filter == NotificationFilter.Resolved ? "active" : "")"
            @onclick="() => SetFilter(NotificationFilter.Resolved)">
        Resolved
    </button>
    <button class="filter-btn @(_filter == NotificationFilter.All ? "active" : "")"
            @onclick="() => SetFilter(NotificationFilter.All)">
        All
    </button>
</div>

@* ── Pending Decision Gates ── *@
@if (_pendingDecisions.Count > 0 && _filter != NotificationFilter.Resolved)
{
    <div class="decision-gates-section">
        <h3>⚖️ Decision Gates Awaiting Review</h3>
        @foreach (var decision in _pendingDecisions)
        {
            <div class="approval-card decision-gate open">
                <div class="approval-card-left">
                    <div class="approval-icon">
                        <span class="impact-badge impact-@decision.ImpactLevel.ToString().ToLower()">@decision.ImpactLevel</span>
                    </div>
                </div>
                <div class="approval-card-body">
                    <div class="approval-card-header">
                        <span class="approval-gate-name">⚖️ @decision.Title</span>
                        <span class="approval-resource-badge">@decision.AgentDisplayName</span>
                        <span class="approval-time">@FormatTime(decision.CreatedAt)</span>
                    </div>
                    <div class="approval-context">
                        <strong>Rationale:</strong> @decision.Rationale
                    </div>
                    @if (!string.IsNullOrEmpty(decision.Alternatives))
                    {
                        <div class="decision-detail-field">
                            <strong>Alternatives Considered:</strong> @decision.Alternatives
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(decision.AffectedFiles))
                    {
                        <div class="decision-detail-field">
                            <strong>Affected Files:</strong> @decision.AffectedFiles
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(decision.RiskAssessment))
                    {
                        <div class="decision-detail-field">
                            <strong>Risk Assessment:</strong> @decision.RiskAssessment
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(decision.Plan))
                    {
                        <details class="decision-plan-detail">
                            <summary>📋 View Implementation Plan</summary>
                            <pre class="decision-plan-content">@decision.Plan</pre>
                        </details>
                    }

                    @* Feedback + Approve/Reject *@
                    <div class="decision-actions">
                        <input type="text" class="decision-feedback-input"
                               placeholder="Optional feedback..."
                               @bind="_feedbackInputs[decision.Id]" />
                        <button class="decision-approve-btn" @onclick="() => ApproveDecision(decision.Id)">
                            ✅ Approve
                        </button>
                        <button class="decision-reject-btn" @onclick="() => RejectDecision(decision.Id)">
                            ❌ Reject
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* ── Standard Gate Notifications ── *@
@if (_notifications.Count == 0 && _pendingDecisions.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">✅</div>
        <div class="empty-text">
            @if (_filter == NotificationFilter.Open)
            {
                <span>No gates awaiting approval</span>
            }
            else if (_filter == NotificationFilter.Resolved)
            {
                <span>No resolved approvals yet</span>
            }
            else
            {
                <span>No gate notifications</span>
            }
        </div>
        <div class="empty-sub">Gate approval requests from agents will appear here</div>
    </div>
}
else if (_notifications.Count > 0)
{
    <div class="approvals-list">
        @foreach (var gate in _notifications)
        {
            var isProjectComplete = gate.GateName.Contains("Project Complete", StringComparison.OrdinalIgnoreCase);
            var isDecisionGate = gate.GateId.StartsWith(DecisionGateService.DecisionGatePrefix);

            @if (!isDecisionGate)
            {
                <div class="approval-card @(gate.IsResolved ? "resolved" : "open") @(isProjectComplete ? "project-complete" : "")">
                    <div class="approval-card-left">
                        <div class="approval-icon">
                            @if (isProjectComplete) { <span>🎉</span> }
                            else if (gate.IsResolved) { <span>✅</span> }
                            else { <span>🚦</span> }
                        </div>
                    </div>
                    <div class="approval-card-body">
                        <div class="approval-card-header">
                            <span class="approval-gate-name">@gate.GateName</span>
                            @if (gate.ResourceType is not null && gate.ResourceNumber is not null)
                            {
                                <span class="approval-resource-badge">@gate.ResourceType #@gate.ResourceNumber</span>
                            }
                            <span class="approval-time">@FormatTime(gate.CreatedAt)</span>
                        </div>
                        <div class="approval-context">@gate.Context</div>
                        @if (gate.IsResolved && gate.ResolvedAt.HasValue)
                        {
                            <div class="approval-resolved-info">
                                ✅ @(isProjectComplete ? "Completed" : "Approved") @FormatTime(gate.ResolvedAt.Value)
                            </div>
                        }
                    </div>
                    <div class="approval-card-actions">
                        @if (gate.GitHubUrl is not null)
                        {
                            <a class="approval-action-btn review-btn" href="@gate.GitHubUrl" target="_blank" rel="noopener">
                                Review on GitHub ↗
                            </a>
                        }
                        @if (!gate.IsResolved && !isProjectComplete)
                        {
                            <span class="approval-status-pill pending">Awaiting Review</span>
                        }
                        else if (gate.IsResolved)
                        {
                            <span class="approval-status-pill approved">@(isProjectComplete ? "Complete" : "Approved")</span>
                        }
                    </div>
                </div>
            }
        }
    </div>
}

@code {
    private NotificationFilter _filter = NotificationFilter.Open;
    private IReadOnlyList<GateNotification> _notifications = Array.Empty<GateNotification>();
    private IReadOnlyList<AgentDecision> _pendingDecisions = Array.Empty<AgentDecision>();
    private Dictionary<string, string> _feedbackInputs = new();
    private int _openCount;
    private int _resolvedCount;
    private int _pendingDecisionCount;

    private GateNotificationService? _inProcessService;
    private HttpGateNotificationService? _httpService;
    private IDecisionLog? _decisionLog;
    private DecisionGateService? _decisionGateService;

    protected override void OnInitialized()
    {
        _httpService = ServiceProvider.GetService<HttpGateNotificationService>();
        _inProcessService = ServiceProvider.GetService<GateNotificationService>();
        _decisionLog = ServiceProvider.GetService<IDecisionLog>();
        _decisionGateService = ServiceProvider.GetService<DecisionGateService>();

        if (_httpService is not null)
            _httpService.OnChange += OnChange;
        else if (_inProcessService is not null)
            _inProcessService.OnChange += OnChange;

        if (_decisionLog is not null)
            _decisionLog.OnDecisionChanged += OnDecisionChange;

        RefreshData();
    }

    private void OnChange()
    {
        InvokeAsync(() =>
        {
            RefreshData();
            StateHasChanged();
        });
    }

    private void OnDecisionChange(AgentDecision _)
    {
        InvokeAsync(() =>
        {
            RefreshData();
            StateHasChanged();
        });
    }

    private void SetFilter(NotificationFilter filter)
    {
        _filter = filter;
        RefreshData();
    }

    private void RefreshData()
    {
        if (_httpService is not null)
        {
            _notifications = _httpService.GetByStatus(_filter);
            _openCount = _httpService.OpenCount;
            _resolvedCount = _httpService.ResolvedCount;
        }
        else if (_inProcessService is not null)
        {
            _notifications = _inProcessService.GetByStatus(_filter);
            _openCount = _inProcessService.OpenCount;
            _resolvedCount = _inProcessService.ResolvedCount;
        }

        // Get pending decisions
        if (_decisionLog is not null)
        {
            _pendingDecisions = _decisionLog.GetPendingDecisions();
            _pendingDecisionCount = _pendingDecisions.Count;

            // Ensure feedback inputs exist for each pending decision
            foreach (var d in _pendingDecisions)
            {
                _feedbackInputs.TryAdd(d.Id, "");
            }
        }
    }

    private void ApproveDecision(string decisionId)
    {
        var feedback = _feedbackInputs.GetValueOrDefault(decisionId, "");
        _decisionGateService?.ApproveDecision(decisionId, string.IsNullOrWhiteSpace(feedback) ? null : feedback);
        _feedbackInputs.Remove(decisionId);
        RefreshData();
    }

    private void RejectDecision(string decisionId)
    {
        var feedback = _feedbackInputs.GetValueOrDefault(decisionId, "");
        _decisionGateService?.RejectDecision(decisionId, string.IsNullOrWhiteSpace(feedback) ? null : feedback);
        _feedbackInputs.Remove(decisionId);
        RefreshData();
    }

    private static string FormatTime(DateTime dt)
    {
        var ago = DateTime.UtcNow - dt;
        if (ago.TotalSeconds < 60) return "just now";
        if (ago.TotalMinutes < 60) return $"{(int)ago.TotalMinutes}m ago";
        if (ago.TotalHours < 24) return $"{(int)ago.TotalHours}h ago";
        return dt.ToLocalTime().ToString("MMM d, HH:mm");
    }

    public void Dispose()
    {
        if (_httpService is not null)
            _httpService.OnChange -= OnChange;
        else if (_inProcessService is not null)
            _inProcessService.OnChange -= OnChange;

        if (_decisionLog is not null)
            _decisionLog.OnDecisionChanged -= OnDecisionChange;
    }
}
