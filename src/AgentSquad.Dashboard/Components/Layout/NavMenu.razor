@using AgentSquad.Core.Notifications
@using AgentSquad.Dashboard.Services
@inject DashboardMode Mode
@inject IServiceProvider ServiceProvider
@implements IDisposable

<div class="sidebar-brand">
    <div class="brand-logo">
        <span class="brand-logo-icon">⚡</span>
    </div>
    <div class="brand-text">
        <div class="brand-title">Virtual Dev Team</div>
        <div class="brand-subtitle">@(Mode.IsStandalone ? "Monitoring Dashboard" : "Runner Admin")</div>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-section-label">Main</div>

        <div class="nav-item" data-testid="nav-overview">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon">🏠</span> Overview
            </NavLink>
        </div>

        <div class="nav-item" data-testid="nav-features">
            <NavLink class="nav-link" href="features">
                <span class="nav-icon">⭐</span> Features
            </NavLink>
        </div>

        <div class="nav-item" data-testid="nav-configuration">
            <NavLink class="nav-link" href="configuration">
                <span class="nav-icon">⚙️</span> Configuration
            </NavLink>
        </div>

        @* Strategies page is accessible in both Runner-embedded and standalone modes
           so operators can observe live candidate runs from the Runner dashboard
           (localhost:5050) during val-e2e. Service registration differs per host:
           InProcessStrategiesDataService in Runner, HttpStrategiesDataService in
           the standalone dashboard. *@
        <div class="nav-item" data-testid="nav-strategies">
            <NavLink class="nav-link" href="strategies">
                <span class="nav-icon">🧪</span> Frameworks
            </NavLink>
        </div>

        @if (Mode.IsStandalone)
        {
            <div class="nav-section-label">Project</div>

            <div class="nav-item" data-testid="nav-timeline">
                <NavLink class="nav-link" href="timeline">
                    <span class="nav-icon">🗺️</span> Project Timeline
                </NavLink>
            </div>

            <div class="nav-item" data-testid="nav-repository">
                <NavLink class="nav-link" href="repository">
                    <span class="nav-icon">📦</span> Repository
                </NavLink>
            </div>

            <div class="nav-section-label">Operations</div>

            <div class="nav-item" data-testid="nav-metrics">
                <NavLink class="nav-link" href="metrics">
                    <span class="nav-icon">📊</span> Metrics
                </NavLink>
            </div>

            <div class="nav-item" data-testid="nav-health">
                <NavLink class="nav-link" href="health">
                    <span class="nav-icon">🩺</span> Health Monitor
                </NavLink>
            </div>

            <div class="nav-item" data-testid="nav-approvals">
                <NavLink class="nav-link" href="approvals">
                    <span class="nav-icon">🚦</span> Approvals
                    @if (_openGateCount > 0)
                    {
                        <span class="nav-badge" data-testid="nav-approvals-badge">@_openGateCount</span>
                    }
                </NavLink>
            </div>

            <div class="nav-item" data-testid="nav-team">
                <NavLink class="nav-link" href="team">
                    <span class="nav-icon">👥</span> Team View
                </NavLink>
            </div>

            <div class="nav-item" data-testid="nav-pipelines">
                <NavLink class="nav-link" href="pipelines">
                    <span class="nav-icon">🔧</span> Pipelines
                </NavLink>
            </div>

            <div class="nav-section-label">Advanced</div>

            <div class="nav-item" data-testid="nav-reasoning">
                <NavLink class="nav-link" href="reasoning">
                    <span class="nav-icon">🧠</span> Reasoning
                </NavLink>
            </div>

            <div class="nav-item" data-testid="nav-director-cli">
                <NavLink class="nav-link" href="director-cli">
                    <span class="nav-icon">💻</span> Director CLI
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private int _openGateCount;
    private GateNotificationService? _inProcessService;
    private HttpGateNotificationService? _httpService;

    protected override void OnInitialized()
    {
        _httpService = ServiceProvider.GetService<HttpGateNotificationService>();
        _inProcessService = ServiceProvider.GetService<GateNotificationService>();

        if (_httpService is not null)
            _httpService.OnChange += OnNotificationChange;
        else if (_inProcessService is not null)
            _inProcessService.OnChange += OnNotificationChange;

        RefreshCount();
    }

    private void OnNotificationChange()
    {
        InvokeAsync(() =>
        {
            RefreshCount();
            StateHasChanged();
        });
    }

    private void RefreshCount()
    {
        _openGateCount = _httpService?.OpenCount ?? _inProcessService?.OpenCount ?? 0;
    }

    public void Dispose()
    {
        if (_httpService is not null)
            _httpService.OnChange -= OnNotificationChange;
        else if (_inProcessService is not null)
            _inProcessService.OnChange -= OnNotificationChange;
    }
}
