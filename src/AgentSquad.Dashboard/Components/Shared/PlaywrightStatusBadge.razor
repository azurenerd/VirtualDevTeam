@using AgentSquad.Core.Workspace
@using System.Net.Http.Json
@inject IServiceProvider ServiceProvider
@implements IDisposable

<div class="playwright-badge @StatusClass" title="@TooltipText">
    <span class="playwright-badge-icon">@StatusIcon</span>
    <span class="playwright-badge-text">Playwright</span>
</div>

@code {
    private bool _isReady;
    private string? _reason;
    private DateTime? _lastValidated;
    private Timer? _refreshTimer;
    private PlaywrightRunner? _runner;
    private HttpClient? _http;

    private string StatusClass => _isReady ? "pw-ready" : "pw-not-ready";
    private string StatusIcon => _isReady ? "🟢" : "🔴";
    private string TooltipText => _isReady
        ? $"Playwright ready — last validated {FormatTime(_lastValidated)}"
        : $"Playwright not ready: {_reason ?? "checking..."}";

    protected override void OnInitialized()
    {
        _runner = ServiceProvider.GetService<PlaywrightRunner>();

        if (_runner is null)
        {
            // Standalone mode — use named HTTP client with correct base address
            var factory = ServiceProvider.GetService<IHttpClientFactory>();
            _http = factory?.CreateClient("RunnerApi");
        }

        if (_runner is not null)
        {
            _isReady = _runner.IsReady;
            _reason = _runner.NotReadyReason;
            _lastValidated = _runner.LastValidatedUtc;
            _runner.ReadyStateChanged += OnReadyStateChanged;
        }

        // Poll for updates (covers standalone HTTP mode and initial startup delay)
        _refreshTimer = new Timer(async _ => await RefreshAsync(), null,
            TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(15));
    }

    private async Task RefreshAsync()
    {
        try
        {
            if (_runner is not null)
            {
                _isReady = _runner.IsReady;
                _reason = _runner.NotReadyReason;
                _lastValidated = _runner.LastValidatedUtc;
            }
            else if (_http is not null)
            {
                // Standalone mode — fetch from Runner API
                var result = await _http.GetFromJsonAsync<PlaywrightStatusDto>("/api/dashboard/health/playwright");
                if (result is not null)
                {
                    _isReady = result.IsReady;
                    _reason = result.NotReadyReason;
                    _lastValidated = result.LastValidatedUtc;
                }
            }

            await InvokeAsync(StateHasChanged);
        }
        catch { /* Runner not reachable yet */ }
    }

    private void OnReadyStateChanged(bool ready)
    {
        _isReady = ready;
        _reason = _runner?.NotReadyReason;
        _lastValidated = _runner?.LastValidatedUtc;
        InvokeAsync(StateHasChanged);
    }

    private static string FormatTime(DateTime? utc)
    {
        if (utc is null) return "never";
        var ago = DateTime.UtcNow - utc.Value;
        return ago.TotalMinutes < 1 ? "just now"
            : ago.TotalMinutes < 60 ? $"{(int)ago.TotalMinutes}m ago"
            : $"{(int)ago.TotalHours}h ago";
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        if (_runner is not null)
            _runner.ReadyStateChanged -= OnReadyStateChanged;
    }

    private record PlaywrightStatusDto(bool IsReady, string? NotReadyReason, DateTime? LastValidatedUtc);
}
