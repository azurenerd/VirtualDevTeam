{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AgentSquad": {
    "Project": {
      "Name": "My Project",
      "Description": "Describe your project here",
      "GitHubRepo": "owner/repo-name",
      "GitHubToken": "<YOUR_GITHUB_PAT>",
      "DefaultBranch": "main",
      "TechStack": "C# .NET 8 with Blazor Server",
      "ExecutiveGitHubUsername": "azurenerd",
      "BaselineCommitSha": "",
      "ResearchPrompt": "",
      "QuickDocumentCreation": false
    },
    "Models": {
      "premium": {
        "Provider": "anthropic",
        "Model": "claude-opus-4.6",
        "ApiKey": "<YOUR_ANTHROPIC_API_KEY>",
        "MaxTokensPerRequest": 8192,
        "Temperature": 0.3
      },
      "standard": {
        "Provider": "anthropic",
        "Model": "claude-sonnet-4",
        "ApiKey": "<YOUR_ANTHROPIC_API_KEY>",
        "MaxTokensPerRequest": 4096,
        "Temperature": 0.3
      },
      "budget": {
        "Provider": "openai",
        "Model": "gpt-4.1-mini",
        "ApiKey": "<YOUR_OPENAI_API_KEY>",
        "MaxTokensPerRequest": 4096,
        "Temperature": 0.3
      },
      "local": {
        "Provider": "ollama",
        "Model": "qwen3-coder",
        "Endpoint": "http://localhost:11434",
        "MaxTokensPerRequest": 4096,
        "Temperature": 0.3
      }
    },
    "Agents": {
      "ProgramManager": { "ModelTier": "premium", "Enabled": true },
      "Researcher": { "ModelTier": "standard", "Enabled": true },
      "Architect": { "ModelTier": "premium", "Enabled": true },
      "PrincipalEngineer": { "ModelTier": "premium", "Enabled": true },
      "TestEngineer": { "ModelTier": "standard", "Enabled": true },
      "SeniorEngineerTemplate": { "ModelTier": "standard" },
      "JuniorEngineerTemplate": { "ModelTier": "local" }
    },
    "Limits": {
      "EngineerPool": {
        "PrincipalEngineerPool": 2,
        "SeniorEngineerPool": 0,
        "JuniorEngineerPool": 0
      },
      "MaxDailyTokenBudget": 1000000,
      "GitHubPollIntervalSeconds": 30,
      "AgentTimeoutMinutes": 15,
      "MaxConcurrentAgents": 10,
      "MaxClarificationRoundTrips": 5,
      "MaxReworkCycles": 3,
      "MaxArchitectReworkCycles": 3,
      "MaxPmReworkCycles": 3,
      "MaxTestReworkCycles": 2,
      "MaxSourceBugRounds": 2,
      "SelfCompletionThresholdMinutes": 10,
      "MinParallelizableTasksForNewEngineer": 3
    },
    "Dashboard": {
      "Port": 5050,
      "EnableSignalR": true
    },
    "CopilotCli": {
      "Enabled": true,
      "ExecutablePath": "copilot",
      "MaxConcurrentRequests": 4,
      "RequestTimeoutSeconds": 3600,
      "ModelName": "gpt-5.4-mini",
      "AutoApprovePrompts": true,
      "SilentMode": true,
      "JsonOutput": false,
      "FastMode": false,
      "FastModeModel": "claude-haiku-4.5",
      "SinglePassMode": false,
      "MaxRetries": 3,
      "ExcludedTools": [],
      "WorkingDirectory": null,
      "ReasoningEffort": null,
      "AdditionalArgs": null
    },
    "Workspace": {
      "RootPath": "C:\\Agents",
      "BuildCommand": "dotnet build",
      "TestCommand": "dotnet test --verbosity normal",
      "UnitTestCommand": null,
      "IntegrationTestCommand": null,
      "UITestCommand": null,
      "UnitTestTimeoutSeconds": 60,
      "IntegrationTestTimeoutSeconds": 180,
      "UITestTimeoutSeconds": 300,
      "EnableUITests": true,
      "UITestsOnly": false,
      "PlaywrightBrowsersCachePath": null,
      "PlaywrightHeadless": true,
      "AppStartCommand": null,
      "AppBaseUrl": "http://localhost:5000",
      "AppStartupTimeoutSeconds": 90,
      "BuildTimeoutSeconds": 120,
      "TestTimeoutSeconds": 300,
      "MaxBuildRetries": 3,
      "MaxTestRetries": 3,
      "CleanupOnProjectComplete": true,
      "GitUserName": "AgentSquad",
      "GitUserEmail": "agentsquad@noreply.github.com",
      "TestWorkflow": "inline",
      "CaptureScreenshots": true,
      "ScreenshotRenderDelaySeconds": 5,
      "RecordTestVideos": true,
      "RecordTestTraces": true,
      "TestResultsDir": "test-results"
    },
    "HumanInteraction": {
      "Enabled": false,
      "Gates": {
        "ProjectKickoff": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "AgentTeamComposition": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "ResearchFindings": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "ResearchCompleteness": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "PMSpecification": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "ArchitectureDesign": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "EngineeringPlan": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "TaskAssignment": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "PRCodeComplete": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "PRReviewApproval": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "ReworkExhaustion": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "SourceBugEscalation": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "TestResults": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "TestScreenshots": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "FinalPRApproval": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "FinalReview": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" },
        "DeploymentDecision": { "RequiresHuman": false, "TimeoutMinutes": 0, "FallbackAction": "auto-approve" }
      }
    }
  }
}
